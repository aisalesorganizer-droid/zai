            "text": "{\"code\":0,\"msg\":\"success\",\"data\":[{\"scene\":\"file-tool\",\"options\":{\"tools\":{\"id\":\"opt-oYlJdg\",\"type\":\"tools\",\"refer\":\"categories\",\"contents\":{\"cn\":\"工具\",\"en\":\"tools\"},\"cascades\":{\"item-DMeUqG\":[{\"id\":\"item-atquDN\",\"type\":\"tool\",\"contents\":{\"cn\":\"指定大小压缩\",\"en\":\"Compress by Size\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"指定大小压缩\",\"en\":\"Compress by Size\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-SDUCZt\",\"type\":\"tool\",\"contents\":{\"cn\":\"指定压缩等级\",\"en\":\"Compress by Level\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"指定压缩等级\",\"en\":\"Compress by Level\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"item-XYkuJs\":[{\"id\":\"item-2K9H8N\",\"type\":\"tool\",\"contents\":{\"cn\":\"PDF转Word\",\"en\":\"PDF to Word\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"PDF转Word\",\"en\":\"PDF to Word\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-mTWACh\",\"type\":\"tool\",\"contents\":{\"cn\":\"Word转PDF\",\"en\":\"Word to PDF\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"Word转PDF\",\"en\":\"Word to PDF\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-zCOGV6\",\"type\":\"tool\",\"contents\":{\"cn\":\"JPG转PDF\",\"en\":\"JPG to PDF\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"JPG转PDF\",\"en\":\"JPG to PDF\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"item-fe4Won\":[{\"id\":\"item-APn9NI\",\"type\":\"tool\",\"contents\":{\"cn\":\"拆分文件\",\"en\":\"Split File\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"拆分文件\",\"en\":\"Split File\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-aTmq9X\",\"type\":\"tool\",\"contents\":{\"cn\":\"合并文件\",\"en\":\"Merge Files\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"合并文件\",\"en\":\"Merge Files\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-M7rj65\",\"type\":\"tool\",\"contents\":{\"cn\":\"提取内容\",\"en\":\"Extract Content\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"提取内容\",\"en\":\"Extract Content\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-WVpueg\",\"type\":\"tool\",\"contents\":{\"cn\":\"分析搜索\",\"en\":\"Search Analysis\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"分析搜索\",\"en\":\"Search Analysis\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}]},\"items\":[],\"templates\":{\"cn\":\"选择文件工具: {tool}\",\"en\":\"Choose file tool: {tool}\"}},\"categories\":{\"id\":\"opt-4anmlF\",\"type\":\"categories\",\"refer\":\"\",\"contents\":{\"cn\":\"类型\",\"en\":\"categories\"},\"cascades\":{},\"items\":[{\"id\":\"item-XYkuJs\",\"type\":\"category\",\"contents\":{\"cn\":\"格式转换\",\"en\":\"Format Conversion\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"格式转换\",\"en\":\"Format Conversion\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-DMeUqG\",\"type\":\"category\",\"contents\":{\"cn\":\"文件压缩\",\"en\":\"Compress File\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"文件压缩\",\"en\":\"Compress File\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-fe4Won\",\"type\":\"category\",\"contents\":{\"cn\":\"文件处理\",\"en\":\"File Processing\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"文件处理\",\"en\":\"File Processing\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"templates\":{\"cn\":\"选择文件工具类型: {category}\",\"en\":\"Choose file tool category: {category}\"}}},\"created_at\":1769511209,\"updated_at\":1770383096},{\"scene\":\"ai-slides\",\"options\":{\"prompts\":{\"id\":\"opt-t5r3MN\",\"type\":\"prompts\",\"refer\":\"\",\"contents\":{\"cn\":\"推荐提示词\",\"en\":\"Recommended Prompts\"},\"cascades\":{},\"items\":[{\"id\":\"item-YrQYLB\",\"type\":\"prompt\",\"contents\":{\"cn\":\"设计一份面向全球投资者的企业级风险敞口分析报告演示文稿，内容需详细拆解当前的关键风险数据，展示具体的风险缓解试点案例，并制定分阶段战略路线图。整体风格应强调“精准溯源”与数据驱动，视觉采用极致理性的暗色数据风格，以石墨黑（#0B0F14）作为全局底色，所有图表与数据面板均采用钴蓝（#2563EB），使用冷灰（#6B7280）、薄荷青（#2DD4BF）作为辅助色，旨在证明主动式风险管理的商业价值并确立企业的稳健治理形象。\",\"en\":\"Design a presentation for a corporate-level risk exposure analysis report for global investors. The presentation should detail current key risk data, showcase specific risk mitigation pilot cases, and outline a phased strategic roadmap. The overall style should emphasize \\\"precise tracing\\\" and data-driven approaches, employing a highly rational, dark data style with graphite black (#0B0F14) as the overall background color. All charts and data panels should use cobalt blue (#2563EB), with cool gray (#6B7280) and mint green (#2DD4BF) as secondary colors. This aims to demonstrate the commercial value of proactive risk management and establish a robust corporate governance image.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"准备一个面向全球投资者的企业级风险敞口分析报告演示文稿\",\"en\":\"Prepare an enterprise-level risk exposure analysis report presentation for global investors\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-6DFfB4\",\"type\":\"prompt\",\"contents\":{\"cn\":\"设计一份关于“品牌交响乐编曲法”的营销方法论演示文稿，目的是向企业决策者展示如何通过和谐一致的品牌乐章增强情感连接并巩固用户忠诚，内容应涵盖“序曲-展开-高潮”的三乐章叙事结构、基于乐谱美学的视觉呈现规范，以及量化的受众共鸣度与参与度提升数据。整体视觉基调采用终端黑（#050505）作为主背景色，所有动态过渡、章节分隔页及核心概念图示均以荧光酸橙（#84C016）勾勒轮廓。\",\"en\":\"Design a marketing methodology presentation on the \\\"Brand Symphony Arrangement Method.\\\" The goal is to show corporate decision-makers how to enhance emotional connections and solidify user loyalty through a harmonious brand symphony. The content should cover a three-movement narrative structure of \\\"overture-development-climax,\\\" visual presentation guidelines based on musical score aesthetics, and quantifiable data on increased audience resonance and engagement. The overall visual tone uses terminal black (#050505) as the main background color. All dynamic transitions, chapter separators, and core concept diagrams are outlined in fluorescent lime (#84C016).\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"创建一个关于 “品牌交响乐编曲法” 的营销方法论演示文稿\",\"en\":\"Create a marketing methodology presentation on the Brand Symphony Arrangement Method\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-vXAqTK\",\"type\":\"prompt\",\"contents\":{\"cn\":\"设计一份针对专业院校教育者的培训演示文稿，核心主题是如何将传统课程讲授从单向的知识传递升级为具有沉浸式体验的探索工坊，遵循教育理念演进 → 学习环境构建 → 教学工具集成 → 学习成果内化的逻辑框架，必须包含具体的教学实施标准，视觉体系采用学术奢华主义取向，整体以深岩灰（#2E2E2E）作为页面基底，章节标题与关键概念统一使用暗金色（#BFA76A）装饰元素严格限制为细线与框线。\",\"en\":\"Design a training presentation for professional educators. The core theme is how to upgrade traditional lectures from one-way knowledge transmission to immersive exploration workshops. Follow the logical framework of educational philosophy evolution → learning environment construction → teaching tool integration → learning outcome internalization. It must include specific teaching implementation standards. The visual system adopts an academic luxury approach, using dark rock gray (#2E2E2E) as the page base. Chapter titles and key concepts use dark gold (#BFA76A) decorative elements, strictly limited to thin lines and borders.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"设计一个面向专业院校教育者的沉浸式探索工坊培训演示文稿\",\"en\":\"Design a training presentation for educators in professional colleges on immersive exploration workshops\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-xPhPHk\",\"type\":\"prompt\",\"contents\":{\"cn\":\"设计一份针对连锁餐饮集团门店运营部门的2025财年年度绩效总结与战略规划演示文稿。内容需全面回顾财务表现、核心菜品里程碑及运营服务效能指标。整体采用 “珍珠白”（#F8FAFC）作为背景底色，核心数据使用 “普鲁士蓝”（#1E3A8A）作为主色，关键增长点运用 “活力橙”（#F97316）作为强调色。整体演示文稿应包含具体的顾客满意案例，并提出针对2026年的战略建议，如数字化点餐系统升级、健康轻食产品线拓展及数据分析专家引进。\",\"en\":\"Design a 2025 fiscal year annual performance summary and strategic planning presentation for the store operations department of a chain restaurant group. The content must comprehensively review financial performance, core dish milestones, and operational service efficiency indicators. The overall presentation uses \\\"Pearl White\\\" (#F8FAFC) as the background color, with \\\"Prussian Blue\\\" (#1E3A8A) as the primary color for core content such as financial data and KPI indicators, and \\\"Graphite Gray\\\" (#4B5563) for secondary information and charts, ensuring a clear and concise information structure. \\\"Vibrant Orange\\\" (#F97316) is used as the accent color for key growth points. The presentation should also include specific customer satisfaction case studies and strategic recommendations for 2026, such as upgrading the digital ordering system, expanding the healthy light meal product line, and bringing in data analytics experts. The overall style should reflect a high degree of rationality and order, aiming to demonstrate to management the operations team's \\\"standardized service\\\" and future \\\"scalable replication capabilities.\\\"\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"准备一个针对连锁餐饮集团门店运营部门的 2025 财年绩效总结与战略规划演示文稿\",\"en\":\"Prepare a FY2025 performance summary and strategic planning presentation for the store operations department of a chain catering group\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"templates\":{\"cn\":\"使用推荐提示词: {prompt}\",\"en\":\"Use recommended prompt: {prompt}\"}}},\"created_at\":1769511208,\"updated_at\":1770383097},{\"scene\":\"artifact\",\"options\":{\"prompts\":{\"id\":\"opt-4n6EfR\",\"type\":\"prompts\",\"refer\":\"projects\",\"contents\":{\"cn\":\"推荐提示词\",\"en\":\"Recommended Prompts\"},\"cascades\":{\"item-2brEeI\":[{\"id\":\"item-HSj4B7\",\"type\":\"prompt\",\"contents\":{\"cn\":\"创建一个名为“构建日志”的个人博客和项目日志。\\n目标：\\n公开记录产品开发过程中的项目、实验和经验教训。\\n核心功能：\\n首页采用时间轴式布局，展示帖子和已完成的项目\\n项目详情页面，包含屏幕截图、堆栈标签和状态标签\\n“每周更新”栏目，包含更新日志式的帖子\\n打开指标面板（访客、订阅者、已发布项目）\\n新闻简报和 GitHub 的行动号召按钮\\n页脚简洁，包含许可信息和联系信息。\\n视觉风格：\\n简约、实用、以创客为导向。\\n颜色：米白色背景，炭灰色文字，荧光绿高光。\",\"en\":\"Create a personal blog and project log called “Build Log”.\\nGoal:\\n Document projects, experiments, and lessons learned while building products in public.\\nCore Features:\\nTimeline-style homepage showing posts and shipped projects\\nProject detail pages with screenshots, stack tags, and status labels\\n“Weekly Updates” section with changelog-style posts\\nOpen metrics panel (visitors, subscribers, shipped projects)\\nCall-to-action buttons for newsletter and GitHub\\nMinimal footer with licensing and contact info\\nVisual Style:\\n Minimal, utilitarian, maker-oriented.\\n Colors: Off-white background, charcoal text, neon green highlights.\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/image4.png?auth_key=1801862921-581083d9bdea49fbbeded189fbaebbfb-0-84765028f064e72b865f2b1cd7d55949\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/f875af75-0e3e-46a4-86fd-388e4e75f340\",\"en\":\"https://chat.z.ai/s/688ed891-78d6-4986-8f8d-837a7b1258e4\"},\"labels\":{\"cn\":\"个人博客 推荐提示词1\",\"en\":\"Personal Blog Recommended Prompt 1\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-WLPe4N\",\"type\":\"prompt\",\"contents\":{\"cn\":\"创建一个名为“设计人生”的个人博客。\\n目标：\\n分享有意识生活的框架、习惯和个人系统。\\n核心功能：\\n首页包含特色框架和最新文章\\n文章围绕原则、工具和反思展开\\n帖子中嵌入了习惯仪表盘和系统图\\n年度回顾和长期目标页面\\n主题系列邮件订阅\\n页脚包含个人宣言和联系链接\\n视觉风格：\\n冷静、有条理、乐观。\\n颜色：柔和的米色、鼠尾草绿、暖灰色。\",\"en\":\"Build a personal blog called “Life by Design”.\\nGoal:\\n Share frameworks, habits, and personal systems for intentional living.\\nCore Features:\\nHomepage with featured frameworks and recent posts\\nArticles structured around principles, tools, and reflections\\nHabit dashboards and system diagrams embedded in posts\\nYearly reviews and long-term goal pages\\nEmail subscription with themed series\\nFooter with personal manifesto and contact link\\nVisual Style:\\n Calm, structured, and optimistic.\\n Colors: Soft beige, sage green, warm gray.\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/image5.png?auth_key=1801862921-7d4e68f2444447108987bb85c5ebd68d-0-ef84f66db4461b0338b69cef4bda4d35\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/f20d7eb5-2613-4ff8-a4da-1ff90c143784\",\"en\":\"https://chat.z.ai/s/6577fa88-e3a4-4095-9607-655904832088\"},\"labels\":{\"cn\":\"个人博客 推荐提示词2\",\"en\":\"Personal Blog Recommended Prompt 2\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-0YmDBU\",\"type\":\"prompt\",\"contents\":{\"cn\":\"创建一个名为“创意信号”的个人博客和作品集混合平台。\\n目标：\\n呈现科技与艺术交汇处的思考、实验和创意成果。\\n核心功能：\\n首页包含精选文章和互动演示\\n支持富媒体（视频、Canvas、WebGL 嵌入）的博客文章\\n实验部分展示互动项目\\n个人时间线，突出关键里程碑\\n联系与合作咨询表\\n页脚包含精选链接和灵感\\n视觉风格：\\n现代、实验性、富有表现力。\\n颜色：深黑色背景，柔和的白色文字，微妙的渐变色点缀。\",\"en\":\"Create a personal blog and portfolio hybrid called “Creative Signals”.\\nGoal:\\n Present thoughts, experiments, and creative outputs at the intersection of technology and art.\\nCore Features:\\nHomepage with featured writings and interactive demos\\nBlog posts supporting rich media (video, canvas, WebGL embeds)\\nExperiments section showcasing interactive projects\\nPersonal timeline highlighting key milestones\\nContact and collaboration inquiry form\\nFooter with curated links and inspirations\\nVisual Style:\\n Modern, experimental, and expressive.\\n Colors: Deep black background, soft white text, subtle gradient accents.\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/image8.png?auth_key=1801907441-e59b5f6c96c548978ff4d3e73929d71c-0-5ee0d52cce9b5ee348ac465a42cee5c0\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/ec21c148-836c-4682-89a6-3858abc5a255\",\"en\":\"https://chat.z.ai/s/ea831a69-6d95-4bd6-9682-bff5cefc2f3b\"},\"labels\":{\"cn\":\"个人博客 推荐提示词3\",\"en\":\"Personal Blog Recommended Prompt 3\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"item-2et4KS\":[{\"id\":\"item-ilX4tO\",\"type\":\"prompt\",\"contents\":{\"cn\":\"构建一个名为 \\\"CyberBeat\\\" 的键盘节奏音游网页。 游戏核心是将落下的音符与背景音乐的节拍在判定线上精准匹配。\\n核心玩法机制：\\n4轨道下落式设计（对应键盘 D, F, J, K 键）\\n音符类型：普通单点音符（点击）、长条音符（按住）\\n判定系统：Perfect (金色特效), Great (绿色), Miss (红色打叉)\\n连击系统（Combo）：连续击中会累积Combo数，Miss则清零，屏幕中央有动态放大的Combo计数\\n包含一首内置的快节奏电子合成器音乐（使用Web Audio API生成或Base64编码的短循环）\\n视觉风格与动效：\\n赛博朋克美学：深紫色背景 (#0f0c29)，搭配霓虹蓝 (#00f260) 和 激光粉 (#0575E6) 的轨道线条\\n判定线要有“呼吸”发光效果\\n按键按下时，轨道底部产生垂直的激光束动画\\n界面采用 HUD 抬头显示风格，分数在左上角，血条在右上角\\n页面结构与交互：\\n开始界面：复古街机风格 Logo，闪烁的 \\\"INSERT COIN / START\\\" 提示\\n结算界面：评级显示 (S/A/B/C)，雷达图展示（准确度、连击、反应速度），以及“重试”按钮\\n移动端适配：检测到移动端时，在屏幕下方显示4个巨大的透明触摸按钮代替键盘\\n技术要求：\\n使用 requestAnimationFrame 确保 60FPS 流畅度\\n必须实现音画同步逻辑，设定延迟校准变量\\n所有图形通过 HTML5 Canvas 绘制\\n生成单一 HTML 文件，内嵌 CSS 和 JS\",\"en\":\"Build a keyboard rhythm game webpage named \\\"CyberBeat\\\". The core of the game is to precisely match the falling notes with the beats of the background music on the judgment line.\\nCore Gameplay Mechanics:4-track falling design (corresponding to the D, F, J, K keys on the keyboard)Note types: Normal single notes (click), hold notes (press and hold)Judgment system: Perfect (golden visual effects), Great (green), Miss (red cross)Combo system: Consecutive hits accumulate the combo count, which resets to zero on a Miss; a dynamically enlarged combo counter is displayed in the center of the screenIncorporate a built-in up-tempo electronic synth track (generated via the Web Audio API or a short Base64-encoded loop)\\nVisual Style & Animations:Cyberpunk aesthetic: Deep purple background (#0f0c29) paired with neon blue (#00f260) and laser pink (#0575E6) track linesThe judgment line features a breathing glow effectA vertical laser beam animation appears at the bottom of the track when a key is pressedHUD (Heads-Up Display) style interface, with the score in the top-left corner and the health bar in the top-right corner\\nPage Structure & Interaction:Start screen: Retro arcade-style logo with a flashing \\\"INSERT COIN / START\\\" promptResult screen: Rating display (S/A/B/C), radar chart (Accuracy, Combo, Reaction Speed), and a \\\"Retry\\\" buttonMobile adaptation: 4 large transparent touch buttons are displayed at the bottom of the screen to replace the keyboard when a mobile device is detected\\nTechnical Requirements:Use requestAnimationFrame to ensure a smooth 60FPS frame rateAudio-visual synchronization logic must be implemented with a delay calibration variableAll graphics are drawn with HTML5 CanvasGenerate a single HTML file with embedded CSS and JavaScript\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/game3.png?auth_key=1801921988-1ba3a90427b4453d908575921c28e8eb-0-9e79b4e3e280ecee525b2ca4288ae6b5608be29224d-0-ce7eb079b18a86ef0d28d1d927b3c78b\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/4799bf15-6938-491d-a744-0d0efb88bf5d\",\"en\":\"https://chat.z.ai/s/b4260d4d-0cba-4566-9ae3-4705d5d60fc1\"},\"labels\":{\"cn\":\"小游戏 推荐提示词1\",\"en\":\"Mini Game Recommended Prompt 1\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-FIM38v\",\"type\":\"prompt\",\"contents\":{\"cn\":\"请设计一个具有蒸汽波（Vaporwave）风格的精美记忆翻牌网页游戏应用，具体要求如下：\\n1. 核心玩法\\n标准记忆翻牌玩法\\n玩家每次翻开两张卡片，若图案一致则消除\\n直至所有卡片配对完成游戏结束\\n2. 视觉设计\\n蒸汽波主题：紫粉渐变背景、霓虹网格、日落元素\\n主色调：霓虹粉（#FF77FF）、青蓝（#00FFFF）、深紫背景\\n卡片采用玻璃拟态（Glassmorphism）效果\\n背景可加入轻微动态噪声或慢速渐变动画\\n3. 卡片设计\\n卡片正面为蒸汽波风格图标（雕塑、磁带、棕榈树等）\\n翻转动画使用 3D rotateY\\n已配对卡片变为半透明并锁定\\n当前翻开的卡片添加霓虹外发光效果\\n4. 交互增强\\n错误配对时卡片轻微左右晃动\\n成功配对触发粒子闪光效果\\n支持点击与键盘操作（Enter / Space）\\n5. 难度系统\\n简单：4×4（8 对）\\n中等：6×6（18 对）\\n困难：8×8（32 对）\\n6. 辅助功能\\n步数计数与用时统计\\n一键重开\\n移动端自适应布局\\n7. 布局要求\\n顶部标题区 + 中央卡片区 + 底部控制栏\\n单 HTML 文件实现\",\"en\":\"Please design an exquisite memory matching card game web application in a Vaporwave style with the following specific requirements:\\nCore Gameplay\\nStandard memory matching card gameplay\\nPlayers flip two cards each time; the pair will be eliminated if the patterns match\\nThe game ends when all card pairs are matched and completed\\nVisual Design\\nVaporwave theme: purple-pink gradient background, neon grid, sunset elements\\nPrimary color palette: neon pink (#FF77FF), cyan blue (#00FFFF), dark purple background\\nCards adopt the Glassmorphism effect\\nA slight dynamic noise or slow gradient animation can be added to the background\\nCard Design\\nThe front of the cards features Vaporwave-style icons (sculptures, cassettes, palm trees, etc.)\\n3D rotateY is used for the flip animation\\nMatched cards become translucent and locked\\nA neon outer glow effect is added to the currently flipped cards\\nInteraction Enhancements\\nCards shake slightly left and right for incorrect matches\\nA particle flash effect is triggered for successful matches\\nSupports click and keyboard controls (Enter / Space)\\nDifficulty System\\nEasy: 4×4 grid (8 pairs)\\nMedium: 6×6 grid (18 pairs)\\nHard: 8×8 grid (32 pairs)\\nAuxiliary Functions\\nStep count and time statistics\\nOne-click restart\\nMobile-adaptive layout\\nLayout Requirements\\nTop title area + central card area + bottom control bar\\nImplemented as a single HTML file\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/game2.png?auth_key=1801920024-69c8968d249e47a290edea3e2e547ae3-0-3ad30339c883d1cea19321ff507c26b0\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/a37652fb-7297-451c-b50e-26027477e723\",\"en\":\"https://chat.z.ai/s/b531d8bf-4604-4298-b2f3-22ad2e52a7d2\"},\"labels\":{\"cn\":\"小游戏 推荐提示词2\",\"en\":\"Mini Game Recommended Prompt 2\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-FsZsmi\",\"type\":\"prompt\",\"contents\":{\"cn\":\"帮我 clone 这个 repo：https://github.com/wayou/t-rex-runner\\n 目标：本地运行可玩的 Dino 跑酷游戏，并加入现代化外观（霓虹边框、渐变背景、动效），同时支持键盘与触屏操作。\\n 要求：\\n一键启动本地 server 并验证可玩\\n提供可配置项：重力、速度增长、障碍生成频率（用一个简单设置面板或常量区）\\n增加暂停/继续与重新开始按钮\\n给出部署到 Vercel 或 GitHub Pages 的最简流程\\n 输出：运行命令、改动说明、部署步骤\",\"en\":\"Help me clone this repo: https://github.com/wayou/t-rex-runnerObjective: Get a playable local version of the Dino Runner game up and running, revamp it with a modern visual style (neon borders, gradient backgrounds, dynamic effects), and add support for both keyboard and touch controls.Requirements:\\nOne-click local server launch and playability verification\\nConfigurable options: gravity, speed increment, obstacle spawn rate (via a simple settings panel or a constant section)\\nAdd pause/resume and restart buttons\\nProvide the simplest deployment workflow to Vercel or GitHub Pages\\nOutput: Run commands, modification notes, deployment steps\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/game1.png?auth_key=1801920024-b9725c2e8c3340dfa551c98cca66719c-0-f7614e427235a31939b79694aca55c6d\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/35543abd-3638-480b-8b76-024957ed0f15\",\"en\":\"https://chat.z.ai/s/5e2fedfd-6292-425b-8dbd-ed95ff436706\"},\"labels\":{\"cn\":\"小游戏 推荐提示词3\",\"en\":\"Mini Game Recommended Prompt 3\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"item-QNNEHu\":[{\"id\":\"item-kwUFyA\",\"type\":\"prompt\",\"contents\":{\"cn\":\"创建一个3D分子结构可视化工具（如水分子、苯环、DNA双螺旋等）。用户可以通过下拉菜单切换不同分子，使用按钮切换显示模式（球棍模型/空间填充模型）。提供自动旋转功能和手动拖拽旋转，支持高亮显示特定原子及其化学键信息。\",\"en\":\"Create a 3D molecular structure visualization tool (such as water molecule, benzene ring, DNA double helix, etc.). Users can switch between different molecules via a dropdown menu and use buttons to switch display modes (ball-and-stick model/space-filling model). It provides an automatic rotation function and manual drag-and-drop rotation, and supports highlighting specific atoms and displaying information about their chemical bonds.\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/edu1.png?auth_key=1801921988-e032a5cbef284b7ea5ba4e1a867635d5-0-1e2e21253267e479931583a78ea650e8\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/04bb9705-075e-4f0a-98cc-380d228dc962\",\"en\":\"https://chat.z.ai/s/50450fad-afdd-4132-8233-aaf4c7e25436\"},\"labels\":{\"cn\":\"3D建模 推荐提示词1\",\"en\":\"3D Modeling Recommended Prompt 1\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-z02oDN\",\"type\":\"prompt\",\"contents\":{\"cn\":\"创建一个机械键盘轴体（Switch）内部运作原理的可视化工具。场景为一个半透明外壳的机械轴体（类似Cherry MX结构）。\\n- 按压交互：提供一个“按压测试”的大按钮或允许用户直接点击轴心。当按下时，轴心（Stem）向下移动，压缩内部的螺旋弹簧，并推动金属触片接触。\\n- 触发反馈：当金属触片闭合的瞬间，接触点产生高亮的电火花特效或发光脉冲，表示信号已触发。\\n- 轴体切换（换色/换结构）：\\n  - 线性轴（红轴）：轴心为红色，直上直下，无段落感。\\n  - 段落轴（青轴）：轴心为蓝色，内部增加一个分体式的发声结构（Clicky Jacket），下压时会有一个明显的跳动动画。\\n- 剖面模式：提供“侧剖面（Cutaway）”视图，将轴体的一半切除，清晰展示内部金属弹片的弯曲变形过程和弹簧的压缩状态。\",\"en\":\"# Mechanical Keyboard Switch Internal Mechanism Visualization Tool\\n\\nCreate a **visualization tool for the internal working principles of a mechanical keyboard switch**. The scene features a mechanical switch with a semi-transparent housing (similar to Cherry MX structure).\\n\\n---\\n\\n## Press Interaction\\n\\n- Provide a large \\\"Press Test\\\" button or allow users to directly click on the stem\\n- When pressed, the Stem moves downward, compressing the internal coil spring and pushing the metal contact leaves together\\n\\n---\\n\\n## Trigger Feedback\\n\\n- At the instant the metal contact leaves close, the contact point produces a highlighted electric spark effect or glowing pulse, indicating the signal has been triggered\\n\\n---\\n\\n## Switch Type Toggle (Color/Structure Switching)\\n\\n### Linear Switch (Red Switch)\\n- Stem is red\\n- Straight up and down movement\\n- No tactile bump\\n\\n### Tactile/Clicky Switch (Blue Switch)\\n- Stem is blue\\n- Includes an additional split-piece sound-producing structure (Clicky Jacket) internally\\n- A noticeable snapping/jumping animation occurs during the downstroke\\n\\n---\\n\\n## Cutaway Mode\\n\\n- Provide a \\\"Side Cutaway\\\" view\\n- Cuts away half of the switch housing\\n- Clearly displays the bending and deformation process of the internal metal contact leaves\\n- Shows the compression state of the spring\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/3d1.png?auth_key=1801922759-c151681619e04e3bb6cd07b75a6a696a-0-4bf41dded5a642db0f1d72d5bf83b1d6\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/cb652380-2ac7-4730-995b-8e0887e987a2\",\"en\":\"https://chat.z.ai/s/7f52ff3f-221b-411a-a8c2-d4432d148fa1\"},\"labels\":{\"cn\":\"3D建模 推荐提示词2\",\"en\":\"3D Modeling Recommended Prompt 2\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-hKY5qd\",\"type\":\"prompt\",\"contents\":{\"cn\":\"创建一个程序化生成的3D星球模型，使用柏林噪声生成随机地形。提供按钮重新生成星球、调整地形粗糙度、海平面高度和旋转速度。可以切换不同的着色模式（高度图/温度图/湿度图）。支持昼夜循环效果和大气层渲染。\",\"en\":\"Create a procedurally generated 3D planet model, using Perlin noise to generate random terrain. Provide buttons to regenerate the planet, adjust terrain roughness, sea level height, and rotation speed. Different shading modes (height map/temperature map/humidity map) can be toggled. Supports day-night cycle effects and atmospheric rendering.\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/edu2.png?auth_key=1801921988-56b7743f96c14e9b8266bee6e4459862-0-eab088e733d4d7ac433f51e197a4eff3\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/41c6e7c1-bcb6-484a-b7af-a3f4d5b76f05\",\"en\":\"https://chat.z.ai/s/3e950efc-a7c0-4abc-b8ac-1787f4540d9b\"},\"labels\":{\"cn\":\"3D建模 推荐提示词3\",\"en\":\"3D Modeling Recommended Prompt 3\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"item-Th7Pdr\":[{\"id\":\"item-ohLaae\",\"type\":\"prompt\",\"contents\":{\"cn\":\"设计一个独立精品咖啡品牌官网，强调“产地、时间与手工感”，拒绝连锁咖啡的商业语境。\\n视觉策略：\\n 意象：咖啡豆烘焙前后对比、手写标签、磨损的操作台面。\\n 摄影：自然光、偏暖色调，允许颗粒与轻微失焦。\\n 视角：大量近景与手部特写。\\n配色方案：\\n 主色：深棕、奶油白、烘焙色。\\n 点缀：极少量深绿或靛蓝。\\n 背景：纸张或布料质感。\\n字体排版：\\n 标题：带轻微人文气质的衬线体。\\n 正文：可读性优先，模拟印刷品排版。\\n 文字与图片保持清晰边界。\\n页面结构：\\n 首屏：静物大图 + 一句关于时间或风味的短句。\\n 豆子介绍：按产区展示，每个产区一个独立页面节奏。\\n 制作过程：线性叙事，从生豆到杯中。\\n 订阅与购买：低调呈现，不打断浏览节奏。\\n整体气质：温暖、真实、慢节奏、有手工痕迹。\",\"en\":\"Design an official website for an independent specialty coffee brand that emphasizes \\\"origin, time, and craftsmanship,\\\" rejecting the commercial context of chain coffee shops.\\nVisual strategy:\\nImagery: Before and after coffee bean roasting, handwritten labels, and a worn-out work surface.\\nPhotography: Natural light, warm tones, grain and slight out-of-focus are permissible.\\nPerspective: Numerous close-ups and hand shots.\\nColor scheme:\\nMain colors: dark brown, cream white, and baked color.\\nAccents: A very small amount of dark green or indigo.\\nBackground: Paper or fabric texture.\\nTypography:\\nTitle: Serif font with a slightly humanistic touch.\\nBody text: Readability is prioritized, and the layout is modeled after printed materials.\\nMaintain clear boundaries between text and images.\\nPage structure:\\nFirst screen: Large still life image + a short sentence about time or flavor.\\nBean introduction: Displayed by production area, with each production area on a separate page.\\nProduction process: linear narrative, from green beans to the cup.\\nSubscriptions and purchases: presented discreetly, without interrupting the browsing experience.\\nOverall feel: warm, authentic, slow-paced, and with traces of handcraftsmanship.\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/image1.png?auth_key=1801860326-416a190b09b14a18b0a63c7b684f0395-0-e1deaa18c381932e40f050eb31c1af54\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/64ecd7a4-9c13-4156-ac78-08a66eaa294a\",\"en\":\"https://chat.z.ai/s/315de18d-8bae-4172-8d21-3467c7a315b3\"},\"labels\":{\"cn\":\"落地页 推荐提示词1\",\"en\":\"Landing Page Recommended Prompt 1\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-EscpZM\",\"type\":\"prompt\",\"contents\":{\"cn\":\"为一款名为“Aura Home”的高端全屋智能家居系统设计产品官网。 网站应剥离传统科技产品的“硬核”参数感，转而强调“科技隐形”与“生活美学”的融合。 核心理念：最好的科技是让你感觉不到科技的存在，只感受到舒适。 视觉策略： 核心画面： 晨光透过白色纱帘洒在极简风格的客厅，空气中漂浮着微尘。智能面板完美融入墙面，几乎不可见。 光影运用： 强调自然光与室内氛围灯的无缝过渡，模拟一天中不同时间段（清晨、正午、黄昏、深夜）的光线变化。 材质： 哑光肤感涂层、温润的浅色橡木、透光的磨砂玻璃。 配色方案： 主色调： 暖灰、云母白、亚麻色。 辅助色： 极淡的暖橙色（光晕颜色）和深空灰（文字）。 避免使用： 科技蓝、高饱和度色彩、锐利的金属反光。 字体排版： 标题： 纤细、优雅的无衬线字体（如 Helvetica Now Thin），字间距开阔，传递呼吸感。 正文： 经典的衬线体，营造一种阅读家居杂志的松弛感。 页面结构： Hero 区域： 全屏沉浸式视频。用户滚动时，视频从“离家模式”（灯光熄灭、窗帘合拢）平滑过渡到“回家模式”（暖光亮起、音乐流淌）。 交互演示： 一个“看不见的控制”板块。鼠标移动模拟人的动线，周围环境（灯光、温度数值）随之柔和变化，而非硬生生的开关切换。 场景叙事： 分屏布局。左侧是生活场景（如阅读、沐浴），右侧是对应的智能场景预设文案，中间通过一条流动的光线连接。 技术参数： 将传感器精度、芯片算力等参数隐藏在“折叠卡片”中，默认只展示“0.1秒极速响应”等体验型文案。 整体气质： 空灵、静谧、甚至带有一丝禅意。\",\"en\":\"Design the official website for a high-end smart home system called \\\"Aura Home\\\". The website should strip away the \\\"hardcore\\\" technical specifications of traditional tech products, instead emphasizing the fusion of \\\"invisible technology\\\" and \\\"lifestyle aesthetics\\\". Core concept: The best technology is technology you don't feel, only comfort. Visual strategy: Core image: Morning light filters through white sheer curtains into a minimalist living room, with dust particles floating in the air. The smart panel blends seamlessly into the wall, almost invisible. Light and shadow usage: Emphasize the seamless transition between natural light and ambient lighting, simulating the changing light at different times of day (morning, noon, dusk, and night). Materials: Matte finish, warm light oak, and translucent frosted glass. Color scheme: Main colors: Warm gray, mica white, and linen. Secondary colors: Very pale warm orange (halo color) and deep space gray (text). Avoid: Tech blue, highly saturated colors, and sharp metallic reflections. Typography: Headings: Slender, elegant sans-serif fonts (such as Helvetica Now Thin) with ample spacing, conveying a sense of breathability. Body Text: Classic serif fonts, creating a relaxed feel reminiscent of reading a home decor magazine. Page Structure: Hero Area: Full-screen immersive video. As the user scrolls, the video smoothly transitions from \\\"Away Mode\\\" (lights off, curtains closed) to \\\"Home Mode\\\" (warm lights on, music playing). Interactive Demonstration: An \\\"invisible control\\\" section. Mouse movement simulates human movement, and the surrounding environment (lights, temperature values) changes gently, rather than abruptly switching on and off. Scene Narrative: Split-screen layout. The left side displays everyday scenes (such as reading, bathing), and the right side displays corresponding smart scene preset text, connected by a flowing light strip. Technical Specifications: Sensor accuracy, chip computing power, and other parameters are hidden in \\\"folded cards,\\\" with only experiential text such as \\\"0.1-second ultra-fast response\\\" displayed by default. Overall Atmosphere: Ethereal, tranquil, and even with a touch of Zen.\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/image2.png?auth_key=1801860326-73c6ea51abbb463d8761b4ac829cbc60-0-28961355a639877764dc1cb49e665d35\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/5accd713-69f8-4ffd-9c09-ad080e40aee5\",\"en\":\"https://chat.z.ai/s/d84ead53-cd1f-4e4d-b58b-358bfb4eb371\"},\"labels\":{\"cn\":\"落地页 推荐提示词2\",\"en\":\"Landing Page Recommended Prompt 2\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-ZkjEPK\",\"type\":\"prompt\",\"contents\":{\"cn\":\"创建一个英文粉丝网页，以电影化的赛博朋克风格重温《银翼杀手》（1982）和《银翼杀手2049》。\\n英雄画面必须包含闪烁的霓虹灯标题和缓慢的视差城市景观。\\n核心部分：关键情节时间线、角色卡片（戴克/K/乔伊）、“主题”面板（身份、记忆）以及带有动画打字机揭示的引言墙。\\n视觉风格：雨夜、霓虹青色/品红色点缀、微妙的 CRT 扫描线、胶片颗粒和反射式 UI 表面。\\n加入响应式设计和悬停时的微交互（柔和发光、轻微扭曲）。\",\"en\":\"Build an English fan webpage that revisits Blade Runner (1982) + Blade Runner 2049, with a cinematic, cyber-noir tone.\\nHero must include a glitching neon marquee headline and a slow parallax cityscape.\\nCore sections: timeline of key plot beats, character cards (Deckard/K/Joi), “themes” panel (identity, memory), and a quote wall with animated typewriter reveal.\\nVisual style: rainy night, neon cyan/magenta accents, subtle CRT scanlines, film grain, and reflective UI surfaces.\\nInclude responsive design and micro-interactions on hover (soft glow, subtle distortion).\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/image3.png?auth_key=1801860766-9c5066ab9971451486ff4fb12d7888a1-0-e7c2f4dc015e09258696839809920ebe\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/fecfc75b-6368-4635-9a14-61ca1ca32ae0\",\"en\":\"https://chat.z.ai/s/57eaeb74-ea26-437c-939b-e3eab2442275\"},\"labels\":{\"cn\":\"落地页 推荐提示词3\",\"en\":\"Landing Page Recommended Prompt 3\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"item-yTOES2\":[{\"id\":\"item-WUecIA\",\"type\":\"prompt\",\"contents\":{\"cn\":\"请生成一个函数与图像动态演示教学工具，用于初中 / 高中数学课堂。\\n支持的函数类型：\\n一次函数 y=ax+b\\n二次函数 y=ax²+bx+c\\n反比例函数 y=k/x\\n功能要求：\\n参数调节：\\na、b、c、k 使用滑块实时调整\\n参数变化即时反映在图像上\\n图像展示：\\n坐标轴清晰标注\\n显示函数表达式\\n关键点高亮（顶点、交点）\\n教学辅助：\\n参数变化趋势说明\\n常见结论提示（如 a>0 开口向上）\\n支持多函数对比\\n视觉与交互：\\n浅色背景\\n高对比线条\\n操作简单直观\\n生成完整交互逻辑说明，确保数学关系正确。\",\"en\":\"Please generate a dynamic interactive teaching tool for demonstrating functions and graphs, designed for middle school and high school math classrooms.\\n\\n**Supported Function Types:**\\n*   Linear Function: $y = ax + b$\\n*   Quadratic Function: $y = ax^2 + bx + c$\\n*   Inverse Proportional Function: $y = k/x$\\n\\n**Feature Requirements:**\\n*   **Parameter Adjustment:** Use sliders to adjust parameters $a$, $b$, $c$, and $k$ in real-time. Changes to parameters must be reflected on the graph immediately.\\n*   **Graph Visualization:**\\n    *   Clearly labeled coordinate axes.\\n    *   Display the current function expression on screen.\\n    *   Highlight key points (e.g., vertex, intercepts).\\n*   **Educational Aids:**\\n    *   Provide explanations of how parameter changes affect the graph.\\n    *   Display common mathematical conclusions/tips (e.g., \\\"If $a > 0$, the parabola opens upwards\\\").\\n    *   Support comparison of multiple functions simultaneously.\\n*   **Visuals and Interaction:**\\n    *   Light background.\\n    *   High-contrast lines for the graph.\\n    *   Simple and intuitive user interface.\\n\\n**Output Requirement:**\\nGenerate the complete interactive logic (code), ensuring all mathematical relationships are accurate.\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/fx11.png?auth_key=1801917571-bb4ff39406e742049984fe5273062c99-0-4e361f20cd9bb5d5eb3c84ed1830dff5\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/68d9cabd-b5de-43cb-8660-0ed814d5815c\",\"en\":\"https://zai-test.chatglm.site/s/70f0829a-ec44-44b9-ac60-4c8ead81ce71\"},\"labels\":{\"cn\":\"科普/教案 推荐提示词1\",\"en\":\"Knowledge/Teaching Material Recommended Prompt 1\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-AkriAl\",\"type\":\"prompt\",\"contents\":{\"cn\":\"生成一个「几何光学虚拟实验室」网页，必须严格按照以下具体细节实现：\\n页面布局：\\n科技感深色背景，左右分栏布局\\n顶部：标题栏，包含重置与帮助按钮\\n左栏（30%）：控制面板，包含透镜选择、参数滑块、成像数据板\\n右栏（70%）：交互式光路Canvas画布\\n功能模块具体实现：\\n凸透镜成像实验 (Convex Lens)：\\n核心逻辑：基于高斯成像公式 1/f = 1/u + 1/v\\n默认参数：焦距 f=100, 物距 u=300, 物高 h=50\\n交互控制：拖动蜡烛改变物距，拖动透镜焦点改变焦距\\n光线绘制规则： a. 平行主光轴射入 -> 过焦点 b. 过光心 -> 传播方向不变 c. 过焦点射入 -> 平行主光轴射出\\n成像规律判断：\\nu > 2f: 倒立缩小实像\\nu = 2f: 倒立等大实像\\nf < u < 2f: 倒立放大实像\\nu < f: 正立放大虚像\\n凹透镜成像实验 (Concave Lens)：\\n核心逻辑：虚焦点发散规则\\n光线绘制规则： a. 平行主光轴射入 -> 反向延长线过虚焦点 b. 过光心 -> 传播方向不变\\n成像特点：始终为正立缩小虚像\\nCanvas 绘制规格：\\n坐标系：中心为原点 (0,0)，向右 x 正，向上 y 正\\n标尺：主光轴上每 50px 绘制刻度\\n元素样式：\\n物体（蜡烛）：橙色实线箭头\\n像：实像用青色实线箭头，虚像用青色虚线箭头\\n光线：入射光黄色，折射光绿色，虚像辅助线灰色虚线\\n焦点：F 点用“×”标记\\n数据实时显示面板：\\n实时计算放大率 M = v/u\\n实时显示像距 v\\n像的性质描述（如：“实像/虚像”、“放大/缩小”、“正立/倒立”）\\n技术要求：\\n使用 HTML5 Canvas 绘图\\n所有的光线交点必须通过解析几何方程精确计算\\n动画帧率不低于 60fps，拖动时无延迟\\n包含“一键演示”功能，自动演示物体从无穷远移动到焦点的过程\",\"en\":\"# Geometric Optics Virtual Laboratory - Specification\\nGenerate a \\\"Geometric Optics Virtual Laboratory\\\" webpage, must strictly implement according to the following specific details:\\n## Page Layout:\\n- Tech-style dark background, left-right split layout\\n- **Top**: Title bar with reset and help buttons\\n- **Left column (30%)**: Control panel including lens selection, parameter sliders, imaging data panel\\n- **Right column (70%)**: Interactive optical path Canvas\\n---\\n## Functional Module Implementation:\\n### Convex Lens Imaging Experiment (Convex Lens):\\n**Core Logic**: Based on Gaussian imaging formula `1/f = 1/u + 1/v`\\n**Default Parameters**:\\n- Focal length: f = 100\\n- Object distance: u = 300\\n- Object height: h = 50\\n**Interactive Controls**:\\n- Drag candle to change object distance\\n- Drag lens focal point to change focal length\\n**Ray Drawing Rules**:\\n- a. Parallel to principal axis → passes through focal point\\n- b. Through optical center → propagation direction unchanged\\n- c. Through focal point → exits parallel to principal axis\\n**Imaging Rules**:\\n- `u > 2f`: inverted, reduced, real image\\n- `u = 2f`: inverted, equal-sized, real image\\n- `f < u < 2f`: inverted, magnified, real image\\n- `u < f`: upright, magnified, virtual image\\n### Concave Lens Imaging Experiment (Concave Lens):\\n**Core Logic**: Virtual focal point divergence rules\\n**Ray Drawing Rules**:\\n- a. Parallel to principal axis → backward extension passes through virtual focal point\\n- b. Through optical center → propagation direction unchanged\\n**Imaging Characteristics**: Always upright, reduced, virtual image\\n---\\n## Canvas Drawing Specifications:\\n**Coordinate System**:\\n- Origin at center (0, 0)\\n- x-axis positive to the right\\n- y-axis positive upward\\n**Ruler**: Draw scale marks every 50px on the principal axis\\n**Element Styles**:\\n- **Object (candle)**: Orange solid arrow\\n- **Image**: Real image with cyan solid arrow, virtual image with cyan dashed arrow\\n- **Light rays**: Incident light yellow, refracted light green, virtual image auxiliary lines gray dashed\\n- **Focal point**: Mark F point with \\\"×\\\"\\n---\\n## Real-time Data Display Panel:\\n- Real-time calculation of magnification: `M = v/u`\\n- Real-time display of image distance: `v`\\n- Image property description (e.g., \\\"real/virtual image\\\", \\\"magnified/reduced\\\", \\\"upright/inverted\\\")\\n---\\n## Technical Requirements:\\n- Use HTML5 Canvas for drawing\\n- All ray intersection points must be calculated precisely through analytical geometry equations\\n- Animation frame rate not less than 60fps, no delay when dragging\\n- Include \\\"One-click Demo\\\" feature that automatically demonstrates the object moving from infinity to the focal point\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/fx22.png?auth_key=1801917571-8db983647e0a4d6890fe35b1698ef957-0-3421b1c5bcf0a7ee9928b2775927e190\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/089c80e6-398e-48ae-a39d-63260152f09c\",\"en\":\"https://chat.z.ai/s/27f8d40e-c542-4880-8b23-d7f7dab0644f\"},\"labels\":{\"cn\":\"科普/教案 推荐提示词2\",\"en\":\"Knowledge/Teaching Material Recommended Prompt 2\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-7mhDnH\",\"type\":\"prompt\",\"contents\":{\"cn\":\"生成中国传统二十四节气文化科普教案 + 水墨风时间线网页，用于小学高年级语文 / 传统文化课堂教学：教案部分包含教学目标、节气文化讲解、课堂手工设计、课后实践任务；网页部分采用中国传统水墨风设计，以宣纸纹理为背景，融入二十四节气相关的水墨插画，按四季分为四个板块，每个节气包含时间、物候特点、传统习俗、诗词谚语等内容，需实现节气搜索、四季筛选、诗词朗读等交互功能，搭配卷轴展开的动画效果，兼顾历史文化厚重感和课堂教学的趣味性。\",\"en\":\"Generate a Chinese traditional 24 Solar Terms cultural science education teaching plan + ink-wash style timeline webpage for upper elementary school Chinese language / traditional culture classroom instruction: The teaching plan section includes teaching objectives, solar term cultural explanations, classroom craft design, and after-class practice tasks; The webpage section adopts traditional Chinese ink-wash style design, with rice paper texture as the background, incorporating ink-wash illustrations related to the 24 solar terms, divided into four sections by the four seasons. Each solar term includes time, phenological characteristics, traditional customs, poetry and proverbs, and other content. It needs to implement interactive functions such as solar term search, four seasons filtering, and poetry recitation, paired with scroll unfolding animation effects, balancing the historical and cultural gravitas with the engagement of classroom teaching.\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/fx33.png?auth_key=1801917571-968e6a7194f94dc2a7ea8c82251dc3c5-0-74d9c5bc63be681aa400456ebe5e30bf\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/bb7b1514-f893-46e9-b835-f34ef7b56131\",\"en\":\"https://chat.z.ai/s/025aac0e-415c-4655-8c24-ab1ea1649750\"},\"labels\":{\"cn\":\"科普/教案 推荐提示词3\",\"en\":\"Knowledge/Teaching Material Recommended Prompt 3\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}]},\"items\":[],\"templates\":{\"cn\":\"{prompt}\",\"en\":\"{prompt}\"}},\"projects\":{\"id\":\"opt-71H6eb\",\"type\":\"projects\",\"refer\":\"\",\"contents\":{\"cn\":\"项目类型\",\"en\":\"Project Type\"},\"cascades\":{},\"items\":[{\"id\":\"item-Th7Pdr\",\"type\":\"project\",\"contents\":{\"cn\":\"落地页\",\"en\":\"Landing Page\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"落地页\",\"en\":\"Landing Page\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-yTOES2\",\"type\":\"project\",\"contents\":{\"cn\":\"科普/教案\",\"en\":\"Knowledge/Teaching Material\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"科普/教案\",\"en\":\"Knowledge/Teaching Material\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-QNNEHu\",\"type\":\"project\",\"contents\":{\"cn\":\"3D建模\",\"en\":\"3D Modeling\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"3D建模\",\"en\":\"3D Modeling\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-2et4KS\",\"type\":\"project\",\"contents\":{\"cn\":\"小游戏\",\"en\":\"Mini Game\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"小游戏\",\"en\":\"Mini Game\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-2brEeI\",\"type\":\"project\",\"contents\":{\"cn\":\"个人博客\",\"en\":\"Personal Blog\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"个人博客\",\"en\":\"Personal Blog\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"templates\":{\"cn\":\"选择项目类型: {project}\",\"en\":\"Choose project type: {project}\"}}},\"created_at\":1769511209,\"updated_at\":1770429278},{\"scene\":\"data-insight\",\"options\":{\"modes\":{\"id\":\"opt-f8btnk\",\"type\":\"modes\",\"refer\":\"\",\"contents\":{\"cn\":\"模式选择\",\"en\":\"Mode Selection\"},\"cascades\":{},\"items\":[{\"id\":\"item-z18deS\",\"type\":\"mode\",\"contents\":{\"cn\":\"# Visual chart Prompt\\n\\n## English Version\\n\\n### Mode & Objective\\n- Scenario: **Visual chart** — the primary deliverable is a ready-to-use chart or structured table.\\n- Focus on speed and clarity; deliver visualization directly without lengthy narrative.\\n- Disallowed outputs: Full analysis reports, multi-page documents, or text-heavy explanations.\\n- If chart type is unspecified, infer the most suitable type based on data characteristics.\\n\\n### Chart Type Selection Logic\\n\\n| Data Pattern | Recommended Chart |\\n|--------------|-------------------|\\n| Category comparison | Bar Chart (horizontal if labels are long) |\\n| Time series trend | Line Chart / Area Chart |\\n| Proportion breakdown (≤7 categories) | Pie Chart / Donut Chart |\\n| Correlation / outlier detection | Scatter Plot |\\n| Multi-dimensional assessment (5–10 axes) | Radar Chart |\\n| Matrix density / correlation matrix | Heatmap |\\n| Hierarchical proportion | Treemap / Sunburst |\\n| Flow / conversion stages | Sankey / Funnel |\\n| Distribution analysis | Histogram / Box Plot |\\n\\n### Data Preprocessing\\n- Auto-detect and handle: missing values, duplicates, outliers.\\n\\n### Chart Quality Checklist\\n- Title: Clear, concise, top-positioned.\\n- Axis labels: Include units (e.g., \\\"Revenue (¥M)\\\").\\n- Legend: Outside plot area if >4 items.\\n- Data labels: Show key values if not cluttered.\\n- Grid: Light gray, dashed, horizontal only (bar/line).\\n- Color: Use colorblind-friendly palette.\",\"en\":\"# Visual chart Prompt\\n\\n## English Version\\n\\n### Mode & Objective\\n- Scenario: **Visual chart** — the primary deliverable is a ready-to-use chart or structured table.\\n- Focus on speed and clarity; deliver visualization directly without lengthy narrative.\\n- Disallowed outputs: Full analysis reports, multi-page documents, or text-heavy explanations.\\n- If chart type is unspecified, infer the most suitable type based on data characteristics.\\n\\n### Chart Type Selection Logic\\n\\n| Data Pattern | Recommended Chart |\\n|--------------|-------------------|\\n| Category comparison | Bar Chart (horizontal if labels are long) |\\n| Time series trend | Line Chart / Area Chart |\\n| Proportion breakdown (≤7 categories) | Pie Chart / Donut Chart |\\n| Correlation / outlier detection | Scatter Plot |\\n| Multi-dimensional assessment (5–10 axes) | Radar Chart |\\n| Matrix density / correlation matrix | Heatmap |\\n| Hierarchical proportion | Treemap / Sunburst |\\n| Flow / conversion stages | Sankey / Funnel |\\n| Distribution analysis | Histogram / Box Plot |\\n\\n### Data Preprocessing\\n- Auto-detect and handle: missing values, duplicates, outliers.\\n\\n### Chart Quality Checklist\\n- Title: Clear, concise, top-positioned.\\n- Axis labels: Include units (e.g., \\\"Revenue (¥M)\\\").\\n- Legend: Outside plot area if >4 items.\\n- Data labels: Show key values if not cluttered.\\n- Grid: Light gray, dashed, horizontal only (bar/line).\\n- Color: Use colorblind-friendly palette.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"图表可视化\",\"en\":\"Quick Charts\"},\"descs\":null,\"on_finish\":\"visual_charts_gen_report\",\"defaults\":null},{\"id\":\"item-mFdQa7\",\"type\":\"mode\",\"contents\":{\"cn\":\"# Data Analysis Report Prompt\\n\\n## English Version\\n\\n### Mode & Objective\\n- Scenario: **Data Analysis** — the primary deliverable is a structured data analysis report.\\n- A valid report MUST include: narrative explanation, quantified evidence, and embedded charts/tables where applicable.\\n- Disallowed outputs: Quick Charts only, bullet-point summaries, chart-only output, or conclusions without supporting evidence.\\n- Non-blocking delivery: If inputs are incomplete, state explicit assumptions and append an Assumptions & Gaps section.\\n\\n### Recommended Workflow\\n\\n| Step | Core | Minimum Output |\\n|------|:----:|----------------|\\n| 1. Scope & Definitions | ✅ | Objective, key metrics, time range, granularity |\\n| 2. Data Quality Checks | ✅ | Row count, coverage, cleaning rules applied |\\n| 3. Core Performance | ✅ | ≥1 chart + key metric highlights with numeric evidence |\\n| 4. Comparisons | ✅ | ≥1 comparison (WoW/MoM/YoY/segment) + variance drivers |\\n| 5. Attribution & Diagnosis | ✅ | Driver list with evidence chain |\\n| 6. Insights & Action Plan | ✅ | ≥2 recommendations with priority, impact, risks, validation |\\n| 7. Uncertainty Statement | ⚪ | Limitations, biases, next validation steps |\",\"en\":\"# Data Analysis Report Prompt\\n\\n## English Version\\n\\n### Mode & Objective\\n- Scenario: **Data Analysis** — the primary deliverable is a structured data analysis report.\\n- A valid report MUST include: narrative explanation, quantified evidence, and embedded charts/tables where applicable.\\n- Disallowed outputs: Quick Charts only, bullet-point summaries, chart-only output, or conclusions without supporting evidence.\\n- Non-blocking delivery: If inputs are incomplete, state explicit assumptions and append an Assumptions & Gaps section.\\n\\n### Recommended Workflow\\n\\n| Step | Core | Minimum Output |\\n|------|:----:|----------------|\\n| 1. Scope & Definitions | ✅ | Objective, key metrics, time range, granularity |\\n| 2. Data Quality Checks | ✅ | Row count, coverage, cleaning rules applied |\\n| 3. Core Performance | ✅ | ≥1 chart + key metric highlights with numeric evidence |\\n| 4. Comparisons | ✅ | ≥1 comparison (WoW/MoM/YoY/segment) + variance drivers |\\n| 5. Attribution & Diagnosis | ✅ | Driver list with evidence chain |\\n| 6. Insights & Action Plan | ✅ | ≥2 recommendations with priority, impact, risks, validation |\\n| 7. Uncertainty Statement | ⚪ | Limitations, biases, next validation steps |\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"数据分析\",\"en\":\"Data Analysis\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"templates\":{\"cn\":\"{mode}\",\"en\":\"{mode}\"}},\"charts\":{\"id\":\"opt-tP8yvO\",\"type\":\"charts\",\"refer\":\"\",\"contents\":{\"cn\":\"推荐图表\",\"en\":\"Recommended Chart\"},\"cascades\":{},\"items\":[{\"id\":\"item-Zd4p3M\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 折线图生成\\n\\n用户已选择折线图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于折线图生成。\\n\\n用户已选择折线图进行生成\",\"en\":\"# Line Chart Generation\\n\\nUser has selected Line Chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for Line Chart generation.\\n\\nUser has selected Line Chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Line%20chart.png\",\"share_urls\":null,\"labels\":{\"cn\":\"折线图\",\"en\":\"Line Chart\"},\"descs\":{\"cn\":\"适用场景：时间序列趋势展示、连续数据变化\\n适用数据结构：时间/序列 + 数值\",\"en\":\"Applicable Scenarios: Time Series Trend Display, Continuous Data Change\\nApplicable Data Structure: Time/Sequence + Value\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-h4Aaso\",\"type\":\"chart\",\"contents\":{\"cn\":\"使用柱状图进行生成和\",\"en\":\"User has selected bar chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Bar%20Chart.png\",\"share_urls\":null,\"labels\":{\"cn\":\"柱状图\",\"en\":\"Bar Chart\"},\"descs\":{\"cn\":\"适用场景：分类数据对比、数量比较\\n适用数据结构：类别 + 数值\",\"en\":\"Applicable Scenarios: Comparison of Categorical Data, Comparison of Quantities\\nApplicable Data Structure: Category + Value\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-u22Lld\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 饼图生成\\n\\n用户已选择饼图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于饼图生成。\\n\\n用户已选择饼图进行生成\",\"en\":\"# Pie Chart Generation\\n\\nUser has selected Pie Chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for Pie Chartt generation.\\n\\nUser has selected Pie Chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Pie%20chart.png\",\"share_urls\":null,\"labels\":{\"cn\":\"饼状图\",\"en\":\"Pie Chart\"},\"descs\":{\"cn\":\"适用场景：占比分布、部分与整体关系\\n适用数据结构：类别 + 数值（占比）\",\"en\":\"Applicable Scenarios: Proportion Distribution, Part-to-Whole Relationship\\nApplicable Data Structure: Category + Value (Proportion)\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-6VSft0\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 散点图生成\\n\\n用户已选择散点图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于散点图生成。\\n\\n用户已选择散点图进行生成\",\"en\":\"# Scatter Plot Generation\\n\\nUser has selected scatter plot for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for scatter plot generation.\\n\\nUser has selected scatter plot for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Scatter%20plot.png\",\"share_urls\":null,\"labels\":{\"cn\":\"散点图\",\"en\":\"Scatter Plot\"},\"descs\":{\"cn\":\"适用场景：相关性分析、分布探索\\n适用数据结构：X轴数值 + Y轴数值\",\"en\":\"Applicable Scenarios: Correlation Analysis, Distribution Exploration\\nApplicable Data Structure: X-axis Value + Y-axis Value\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-lDjO3B\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 热力图生成\\n\\n用户已选择热力图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于热力图生成。\\n\\n用户已选择热力图进行生成\",\"en\":\"# Heatmap Generation\\n\\nUser has selected heatmap for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for heatmap generation.\\n\\nUser has selected heatmap for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Heatmap.png\",\"share_urls\":null,\"labels\":{\"cn\":\"热力图\",\"en\":\"Heatmap\"},\"descs\":{\"cn\":\"适用场景：矩阵数据可视化、密度分布\\n适用数据结构：行标签 + 列标签 + 数值矩阵\",\"en\":\"Applicable Scenarios: Matrix Data Visualization, Density Distribution\\nApplicable Data Structure: Row Labels + Column Labels + Value Matrix\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-OxiBvO\",\"type\":\"chart\",\"contents\":{\"cn\":\"{PROMPT:data-insight:cn:Density Plot }\",\"en\":\"{PROMPT:data-insight:en:Density Plot }\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Density%20Plot.png\",\"share_urls\":null,\"labels\":{\"cn\":\"密度图 \",\"en\":\"Density Plot \"},\"descs\":{\"cn\":\"适用场景：连续型数据的分布形态、峰值位置和数据集中度\\n适用数据结构：单维度或多维度的连续型数值数据\",\"en\":\"Applicable Scenarios:  Distribution pattern, peak position, and data concentration of continuous data\\nApplicable Data Structure: Unidimensional or multidimensional continuous numerical data\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-BLds7n\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 瀑布图生成\\n\\n用户已选择瀑布图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于瀑布图生成。\\n\\n用户已选择瀑布图进行生成\",\"en\":\"# waterfall chart Generation\\n\\nUser has selected waterfall chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for waterfall chart generation.\\n\\nUser has selected waterfall chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/WaterfallChart.png\",\"share_urls\":null,\"labels\":{\"cn\":\"瀑布图\",\"en\":\"Waterfall Chart\"},\"descs\":{\"cn\":\"适用场景：数据的变化过程，拆解每一步增减项的影响程度\\n适用数据结构：分类 + 数值 + 增减标识\",\"en\":\"Applicable Scenarios: The change process of data, and the decomposition of the impact degree of each incremental and decremental item\\nApplicable Data Structure: Category + Value + Increase/Decrease Indicator\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-Vn2bk7\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 桑基图生成\\n\\n用户已选择桑基图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于桑基图生成。\\n\\n用户已选择桑基图进行生成\",\"en\":\"# Sankey Diagram Generation\\n\\nUser has selected Sankey diagram for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for Sankey diagram generation.\\n\\nUser has selected Sankey diagram for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Sankeydiagram.png\",\"share_urls\":null,\"labels\":{\"cn\":\"桑基图\",\"en\":\"Sankey Diagram\"},\"descs\":{\"cn\":\"适用场景：流量流向、转化路径、能量流动\\n适用数据结构：源节点 + 目标节点 + 流量值\",\"en\":\"Applicable Scenarios: Traffic Flow, Conversion Path, Energy Flow\\nApplicable Data Structure: Source Node + Destination Node + Flow Value\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-ptRnAJ\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 主题河流图生成\\n\\n用户已选择主题河流图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于主题河流图生成。\\n\\n用户已选择主题河流图进行生成\",\"en\":\"# ThemeRiver Generation\\n\\nUser has selected ThemeRiver for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for ThemeRiver generation.\\n\\nUser has selected ThemeRiver for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Themeriver.png\",\"share_urls\":null,\"labels\":{\"cn\":\"主题河流图\",\"en\":\"ThemeRiver\"},\"descs\":{\"cn\":\"适用场景：多主题时间演变、话题热度变化\\n适用数据结构：时间 + 主题 + 数值\",\"en\":\"Applicable Scenarios: Multi-topic Time Evolution, Topic Popularity Changes\\nApplicable Data Structure: Time + Topic + Value\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-52Cxex\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 雷达图生成\\n\\n用户已选择雷达图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于雷达图生成。\\n\\n用户已选择雷达图进行生成\",\"en\":\"# Radar Chart Generation\\n\\nUser has selected radar chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for radar chart generation.\\n\\nUser has selected radar chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Radar%20Chart.png\",\"share_urls\":null,\"labels\":{\"cn\":\"雷达图\",\"en\":\"Radar Chart\"},\"descs\":{\"cn\":\"适用场景：多维度评价、能力对比\\n适用数据结构：维度 + 数值（多组）\",\"en\":\"Applicable Scenarios: Multi-dimensional Evaluation, Competency Comparison\\nApplicable Data Structure: Dimension + Value (Multiple Sets)\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-FkGbi8\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 堆叠柱状图生成\\n\\n用户已选择堆叠柱状图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于堆叠柱状图生成。\\n\\n用户已选择堆叠柱状图进行生成\",\"en\":\"# Stacked Bar Chart Generation\\n\\nUser has selected stacked bar chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for stacked bar chart generation.\\n\\nUser has selected stacked bar chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Stacked%20Column%C2%A0.png\",\"share_urls\":null,\"labels\":{\"cn\":\"堆叠柱状图\",\"en\":\"Stacked Bar Chart\"},\"descs\":{\"cn\":\"适用场景：分类内部构成、多维度对比\\n适用数据结构：类别 + 子类别 + 数值\",\"en\":\"Applicable Scenarios: Internal Composition of Categories, Multi-dimensional Comparison\\nApplicable Data Structure: Category + Subcategory + Value\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-QHML1l\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 旭日图生成\\n\\n用户已选择旭日图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于旭日图生成。\\n\\n用户已选择旭日图进行生成\",\"en\":\"# Sunburst Chart Generation\\n\\nUser has selected sunburst chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for sunburst chart generation.\\n\\nUser has selected sunburst chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Sunburst.png\",\"share_urls\":null,\"labels\":{\"cn\":\"旭日图\",\"en\":\"Sunburst Chart\"},\"descs\":{\"cn\":\"适用场景：层级数据展示、占比嵌套\\n适用数据结构：多层级分类 + 数值\",\"en\":\"Applicable Scenarios: Hierarchical Data Display, Proportion Nested\\nApplicable Data Structure: Multi-level Classification + Numerical Value\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-4I0ZVm\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 漏斗图生成\\n\\n用户已选择漏斗图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于漏斗图生成。\\n\\n用户已选择漏斗图进行生成\",\"en\":\"# Funnel Chart Generation\\n\\nUser has selected funnel chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for funnel chart generation.\\n\\nUser has selected funnel chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Funnel%20chart.png\",\"share_urls\":null,\"labels\":{\"cn\":\"漏斗图\",\"en\":\"Funnel Chart\"},\"descs\":{\"cn\":\"适用场景：转化率分析、流程衰减\\n适用数据结构：阶段 + 数值（递减）\",\"en\":\"Applicable Scenarios: Conversion Rate Analysis, Process Decay\\nApplicable Data Structure: Phase + Value (Decreasing)\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-7GjkH1\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 金字塔图生成\\n\\n用户已选择金字塔图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于金字塔图生成。\\n\\n用户已选择金字塔图进行生成\",\"en\":\"# pyramid chart Generation\\n\\nUser has selected pyramid chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for pyramid chart generation.\\n\\nUser has selected pyramid chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Pyramid.png\",\"share_urls\":null,\"labels\":{\"cn\":\"金字塔图\",\"en\":\"Pyramid Chart\"},\"descs\":{\"cn\":\"适用场景：层级递减 / 递增的分布\\n适用数据结构：分类 + 层级 + 数值\",\"en\":\"Applicable Scenarios: hierarchically decreasing distribution/hierarchically increasing distribution\\nApplicable Data Structure: Category + Hierarchy + Value\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-FeAXIF\",\"type\":\"chart\",\"contents\":{\"cn\":\"# K线图生成\\n\\n用户已选择K线图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于K线图生成。\\n\\n用户已选择K线图进行生成\",\"en\":\"# Candlestick Chart Generation\\n\\nUser has selected candlestick chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for candlestick chart generation.\\n\\nUser has selected candlestick chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Candlestick.png\",\"share_urls\":null,\"labels\":{\"cn\":\"K线图\",\"en\":\"Candlestick Chart\"},\"descs\":{\"cn\":\"适用场景：股票/金融数据、OHLC数据\\n适用数据结构：日期 + 开盘 + 最高 + 最低 + 收盘\",\"en\":\"Applicable Scenarios: Stock/Financial Data, OHLC Data\\nApplicable Data Structure: Date + Open + High + Low + Close\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-0KeiiM\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 环形图生成\\n\\n用户已选择环形图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于环形图生成。\\n\\n用户已选择环形图进行生成\",\"en\":\"# donut chart Generation\\n\\nUser has selected donut chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for donut chart generation.\\n\\nUser has selected donut chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Doughnut%C2%A0.png\",\"share_urls\":null,\"labels\":{\"cn\":\"环形图\",\"en\":\"Donut Chart\"},\"descs\":{\"cn\":\"适用场景：展示各分类对总体的占比关系\\n适用数据结构：分类字段 + 数值字段\",\"en\":\"Applicable Scenarios: Display the proportion of each category to the total\\nApplicable Data Structure:Category Field + Value Field\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-c0zrXk\",\"type\":\"chart\",\"contents\":{\"cn\":\"# 面积图生成\\n\\n用户已选择面积图进行生成。\\n\\n图表内容根据数据特征自动生成，系统自动判断数据如何使用和呈现。\\n\\n用户上传的数据已验证适用于面积图生成。\\n\\n用户已选择面积图进行生成\",\"en\":\"# Area Chart Generation\\n\\nUser has selected area chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for area chart generation.\\n\\nUser has selected area chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Area%20chart.png\",\"share_urls\":null,\"labels\":{\"cn\":\"面积图\",\"en\":\"Area Chart\"},\"descs\":{\"cn\":\"适用场景：累积趋势、体量变化\\n适用数据结构：时间/序列 + 数值\",\"en\":\"Applicable Scenarios: Cumulative Trends, Volume Changes\\nApplicable Data Structure: Time/Sequence + Value\"},\"on_finish\":null,\"defaults\":null},{\"id\":\"item-BZl9YY\",\"type\":\"chart\",\"contents\":{\"cn\":\"# gantt chart Generation\\n\\nUser has selected gantt chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for gantt chart generation.\\n\\nUser has selected gantt chart for generation.\",\"en\":\"# gantt chart Generation\\n\\nUser has selected gantt chart for generation.\\n\\nChart content is automatically generated based on data characteristics, with the system automatically determining how to use and present the data.\\n\\nUser-uploaded data has been validated as suitable for gantt chart generation.\\n\\nUser has selected gantt chart for generation.\"},\"img\":\"https://z-cdn.chatglm.cn/z-ai/static/data-insight/Ganttchart.png\",\"share_urls\":null,\"labels\":{\"cn\":\"甘特图\",\"en\":\"Gantt Chart\"},\"descs\":{\"cn\":\"适用场景：可视化展示项目任务的时间进度、依赖关系与资源分配\\n适用数据结构：任务 + 时间 + 状态\",\"en\":\"Applicable Scenarios: Visually display the time progress, dependency relationships, and resource allocation of project tasks\\nApplicable Data Structure: Task + Time + Status\"},\"on_finish\":null,\"defaults\":null}],\"templates\":{\"cn\":\"{chart}\",\"en\":\"{chart}\"}},\"outputs\":{\"id\":\"opt-ghTPmk\",\"type\":\"outputs\",\"refer\":\"modes\",\"contents\":{\"cn\":\"输出格式选择\",\"en\":\"Output Format Selection\"},\"cascades\":{\"item-mFdQa7\":[{\"id\":\"item-6lzAWZ\",\"type\":\"output\",\"contents\":{\"cn\":\"* **The report output format must be Word (.docx)**:\\n  - **Library**: Use `python-docx`.\\n  - **Fonts**:\\n    - Chinese: SimSun (宋体) / Microsoft YaHei (微软雅黑)\\n    - English: Arial / Times New Roman\\n    - Fallback: Use system-available fonts; avoid hardcoding font paths.\\n  - **Page Setup**: A4, margins 2.5cm (top/bottom), 2cm (left/right).\\n  - **Header & Footer** (exclude cover page):\\n    - Header: Report title, right-aligned or centered, font size 10pt.\\n    - Footer: Page number centered (format: \\\"Page X\\\" or \\\"第 X 页\\\").\\n    - Use Section Breaks to isolate cover page (no header/footer on cover).\\n  - **Document Structure**:\\n    - Use built-in styles: Heading 1 / Heading 2 / Heading 3 for hierarchy.\\n    - Auto-generate Table of Contents (TOC) linked to heading styles.\\n  - **Image Embedding**:\\n    - Alignment: Inline with text, centered.\\n    - Maintain aspect ratio; width ≤ 80% page width (~14cm).\\n    - Caption below image: \\\"图 X-XX：[描述]\\\" (centered, smaller font).\\n  - **Table Formatting**:\\n    - Enable text wrapping in cells (prevent overflow).\\n    - Auto-fit column width to content.\\n    - Header row: Bold, background #F2F2F2.\\n  - **File Naming**: `[主题]_分析报告_[YYYY-MM-DD].docx`\\n* **Output**: Provide a direct download link after generating the file.\",\"en\":\"* **The report output format must be Word (.docx)**:\\n  - **Library**: Use `python-docx`.\\n  - **Fonts**:\\n    - Chinese: SimSun (宋体) / Microsoft YaHei (微软雅黑)\\n    - English: Arial / Times New Roman\\n    - Fallback: Use system-available fonts; avoid hardcoding font paths.\\n  - **Page Setup**: A4, margins 2.5cm (top/bottom), 2cm (left/right).\\n  - **Header & Footer** (exclude cover page):\\n    - Header: Report title, right-aligned or centered, font size 10pt.\\n    - Footer: Page number centered (format: \\\"Page X\\\" or \\\"第 X 页\\\").\\n    - Use Section Breaks to isolate cover page (no header/footer on cover).\\n  - **Document Structure**:\\n    - Use built-in styles: Heading 1 / Heading 2 / Heading 3 for hierarchy.\\n    - Auto-generate Table of Contents (TOC) linked to heading styles.\\n  - **Image Embedding**:\\n    - Alignment: Inline with text, centered.\\n    - Maintain aspect ratio; width ≤ 80% page width (~14cm).\\n    - Caption below image: \\\"图 X-XX：[描述]\\\" (centered, smaller font).\\n  - **Table Formatting**:\\n    - Enable text wrapping in cells (prevent overflow).\\n    - Auto-fit column width to content.\\n    - Header row: Bold, background #F2F2F2.\\n  - **File Naming**: `[主题]_分析报告_[YYYY-MM-DD].docx`\\n* **Output**: Provide a direct download link after generating the file.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"docx\",\"en\":\"docx\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-tDW92z\",\"type\":\"output\",\"contents\":{\"cn\":\"* **The report output format must be PDF**:\\n  - **Library**: Use `reportlab` (preferred for complex layouts and CJK support) or `fpdf2` with registered CJK fonts.\\n  - **Fonts**:\\n    - Chinese: SimSun / Microsoft YaHei / Noto Sans CJK SC\\n    - English: Arial / Times New Roman\\n    - Fallback: Ensure font embedding for cross-platform rendering.\\n  - **Page Setup**: A4 (210×297mm), margins 2.5cm (top/bottom), 2cm (left/right).\\n  - **Header & Footer** (exclude cover page):\\n    - Header: Report title, right-aligned or centered, font size 10pt.\\n    - Footer: Page number centered (format: \\\"Page X\\\" or \\\"第 X 页\\\").\\n  - **Bookmarks**: Auto-generate PDF bookmarks from Heading 1/2/3 for navigation.\\n  - **Image Embedding**:\\n    - Resolution ≥ 150 DPI for print quality.\\n    - Maintain aspect ratio; width ≤ 80% page width.\\n  - **File Optimization**: Target file size ≤ 10MB; compress images if necessary.\\n  - **File Naming**: `[主题]_分析报告_[YYYY-MM-DD].pdf`\\n* **Output**: Provide a direct download link after generating the file.\",\"en\":\"* **The report output format must be PDF**:\\n  - **Library**: Use `reportlab` (preferred for complex layouts and CJK support) or `fpdf2` with registered CJK fonts.\\n  - **Fonts**:\\n    - Chinese: SimSun / Microsoft YaHei / Noto Sans CJK SC\\n    - English: Arial / Times New Roman\\n    - Fallback: Ensure font embedding for cross-platform rendering.\\n  - **Page Setup**: A4 (210×297mm), margins 2.5cm (top/bottom), 2cm (left/right).\\n  - **Header & Footer** (exclude cover page):\\n    - Header: Report title, right-aligned or centered, font size 10pt.\\n    - Footer: Page number centered (format: \\\"Page X\\\" or \\\"第 X 页\\\").\\n  - **Bookmarks**: Auto-generate PDF bookmarks from Heading 1/2/3 for navigation.\\n  - **Image Embedding**:\\n    - Resolution ≥ 150 DPI for print quality.\\n    - Maintain aspect ratio; width ≤ 80% page width.\\n  - **File Optimization**: Target file size ≤ 10MB; compress images if necessary.\\n  - **File Naming**: `[主题]_分析报告_[YYYY-MM-DD].pdf`\\n* **Output**: Provide a direct download link after generating the file.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"pdf\",\"en\":\"pdf\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"item-z18deS\":[{\"id\":\"item-kOMvX2\",\"type\":\"output\",\"contents\":{\"cn\":\"* **The output format must be Image**:\\n  - **Library**: Use `matplotlib` + `seaborn` (static charts) or `pyecharts` / `plotly` (interactive → export as static).\\n  - **Fonts**:\\n    - Chinese: SimHei (黑体) / Microsoft YaHei / Noto Sans CJK SC\\n    - English: Arial / Helvetica / DejaVu Sans\\n    - Set globally: `plt.rcParams['font.sans-serif'] = ['SimHei', 'Arial']`\\n    - Fix minus sign: `plt.rcParams['axes.unicode_minus'] = False`\\n  - **Output Format**:\\n    - PNG: Default, white background, best compatibility.\\n    - PNG (transparent): Use `transparent=True` when user requests.\\n  - **Resolution & Size**:\\n    - Resolution: 150 DPI (screen) / 300 DPI (print-ready).\\n    - Default size: 1920×1080 px (16:9) or 1600×1200 px (4:3).\\n    - Export: `plt.savefig('filename.png', dpi=150, bbox_inches='tight')`\\n  - **Color Scheme**:\\n    - Use professional palettes: `seaborn` built-in (e.g., \\\"muted\\\", \\\"colorblind\\\") or custom brand colors.\\n    - Ensure colorblind-friendly (avoid red-green only differentiation).\\n  - **Chart Quality Checklist**:\\n    - Title: Clear, concise, positioned at top.\\n    - Axis labels: Include units (e.g., \\\"Revenue (¥M)\\\").\\n    - Legend: Positioned outside plot area if >4 items.\\n    - Data labels: Show key values on bars/points (if not cluttered).\\n    - Grid: Light gray, dashed, horizontal only (for bar/line charts).\\n    - Source annotation: Bottom-left, small font (if applicable).\\n  - **File Naming**: `[ChartType]_[Topic]_[YYYY-MM-DD].png`\\n* **Output**: Provide a direct download link after generating the file.\",\"en\":\"* **The output format must be Image**:\\n  - **Library**: Use `matplotlib` + `seaborn` (static charts) or `pyecharts` / `plotly` (interactive → export as static).\\n  - **Fonts**:\\n    - Chinese: SimHei (黑体) / Microsoft YaHei / Noto Sans CJK SC\\n    - English: Arial / Helvetica / DejaVu Sans\\n    - Set globally: `plt.rcParams['font.sans-serif'] = ['SimHei', 'Arial']`\\n    - Fix minus sign: `plt.rcParams['axes.unicode_minus'] = False`\\n  - **Output Format**:\\n    - PNG: Default, white background, best compatibility.\\n    - PNG (transparent): Use `transparent=True` when user requests.\\n  - **Resolution & Size**:\\n    - Resolution: 150 DPI (screen) / 300 DPI (print-ready).\\n    - Default size: 1920×1080 px (16:9) or 1600×1200 px (4:3).\\n    - Export: `plt.savefig('filename.png', dpi=150, bbox_inches='tight')`\\n  - **Color Scheme**:\\n    - Use professional palettes: `seaborn` built-in (e.g., \\\"muted\\\", \\\"colorblind\\\") or custom brand colors.\\n    - Ensure colorblind-friendly (avoid red-green only differentiation).\\n  - **Chart Quality Checklist**:\\n    - Title: Clear, concise, positioned at top.\\n    - Axis labels: Include units (e.g., \\\"Revenue (¥M)\\\").\\n    - Legend: Positioned outside plot area if >4 items.\\n    - Data labels: Show key values on bars/points (if not cluttered).\\n    - Grid: Light gray, dashed, horizontal only (for bar/line charts).\\n    - Source annotation: Bottom-left, small font (if applicable).\\n  - **File Naming**: `[ChartType]_[Topic]_[YYYY-MM-DD].png`\\n* **Output**: Provide a direct download link after generating the file.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"png\",\"en\":\"png\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-MDdxi9\",\"type\":\"output\",\"contents\":{\"cn\":\"* **The output format must be Excel/CSV**:\\n  - **Library**: Use `pandas` + `openpyxl` (for .xlsx) or `xlsxwriter` (for advanced formatting).\\n  - **Output Format**:\\n    - XLSX: Default, supports multi-sheet, formatting, formulas.\\n    - CSV: Use when user requests or for cross-platform compatibility (UTF-8 with BOM).\\n    - **Formatting Standards**:\\n    - Header row: Bold, background #F2F2F2, border, center-aligned.\\n    - Number formats:\\n      - Integer: `#,##0`\\n      - Decimal: `#,##0.00`\\n      - Percentage: `0.00%`\\n      - Currency: `¥#,##0.00` or `$#,##0.00`\\n      - Date: `YYYY-MM-DD`\\n    - Conditional formatting: Green for positive growth, red for negative.\\n  - **Data Integrity**:\\n    - Freeze first row (header) and first column (if row labels exist).\\n    - Enable auto-filter on header row.\\n    - Add data validation / dropdown for key columns (if applicable).\\n  - **Print Settings** (for XLSX):\\n    - Page: A4 landscape, fit to page width.\\n    - Repeat header row on each printed page.\\n  - **File Naming**: `[Topic]_[YYYY-MM-DD]_v[Version].xlsx`\\n* **Output**: Provide a direct download link after generating the file.\",\"en\":\"* **The output format must be Excel/CSV**:\\n  - **Library**: Use `pandas` + `openpyxl` (for .xlsx) or `xlsxwriter` (for advanced formatting).\\n  - **Output Format**:\\n    - XLSX: Default, supports multi-sheet, formatting, formulas.\\n    - CSV: Use when user requests or for cross-platform compatibility (UTF-8 with BOM).\\n    - **Formatting Standards**:\\n    - Header row: Bold, background #F2F2F2, border, center-aligned.\\n    - Number formats:\\n      - Integer: `#,##0`\\n      - Decimal: `#,##0.00`\\n      - Percentage: `0.00%`\\n      - Currency: `¥#,##0.00` or `$#,##0.00`\\n      - Date: `YYYY-MM-DD`\\n    - Conditional formatting: Green for positive growth, red for negative.\\n  - **Data Integrity**:\\n    - Freeze first row (header) and first column (if row labels exist).\\n    - Enable auto-filter on header row.\\n    - Add data validation / dropdown for key columns (if applicable).\\n  - **Print Settings** (for XLSX):\\n    - Page: A4 landscape, fit to page width.\\n    - Repeat header row on each printed page.\\n  - **File Naming**: `[Topic]_[YYYY-MM-DD]_v[Version].xlsx`\\n* **Output**: Provide a direct download link after generating the file.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"csv\",\"en\":\"csv\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}]},\"items\":[],\"templates\":{\"cn\":\"{output}\",\"en\":\"{output}\"}},\"prompts\":{\"id\":\"opt-FxTGBh\",\"type\":\"prompts\",\"refer\":\"modes\",\"contents\":{\"cn\":\"推荐提示词\",\"en\":\"Recommended Prompts\"},\"cascades\":{\"item-mFdQa7\":[{\"id\":\"item-r3Aqpu\",\"type\":\"prompt\",\"contents\":{\"cn\":\"2021–2025年全球核心贵金属价格（黄金、白银、铂金、钯金），包括月度收盘价、季度环比变化和波动率（CV值）。新增对比表，显示：（1）同期全球主要经济体核心CPI、PPI数据，以分析贵金属价格与通胀、工业需求的相关性；（2）相关行业成本指数，如珠宝加工成本、电子元器件原材料成本、化工催化材料成本。构建包含价格趋势、相关性热力图及行业成本传导路径的图表仪表板。 \",\"en\":\"Global core precious metal prices (gold, silver, platinum, palladium) from 2021 to 2025, including monthly closing prices, quarter-on-quarter changes, and volatility (CV values). Add a comparative table showing: (1) core CPI and PPI data of major global economies over the same period to analyze the correlation between precious metal prices, inflation, and industrial demand; (2) relevant industry cost indices, such as jewelry processing costs, raw material costs for electronic components, and costs for chemical catalytic materials. Build a chart dashboard containing price trends, correlation heatmaps, and industry cost transmission paths.\"},\"img\":\"https://z-cdn.chatglm.cn/imgs/feedback-insight-tool-1.png\",\"share_urls\":null,\"labels\":{\"cn\":\"2021–2025年全球核心贵金属价格\",\"en\":\"Global core precious metal prices from 2021 to 2025\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"modes\":[\"item-z18deS\"],\"charts\":[\"item-h4Aaso\",\"item-lDjO3B\"],\"outputs\":[\"item-MDdxi9\"]}},{\"id\":\"item-92c8v3\",\"type\":\"prompt\",\"contents\":{\"cn\":\"分析2024年两家新能源科技公司的季度成本管控成效，重点拆解营业成本、销售费用、管理费用的季度变化趋势，计算各成本费用占营收的比重，对比两家公司的成本管控效率；展示其中一家公司全年各季度的成本费用结构细分，识别成本管控中的优势与薄弱环节，结合行业成本趋势，提出可落地的成本优化方案。\",\"en\":\"Analyze the quarterly cost control effectiveness of two new energy technology companies in 2024, with a focus on dissecting the quarterly change trends of operating costs, sales expenses and general & administrative expenses; calculate the proportion of each cost and expense to revenue, and compare the cost control efficiency of the two companies; present the quarterly breakdown of the cost and expense structure of one of the companies throughout the year, identify the strengths and weaknesses in cost control, and put forward actionable cost optimization solutions in combination with the industry cost trends.\"},\"img\":\"https://z-cdn.chatglm.cn/imgs/feedback-insight-tool-2.png\",\"share_urls\":null,\"labels\":{\"cn\":\"2024年两家新能源科技公司的季度成本管控成效\",\"en\":\"The Quarterly Cost Control Effectiveness of Two New Energy Technology Companies in 2024\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"modes\":[\"item-mFdQa7\"],\"charts\":[\"item-h4Aaso\",\"item-FkGbi8\"],\"outputs\":[\"item-tDW92z\"]}},{\"id\":\"item-Gq3Itz\",\"type\":\"prompt\",\"contents\":{\"cn\":\"你是某知名投资机构的高级股票经纪人兼财务顾问，受托为一位高净值客户准备一份全面的《年度投资策略与投资组合回顾》报告。你的目标是用英文编写一份详尽且专业的报告，分析当前市场环境，并提出一套定制化的多资产投资策略。该文档不得包含目录（TOC），并且所有文本须使用 Times New Roman 字体。 最终交付物必须是一份经过精心润色的 Microsoft Word 文档（.docx 文件），用于正式场合呈现。请遵循以下具体要求： 执行摘要（Executive Summary）： 以简明的执行摘要开篇。内容应对当前宏观经济及地缘政治环境进行高层次概述，并重点分析具有结构性增长潜力的关键领域，尤其是科技领域（例如：人工智能、网络安全、云计算）以及可持续能源领域（例如：可再生能源基础设施、储能、电气化）。 投资组合配置与可视化： 资产配置方案（Asset Allocation Plan）： 为“平衡型”风险偏好的投资者（即中等风险承受能力）设计一个多元化的资产配置模型。明确以下核心资产类别的目标配置比例： * 股票（进一步按地区/市值划分） * 固定收益 * 实物资产（房地产/基础设施） * 现金及另类投资 图表 1 – 饼图/环形图（Pie/Donut Chart）： 创建一张高分辨率、可用于正式出版的图表（如饼图或环形图），直观展示建议的资产配置比例。采用专业配色方案（以海军蓝和铂金色为主，辅以协调的点缀色）。该图需嵌入文档中。 图表 2 – 柱状图（Bar Chart）： 创建第二张高分辨率柱状图，对比所建议投资组合与标准基准（具体为标普500指数以及全球60/40综合基准）在两个时间维度（5年和10年）下的预期年化收益率。 投资建议与详细数据表： 表格 1 – 前十大股票持仓（Top 10 Equity Holdings）： 生成一张详细表格，列出推荐的前10只个股。表格列必须包括： * 公司名称 * 股票代码 * 行业（科技 / 可持续能源 / 其他） * 当前价格 * 预期市盈率（Forward P/E） * 股息收益率（%） * 12个月目标价 并为每一项投资提供简要的要点式投资逻辑说明（1–2点）。 表格 2 – 基金 / ETF 推荐（Fund/ETF Recommendations）： 创建另一张表格，推荐5只互惠基金或ETF，用于提供更广泛的市场或主题敞口。表格列包括： * 基金名称 * 代码 * 资产类别 / 投资主题 * 费用率（Expense Ratio） * 三年年化回报率 表格 3 – 风险指标汇总（Risk Metrics Summary）： 添加第三张简要表格，总结建议投资组合的关键风险收益指标，包括： * 预期波动率（标准差） * 夏普比率 * 最大回撤 * 相对标普500的Beta系数 新增要求： 增加一张折线图（Line Chart），并调用图像生成接口以获取一个示意性图表（schematic diagram）。 文档格式与专业标准： Word文档必须遵循严格的企业视觉规范。 字体（Typography）： 所有标题使用专业衬线字体（如 Times New Roman、Garamond）；正文使用清晰的无衬线字体（如 Calibri、Arial）。 配色方案（Color Scheme）： 主色为海军蓝（#002D62）和铂金色（#E5E4E2）。用于标题、分节线、图表元素及视觉点缀。 结构（Structure）： 包含目录（Table of Contents）、专业页眉（含客户名称/报告标题）以及页脚（含页码、保密声明及日期）。 免责声明（Disclaimers）： 在独立章节中附上必要的法律与合规免责声明，明确说明本报告仅供参考，不构成对未来收益的保证，并建议客户咨询其个人税务及法律顾问。 输出说明（Output Instructions）： 请生成完整的Word文档内容，包括所有文字部分、图表的详细说明（图表将由我在外部制作）、以及所有以清晰Markdown或可直接复制到Word的文本格式呈现的表格。确保内容具有洞察力、数据驱动，并以客户为中心。\",\"en\":\"You are a Senior Stockbroker and Financial Advisor at a prestigious investment firm, tasked with preparing a comprehensive \\\"Annual Investment Strategy & Portfolio Review\\\" for a high-net-worth client. Your objective is to compile a detailed, professional report in English that analyzes prevailing market conditions and proposes a bespoke, multi-asset investment strategy. The doc should not have TOC and use times new roman for all text The final deliverable must be a polished Microsoft Word document (.docx file), designed for formal presentation. Please follow these specific instructions: Executive Summary: Begin with a concise executive summary. It should provide a high-level overview of the current macroeconomic and geopolitical outlook, with a focused analysis identifying key structural growth opportunities, particularly within the Technology (e.g., AI, Cybersecurity, Cloud Computing) and Sustainable Energy (e.g., Renewable Infrastructure, Energy Storage, Electrification) sectors. Portfolio Allocation & Visualization: Asset Allocation Plan: Develop a diversified portfolio allocation model suitable for a \\\"Balanced\\\" risk profile (e.g., moderate risk tolerance). Specify target percentages for the following core asset classes: Equities (further broken down by region/market cap), Fixed Income, Real Assets (Real Estate/Infrastructure), and Cash & Alternatives. Visual 1 - Pie/Donut Chart: Create a high-resolution, publication-quality chart (e.g., a pie or donut chart) that visually represents the recommended asset allocation percentages. Use a professional color scheme (primarily Navy Blue and Platinum, with complementary accents). Embed this chart in the document. Visual 2 - Bar Chart: Create a second high-resolution bar chart comparing the projected annualized returns of the proposed portfolio against standard benchmarks (specifically the S&P 500 and a Global 60/40 Aggregate Benchmark) over two time horizons: 5 years and 10 years. Investment Recommendations with Detailed Data Tables: Provide actionable investment recommendations supported by detailed data tables. Table 1 - Top 10 Equity Holdings: Generate a detailed table listing the top 10 recommended individual stock picks. Columns must include: Company Name, Ticker Symbol, Sector (Technology/Sustainable Energy/Other), Current Price, Forward P/E Ratio, Dividend Yield (%), and 12-Month Price Target. Include brief, bullet-point rationale for each selection (1-2 points). Table 2 - Fund/ETF Recommendations: Create a separate table recommending 5 complementary mutual funds or ETFs to provide broader market or thematic exposure. Columns should include: Fund Name, Ticker, Asset Class/Focus, Expense Ratio, and 3-Year Annualized Return. Table 3 - Risk Metrics Summary: Include a succinct third table summarizing the key risk-return metrics of the proposed portfolio, such as: Projected Volatility (Std Dev), Sharpe Ratio, Maximum Drawdown, and Beta vs. S&P 500. Add a requirement for a line chart and call the image generation interface to obtain a schematic diagram Document Formatting & Professional Standards: The Word document must adhere to a strict corporate visual identity. Typography: Use a professional serif font (e.g., Times New Roman, Garamond) for all headings and a clean sans-serif font (e.g., Calibri, Arial) for body text. Color Scheme: Primary colors are Navy Blue (#002D62) and Platinum (#E5E4E2). Use these for headings, section dividers, chart elements, and accents. Structure: Include a Table of Contents, professional headers (with client name/report title) and footers (with page numbers, confidentiality notice, and date). Disclaimers: Append necessary legal and compliance disclaimers in a dedicated section, clarifying that this is for informational purposes, is not a guarantee of future performance, and advising the client to consult with their personal tax and legal advisors. Output Instructions: Please generate the full content of the Word document, including all written sections, the specifications/descriptions for the charts (which I will create externally), and all tables formatted in clear Markdown or text suitable for copying into Word. Ensure the narrative is insightful, data-driven, and client-focused.\"},\"img\":\"https://z-cdn.chatglm.cn/imgs/feedback-insight-tool-3.png\",\"share_urls\":null,\"labels\":{\"cn\":\"分析当前市场环境，定制一套年度投资策略与投资组合\",\"en\":\"Analyze the current market environment and tailor an annual investment strategy and portfolio plan\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"modes\":[\"item-mFdQa7\"],\"charts\":[\"item-u22Lld\",\"item-h4Aaso\",\"item-0KeiiM\"],\"outputs\":[\"item-6lzAWZ\"]}},{\"id\":\"item-Q3ZFgc\",\"type\":\"prompt\",\"contents\":{\"cn\":\"你是一名高级 MLOps 架构师，负责对企业级机器学习基础设施进行现代化改造。你的目标是设计一套稳健、自动化的 MLOps 流水线策略，推动模型从实验阶段平滑过渡到生产级部署，重点减少与手动容器管理相关的运维开销，并能够编排复杂的训练工作流。 请对现代编排与容器化方法进行全面分析，尤其要对比云原生方案（例如使用 Cloud Native Buildpacks 和 Tekton）与传统的手写 Dockerfile/手动构建工作流。基于这项技术评估，制定一份详细的战略规划，覆盖模型版本管理、自动化训练触发机制以及持续部署（CD）标准。 最后，请将你的分析与策略整理成一份结构专业的 Excel 工作簿（.xlsx）。文件至少包含三个独立工作表： 1. **Tooling Evaluation Matrix（工具评估矩阵）**：对多种编排工具进行对比，列包含如可扩展性（Scalability）、复杂度（Complexity）、集成难易度（Integration Ease）等； 2. **Deployment Roadmap（部署路线图）**：按阶段列出实施自动化流水线的推进计划； 3. **Risk Assessment（风险评估）**：列出风险项与应对措施等。 该 Excel 文件必须具备专业格式，包括： * 冻结首行作为表头； * 对所有数据表启用筛选器； * 使用条件格式高亮关键路径事项或高风险因素； * 自动调整列宽，以确保整体呈现效果清晰、专业。\",\"en\":\"You are a Senior MLOps Architect responsible for modernizing an enterprise-level machine learning infrastructure. Your objective is to design a robust, automated MLOps pipeline strategy that facilitates the transition from experimental models to production-grade deployment, specifically aiming to reduce operational overhead associated with manual container management and orchestrate complex training workflows.\\\\n\\\\nPlease conduct a comprehensive analysis of modern orchestration and containerization methodologies, specifically comparing cloud-native approaches (such as utilizing Cloud Native Buildpacks and Tekton) against traditional manual Dockerfile workflows. Based on this technical evaluation, develop a detailed strategic plan that addresses model versioning, automated training triggers, and continuous deployment standards.\\\\n\\\\nFinally, consolidate your analysis and strategy into a professionally structured Excel workbook (.xlsx). The file should include at least three distinct worksheets: a 'Tooling Evaluation Matrix' that compares various orchestration tools across columns such as Scalability, Complexity, and Integration Ease; a 'Deployment Roadmap' sheet outlining the phases of implementing this automated pipeline; and a 'Risk Assessment' sheet. The Excel file must feature professional formatting, including frozen top rows for headers, activated filters on all data tables, conditional formatting to highlight critical path items or high-risk factors, and auto-adjusted column widths to ensure a high-quality visual presentation.\"},\"img\":\"https://z-cdn.chatglm.cn/imgs/feedback-insight-tool-4.png\",\"share_urls\":null,\"labels\":{\"cn\":\"企业级 MLOps 现代化与自动化流水线架构战略设计\",\"en\":\"Enterprise MLOps Modernization & Automated Pipeline Architecture Strategy\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"modes\":[\"item-z18deS\"],\"outputs\":[\"item-MDdxi9\"]}}],\"item-z18deS\":[{\"id\":\"item-WP3arJ\",\"type\":\"prompt\",\"contents\":{\"cn\":\"2021–2025年全球核心贵金属价格（黄金、白银、铂金、钯金），包括月度收盘价、季度环比变化和波动率（CV值）。新增对比表，显示：（1）同期全球主要经济体核心CPI、PPI数据，以分析贵金属价格与通胀、工业需求的相关性；（2）相关行业成本指数，如珠宝加工成本、电子元器件原材料成本、化工催化材料成本。构建包含价格趋势、相关性热力图及行业成本传导路径的图表仪表板。 \",\"en\":\"Global core precious metal prices (gold, silver, platinum, palladium) from 2021 to 2025, including monthly closing prices, quarter-on-quarter changes, and volatility (CV values). Add a comparative table showing: (1) core CPI and PPI data of major global economies over the same period to analyze the correlation between precious metal prices, inflation, and industrial demand; (2) relevant industry cost indices, such as jewelry processing costs, raw material costs for electronic components, and costs for chemical catalytic materials. Build a chart dashboard containing price trends, correlation heatmaps, and industry cost transmission paths.\"},\"img\":\"https://z-cdn.chatglm.cn/imgs/feedback-insight-tool-1.png\",\"share_urls\":null,\"labels\":{\"cn\":\"2021–2025年全球核心贵金属价格\",\"en\":\"Global core precious metal prices from 2021 to 2025\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"modes\":[\"item-z18deS\"],\"charts\":[\"item-h4Aaso\",\"item-lDjO3B\"],\"outputs\":[\"item-MDdxi9\"]}},{\"id\":\"item-9qULoG\",\"type\":\"prompt\",\"contents\":{\"cn\":\"分析2024年两家新能源科技公司的季度成本管控成效，重点拆解营业成本、销售费用、管理费用的季度变化趋势，计算各成本费用占营收的比重，对比两家公司的成本管控效率；展示其中一家公司全年各季度的成本费用结构细分，识别成本管控中的优势与薄弱环节，结合行业成本趋势，提出可落地的成本优化方案。\",\"en\":\"Analyze the quarterly cost control effectiveness of two new energy technology companies in 2024, with a focus on dissecting the quarterly change trends of operating costs, sales expenses and general & administrative expenses; calculate the proportion of each cost and expense to revenue, and compare the cost control efficiency of the two companies; present the quarterly breakdown of the cost and expense structure of one of the companies throughout the year, identify the strengths and weaknesses in cost control, and put forward actionable cost optimization solutions in combination with the industry cost trends.\"},\"img\":\"https://z-cdn.chatglm.cn/imgs/feedback-insight-tool-2.png\",\"share_urls\":null,\"labels\":{\"cn\":\"2024年两家新能源科技公司的季度成本管控成效\",\"en\":\"The Quarterly Cost Control Effectiveness of Two New Energy Technology Companies in 2024\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"modes\":[\"item-mFdQa7\"],\"charts\":[\"item-h4Aaso\",\"item-FkGbi8\"],\"outputs\":[\"item-6lzAWZ\"]}},{\"id\":\"item-oyWNA3\",\"type\":\"prompt\",\"contents\":{\"cn\":\"你是某知名投资机构的高级股票经纪人兼财务顾问，受托为一位高净值客户准备一份全面的《年度投资策略与投资组合回顾》报告。你的目标是用英文编写一份详尽且专业的报告，分析当前市场环境，并提出一套定制化的多资产投资策略。该文档不得包含目录（TOC），并且所有文本须使用 Times New Roman 字体。\\n\\n最终交付物必须是一份经过精心润色的 Microsoft Word 文档（.docx 文件），用于正式场合呈现。请遵循以下具体要求：\\n\\n执行摘要（Executive Summary）：\\n以简明的执行摘要开篇。内容应对当前宏观经济及地缘政治环境进行高层次概述，并重点分析具有结构性增长潜力的关键领域，尤其是科技领域（例如：人工智能、网络安全、云计算）以及可持续能源领域（例如：可再生能源基础设施、储能、电气化）。\\n\\n投资组合配置与可视化：\\n\\n资产配置方案（Asset Allocation Plan）：\\n为“平衡型”风险偏好的投资者（即中等风险承受能力）设计一个多元化的资产配置模型。明确以下核心资产类别的目标配置比例：\\n\\n* 股票（进一步按地区/市值划分）\\n* 固定收益\\n* 实物资产（房地产/基础设施）\\n* 现金及另类投资\\n\\n图表 1 – 饼图/环形图（Pie/Donut Chart）：\\n创建一张高分辨率、可用于正式出版的图表（如饼图或环形图），直观展示建议的资产配置比例。采用专业配色方案（以海军蓝和铂金色为主，辅以协调的点缀色）。该图需嵌入文档中。\\n\\n图表 2 – 柱状图（Bar Chart）：\\n创建第二张高分辨率柱状图，对比所建议投资组合与标准基准（具体为标普500指数以及全球60/40综合基准）在两个时间维度（5年和10年）下的预期年化收益率。\\n\\n投资建议与详细数据表：\\n\\n表格 1 – 前十大股票持仓（Top 10 Equity Holdings）：\\n生成一张详细表格，列出推荐的前10只个股。表格列必须包括：\\n\\n* 公司名称\\n* 股票代码\\n* 行业（科技 / 可持续能源 / 其他）\\n* 当前价格\\n* 预期市盈率（Forward P/E）\\n* 股息收益率（%）\\n* 12个月目标价\\n\\n并为每一项投资提供简要的要点式投资逻辑说明（1–2点）。\\n\\n表格 2 – 基金 / ETF 推荐（Fund/ETF Recommendations）：\\n创建另一张表格，推荐5只互惠基金或ETF，用于提供更广泛的市场或主题敞口。表格列包括：\\n\\n* 基金名称\\n* 代码\\n* 资产类别 / 投资主题\\n* 费用率（Expense Ratio）\\n* 三年年化回报率\\n\\n表格 3 – 风险指标汇总（Risk Metrics Summary）：\\n添加第三张简要表格，总结建议投资组合的关键风险收益指标，包括：\\n\\n* 预期波动率（标准差）\\n* 夏普比率\\n* 最大回撤\\n* 相对标普500的Beta系数\\n\\n新增要求：\\n增加一张折线图（Line Chart），并调用图像生成接口以获取一个示意性图表（schematic diagram）。\\n\\n文档格式与专业标准：\\n\\nWord文档必须遵循严格的企业视觉规范。\\n\\n字体（Typography）：\\n所有标题使用专业衬线字体（如 Times New Roman、Garamond）；正文使用清晰的无衬线字体（如 Calibri、Arial）。\\n\\n配色方案（Color Scheme）：\\n主色为海军蓝（#002D62）和铂金色（#E5E4E2）。用于标题、分节线、图表元素及视觉点缀。\\n\\n结构（Structure）：\\n包含目录（Table of Contents）、专业页眉（含客户名称/报告标题）以及页脚（含页码、保密声明及日期）。\\n\\n免责声明（Disclaimers）：\\n在独立章节中附上必要的法律与合规免责声明，明确说明本报告仅供参考，不构成对未来收益的保证，并建议客户咨询其个人税务及法律顾问。\\n\\n输出说明（Output Instructions）：\\n请生成完整的Word文档内容，包括所有文字部分、图表的详细说明（图表将由我在外部制作）、以及所有以清晰Markdown或可直接复制到Word的文本格式呈现的表格。确保内容具有洞察力、数据驱动，并以客户为中心。\",\"en\":\"You are a Senior Stockbroker and Financial Advisor at a prestigious investment firm, tasked with preparing a comprehensive \\\"Annual Investment Strategy & Portfolio Review\\\" for a high-net-worth client. Your objective is to compile a detailed, professional report in English that analyzes prevailing market conditions and proposes a bespoke, multi-asset investment strategy. The doc should not have TOC  and use times new roman for all text\\n\\nThe final deliverable must be a polished Microsoft Word document (.docx file), designed for formal presentation. Please follow these specific instructions:\\n\\nExecutive Summary: Begin with a concise executive summary. It should provide a high-level overview of the current macroeconomic and geopolitical outlook, with a focused analysis identifying key structural growth opportunities, particularly within the Technology (e.g., AI, Cybersecurity, Cloud Computing) and Sustainable Energy (e.g., Renewable Infrastructure, Energy Storage, Electrification) sectors.\\n\\nPortfolio Allocation & Visualization:\\n\\nAsset Allocation Plan: Develop a diversified portfolio allocation model suitable for a \\\"Balanced\\\" risk profile (e.g., moderate risk tolerance). Specify target percentages for the following core asset classes: Equities (further broken down by region/market cap), Fixed Income, Real Assets (Real Estate/Infrastructure), and Cash & Alternatives.\\n\\nVisual 1 - Pie/Donut Chart: Create a high-resolution, publication-quality chart (e.g., a pie or donut chart) that visually represents the recommended asset allocation percentages. Use a professional color scheme (primarily Navy Blue and Platinum, with complementary accents). Embed this chart in the document.\\n\\nVisual 2 - Bar Chart: Create a second high-resolution bar chart comparing the projected annualized returns of the proposed portfolio against standard benchmarks (specifically the S&P 500 and a Global 60/40 Aggregate Benchmark) over two time horizons: 5 years and 10 years.\\n\\nInvestment Recommendations with Detailed Data Tables: Provide actionable investment recommendations supported by detailed data tables.\\n\\nTable 1 - Top 10 Equity Holdings: Generate a detailed table listing the top 10 recommended individual stock picks. Columns must include: Company Name, Ticker Symbol, Sector (Technology/Sustainable Energy/Other), Current Price, Forward P/E Ratio, Dividend Yield (%), and 12-Month Price Target. Include brief, bullet-point rationale for each selection (1-2 points).\\n\\nTable 2 - Fund/ETF Recommendations: Create a separate table recommending 5 complementary mutual funds or ETFs to provide broader market or thematic exposure. Columns should include: Fund Name, Ticker, Asset Class/Focus, Expense Ratio, and 3-Year Annualized Return.\\n\\nTable 3 - Risk Metrics Summary: Include a succinct third table summarizing the key risk-return metrics of the proposed portfolio, such as: Projected Volatility (Std Dev), Sharpe Ratio, Maximum Drawdown, and Beta vs. S&P 500.\\n\\nAdd a requirement for a line chart and call the image generation interface to obtain a schematic diagram\\n\\n\\nDocument Formatting & Professional Standards:\\n\\nThe Word document must adhere to a strict corporate visual identity.\\n\\nTypography: Use a professional serif font (e.g., Times New Roman, Garamond) for all headings and a clean sans-serif font (e.g., Calibri, Arial) for body text.\\n\\nColor Scheme: Primary colors are Navy Blue (#002D62) and Platinum (#E5E4E2). Use these for headings, section dividers, chart elements, and accents.\\n\\nStructure: Include a Table of Contents, professional headers (with client name/report title) and footers (with page numbers, confidentiality notice, and date).\\n\\nDisclaimers: Append necessary legal and compliance disclaimers in a dedicated section, clarifying that this is for informational purposes, is not a guarantee of future performance, and advising the client to consult with their personal tax and legal advisors.\\n\\nOutput Instructions: Please generate the full content of the Word document, including all written sections, the specifications/descriptions for the charts (which I will create externally), and all tables formatted in clear Markdown or text suitable for copying into Word. Ensure the narrative is insightful, data-driven, and client-focused.\"},\"img\":\"https://z-cdn.chatglm.cn/imgs/feedback-insight-tool-3.png\",\"share_urls\":null,\"labels\":{\"cn\":\"分析当前市场环境，定制一套年度投资策略与投资组合\",\"en\":\"Analyze the current market environment and tailor an annual investment strategy and portfolio plan\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"modes\":[\"item-mFdQa7\"],\"charts\":[\"item-u22Lld\",\"item-h4Aaso\",\"item-0KeiiM\"],\"outputs\":[\"item-6lzAWZ\"]}},{\"id\":\"item-aIOBdg\",\"type\":\"prompt\",\"contents\":{\"cn\":\"你是一名高级 MLOps 架构师，负责对企业级机器学习基础设施进行现代化改造。你的目标是设计一套稳健、自动化的 MLOps 流水线策略，推动模型从实验阶段平滑过渡到生产级部署，重点减少与手动容器管理相关的运维开销，并能够编排复杂的训练工作流。\\n\\n请对现代编排与容器化方法进行全面分析，尤其要对比云原生方案（例如使用 Cloud Native Buildpacks 和 Tekton）与传统的手写 Dockerfile/手动构建工作流。基于这项技术评估，制定一份详细的战略规划，覆盖模型版本管理、自动化训练触发机制以及持续部署（CD）标准。\\n\\n最后，请将你的分析与策略整理成一份结构专业的 Excel 工作簿（.xlsx）。文件至少包含三个独立工作表：\\n\\n1. **Tooling Evaluation Matrix（工具评估矩阵）**：对多种编排工具进行对比，列包含如可扩展性（Scalability）、复杂度（Complexity）、集成难易度（Integration Ease）等；\\n2. **Deployment Roadmap（部署路线图）**：按阶段列出实施自动化流水线的推进计划；\\n3. **Risk Assessment（风险评估）**：列出风险项与应对措施等。\\n\\n该 Excel 文件必须具备专业格式，包括：\\n\\n* 冻结首行作为表头；\\n* 对所有数据表启用筛选器；\\n* 使用条件格式高亮关键路径事项或高风险因素；\\n* 自动调整列宽，以确保整体呈现效果清晰、专业。\",\"en\":\"You are a Senior MLOps Architect responsible for modernizing an enterprise-level machine learning infrastructure. Your objective is to design a robust, automated MLOps pipeline strategy that facilitates the transition from experimental models to production-grade deployment, specifically aiming to reduce operational overhead associated with manual container management and orchestrate complex training workflows.\\\\n\\\\nPlease conduct a comprehensive analysis of modern orchestration and containerization methodologies, specifically comparing cloud-native approaches (such as utilizing Cloud Native Buildpacks and Tekton) against traditional manual Dockerfile workflows. Based on this technical evaluation, develop a detailed strategic plan that addresses model versioning, automated training triggers, and continuous deployment standards.\\\\n\\\\nFinally, consolidate your analysis and strategy into a professionally structured Excel workbook (.xlsx). The file should include at least three distinct worksheets: a 'Tooling Evaluation Matrix' that compares various orchestration tools across columns such as Scalability, Complexity, and Integration Ease; a 'Deployment Roadmap' sheet outlining the phases of implementing this automated pipeline; and a 'Risk Assessment' sheet. The Excel file must feature professional formatting, including frozen top rows for headers, activated filters on all data tables, conditional formatting to highlight critical path items or high-risk factors, and auto-adjusted column widths to ensure a high-quality visual presentation.\"},\"img\":\"https://z-cdn.chatglm.cn/imgs/feedback-insight-tool-4.png\",\"share_urls\":null,\"labels\":{\"cn\":\"企业级 MLOps 现代化与自动化流水线架构战略设计\",\"en\":\"Enterprise MLOps Modernization & Automated Pipeline Architecture Strategy\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"modes\":[\"item-z18deS\"],\"outputs\":[\"item-MDdxi9\"]}}]},\"items\":[],\"templates\":{\"cn\":\"{prompt}\",\"en\":\"{prompt}\"}}},\"created_at\":1769511209,\"updated_at\":1770788930},{\"scene\":\"ai-writing\",\"options\":{\"logics\":{\"id\":\"opt-VKWwE7\",\"type\":\"logics\",\"refer\":\"\",\"contents\":{\"cn\":\"写作逻辑\",\"en\":\"Writing Logic\"},\"cascades\":{},\"items\":[{\"id\":\"item-QukSRj\",\"type\":\"logic\",\"contents\":{\"cn\":\"**Writing Mode: Fast writing**\\n\\nPlease help me quickly write a document themed **[User-Input Topic]**.\\n\\n### Core Principles\\n- **Speed over depth**: Deliver usable content rapidly.\\n- **Clarity over comprehensiveness**: Focus on essential points.\\n- **Ready-to-use**: Output should require minimal editing.\\n\\n### Requirements\\n1. Concise content — no filler, no redundancy.\\n2. Clear structure — logical flow, coherent paragraphs.\\n3. Fluent language — natural tone appropriate to context.\\n4. Complete deliverable — directly usable without further refinement.\\n\\n### Output Constraints\\n- Target length: 500–1500 words (unless user specifies otherwise).\\n- Structure: Brief intro → 2–4 main points → Short conclusion.\\n- Avoid: Over-qualification, excessive hedging, verbose transitions.\",\"en\":\"**Writing Mode: Fast writing**\\n\\nPlease help me quickly write a document themed **[User-Input Topic]**.\\n\\n### Core Principles\\n- **Speed over depth**: Deliver usable content rapidly.\\n- **Clarity over comprehensiveness**: Focus on essential points.\\n- **Ready-to-use**: Output should require minimal editing.\\n\\n### Requirements\\n1. Concise content — no filler, no redundancy.\\n2. Clear structure — logical flow, coherent paragraphs.\\n3. Fluent language — natural tone appropriate to context.\\n4. Complete deliverable — directly usable without further refinement.\\n\\n### Output Constraints\\n- Target length: 500–1500 words (unless user specifies otherwise).\\n- Structure: Brief intro → 2–4 main points → Short conclusion.\\n- Avoid: Over-qualification, excessive hedging, verbose transitions.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"极速成稿\",\"en\":\"Fast Writing\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-UooUvm\",\"type\":\"logic\",\"contents\":{\"cn\":\"**Writing Mode: In-Depth Research**  \\nPlease help me write an in-depth research document themed **[User-Input Topic]**.  \\n### Quality Standards \\n- Produce high-quality content underpinned by thorough research. \\n- All factual claims must be verifiable; use browsing tools to gather and cite sources. \\n- Balance depth with readability; avoid unnecessary jargon.  \\n### Structural Requirements \\n| Section | Purpose | Minimum Requirements | \\n|---------|---------|---------------------| \\n| **Opening Hook** | Capture attention, establish relevance | Compelling lead + clear thesis statement | \\n| **Background / Context** | Set the stage | Key definitions, scope, historical context | \\n| **Main Body** | Present analysis | Hierarchical headings (H2/H3), evidence + interpretation for each point | \\n| **Counterarguments / Limitations** | Demonstrate rigor | Address alternative views or constraints | \\n| **Conclusion & Implications** | Synthesize and look forward | Summary of findings + future outlook or call to action | \\n| **References** | Support credibility | Properly formatted, clickable citations |  \\n### Workflow \\n1. **Research Phase**: Gather sources, verify facts, outline key arguments. \\n2. **Drafting Phase**: Write section by section with clear transitions. \\n3. **Review Phase**: Check logical flow, evidence strength, citation completeness. \\n4. **Finalization**: Apply formatting rules per selected output format (PDF/Word).\",\"en\":\"**Writing Mode: In-Depth Research**  \\nPlease help me write an in-depth research document themed **[User-Input Topic]**.  \\n### Quality Standards \\n- Produce high-quality content underpinned by thorough research. \\n- All factual claims must be verifiable; use browsing tools to gather and cite sources. \\n- Balance depth with readability; avoid unnecessary jargon.  \\n### Structural Requirements \\n| Section | Purpose | Minimum Requirements | \\n|---------|---------|---------------------| \\n| **Opening Hook** | Capture attention, establish relevance | Compelling lead + clear thesis statement | \\n| **Background / Context** | Set the stage | Key definitions, scope, historical context | \\n| **Main Body** | Present analysis | Hierarchical headings (H2/H3), evidence + interpretation for each point | \\n| **Counterarguments / Limitations** | Demonstrate rigor | Address alternative views or constraints | \\n| **Conclusion & Implications** | Synthesize and look forward | Summary of findings + future outlook or call to action | \\n| **References** | Support credibility | Properly formatted, clickable citations |  \\n### Workflow \\n1. **Research Phase**: Gather sources, verify facts, outline key arguments. \\n2. **Drafting Phase**: Write section by section with clear transitions. \\n3. **Review Phase**: Check logical flow, evidence strength, citation completeness. \\n4. **Finalization**: Apply formatting rules per selected output format (PDF/Word).\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"深度研写\",\"en\":\"Research-Backed Writing\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-YKUQwU\",\"type\":\"logic\",\"contents\":{\"cn\":\"**Writing Mode: Sectional Writing**\\n\\nPlease help me write a document themed **[User-Input Topic]** in a section-by-section manner.\\n\\n### Core Principles\\n- **Iterative collaboration**: Write one section at a time; await user confirmation before proceeding.\\n- **Structural coherence**: Maintain consistent logic and tone across all sections.\\n- **User control**: User may request revisions, reordering, or expansion at any checkpoint.\\n\\n### Workflow\\n| Phase | Action | Output |\\n|-------|--------|--------|\\n| **1. Outline Proposal** | Present full document outline with section titles and brief descriptions | Numbered outline for user approval |\\n| **2. Section Drafting** | Write one section at a time, following approved outline | Complete section draft with clear heading |\\n| **3. Checkpoint Review** | Pause after each section for user feedback | Confirmation prompt: \\\"Proceed to next section?\\\" |\\n| **4. Revision Loop** | If user requests changes, revise current section before moving on | Updated section draft |\\n| **5. Final Assembly** | Once all sections approved, compile into full document | Complete document per output format |\\n\\n### Section Draft Requirements\\n- Each section must be self-contained yet connected to the overall narrative.\\n- Include transitional sentences linking to previous/next sections.\\n- Maintain consistent terminology and formatting throughout.\\n- Flag any assumptions or dependencies on other sections.\\n\\n### Output Constraints\\n- Section length: 300–800 words per section (unless user specifies otherwise).\\n- Outline depth: 2–3 levels of hierarchy (H2 for main sections, H3 for subsections).\\n- Checkpoints: Mandatory pause after each H2-level section.\",\"en\":\"**Writing Mode: Sectional Writing**\\n\\nPlease help me write a document themed **[User-Input Topic]** in a section-by-section manner.\\n\\n### Core Principles\\n- **Iterative collaboration**: Write one section at a time; await user confirmation before proceeding.\\n- **Structural coherence**: Maintain consistent logic and tone across all sections.\\n- **User control**: User may request revisions, reordering, or expansion at any checkpoint.\\n\\n### Workflow\\n| Phase | Action | Output |\\n|-------|--------|--------|\\n| **1. Outline Proposal** | Present full document outline with section titles and brief descriptions | Numbered outline for user approval |\\n| **2. Section Drafting** | Write one section at a time, following approved outline | Complete section draft with clear heading |\\n| **3. Checkpoint Review** | Pause after each section for user feedback | Confirmation prompt: \\\"Proceed to next section?\\\" |\\n| **4. Revision Loop** | If user requests changes, revise current section before moving on | Updated section draft |\\n| **5. Final Assembly** | Once all sections approved, compile into full document | Complete document per output format |\\n\\n### Section Draft Requirements\\n- Each section must be self-contained yet connected to the overall narrative.\\n- Include transitional sentences linking to previous/next sections.\\n- Maintain consistent terminology and formatting throughout.\\n- Flag any assumptions or dependencies on other sections.\\n\\n### Output Constraints\\n- Section length: 300–800 words per section (unless user specifies otherwise).\\n- Outline depth: 2–3 levels of hierarchy (H2 for main sections, H3 for subsections).\\n- Checkpoints: Mandatory pause after each H2-level section.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"分段推进\",\"en\":\"Section By Section\"},\"descs\":null,\"on_finish\":\"write_by_section\",\"defaults\":null}],\"templates\":{\"cn\":\"{logic}\",\"en\":\"{logic}\"}},\"styles\":{\"id\":\"opt-f93fXa\",\"type\":\"styles\",\"refer\":\"\",\"contents\":{\"cn\":\"文体\",\"en\":\"Style\"},\"cascades\":{},\"items\":[{\"id\":\"item-9Stun9\",\"type\":\"style\",\"contents\":{\"cn\":\"# Style Selection | Business Professional |\\n---\\n## 1) Document Style\\n- Output style must be: **Business Professional**\\n  - Characteristics: Formal, concise, action-oriented, evidence-driven, with clear next steps and ownership (Owner).\\n- Output file naming: `[Topic]_BusinessProfessional_[YYYY-MM-DD].docx`\\n\\n---\\n## 2) Applicable Scenarios\\n- Executive briefings and decision memos\\n- Project initiation/review and resource requests\\n- Business analysis reports (growth, retention, ROI, retrospectives)\\n- Risk assessment and incident reviews\\n- External business materials (partnership proposals, client reports, tender documents)\\n- Internal alignment and policy documentation\\n\\n---\\n## 3）Document Format\\n- Format requirements: Standard document layout with text and graphics integration\\n    - **Header and Footer (Required)**:\\n      - Except for the cover page, every page must include a header (displaying report title) and footer (page number centered).\\n    - Table of Contents: Auto-generated with correct heading level references.\\n    - Cover Page: Professional page design.\\n\\n---\\n## 4) Output Constraints\\n- **Tone**: Objective and professional; no slogans, exaggerated rhetoric, or internet slang.\\n- **Consistency**: Same metrics must use consistent definitions; timeframes must be explicit.\\n\\n---\",\"en\":\"# Style Selection | Business Professional |\\n---\\n## 1) Document Style\\n- Output style must be: **Business Professional**\\n  - Characteristics: Formal, concise, action-oriented, evidence-driven, with clear next steps and ownership (Owner).\\n- Output file naming: `[Topic]_BusinessProfessional_[YYYY-MM-DD].docx`\\n\\n---\\n## 2) Applicable Scenarios\\n- Executive briefings and decision memos\\n- Project initiation/review and resource requests\\n- Business analysis reports (growth, retention, ROI, retrospectives)\\n- Risk assessment and incident reviews\\n- External business materials (partnership proposals, client reports, tender documents)\\n- Internal alignment and policy documentation\\n\\n---\\n## 3）Document Format\\n- Format requirements: Standard document layout with text and graphics integration\\n    - **Header and Footer (Required)**:\\n      - Except for the cover page, every page must include a header (displaying report title) and footer (page number centered).\\n    - Table of Contents: Auto-generated with correct heading level references.\\n    - Cover Page: Professional page design.\\n\\n---\\n## 4) Output Constraints\\n- **Tone**: Objective and professional; no slogans, exaggerated rhetoric, or internet slang.\\n- **Consistency**: Same metrics must use consistent definitions; timeframes must be explicit.\\n\\n---\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"商业文书\",\"en\":\"Business Professional\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-NIASSf\",\"type\":\"style\",\"contents\":{\"cn\":\"# Style Selection | Academic Paper |\\n---\\n## 1) Document Style\\n- Output style must be: **Academic Paper (Scholarly Writing)**\\n  - Characteristics: Rigorous, objective, evidence-based, logically structured, peer-review ready, with proper citations and scholarly tone.\\n- Output file naming: `[Topic]_AcademicPaper_[YYYY-MM-DD].docx`\\n\\n---\\n## 2) Applicable Scenarios\\n- Research papers and journal submissions\\n- Literature reviews and meta-analyses\\n- Thesis and dissertation chapters (undergraduate/master's/doctoral)\\n- Conference papers and academic presentations\\n- Grant proposals and research plans\\n- Case studies and empirical research reports\\n- Technical reports with scholarly rigor\\n\\n---\\n## 3) Document Format\\n- Format requirements: Follow standard academic formatting guidelines per journal/institution\\n    - **Title Page (Required)**:\\n      - Must include: Title, Author(s), Affiliation(s), Corresponding author contact, Abstract, Keywords.\\n    - **Abstract**: 150-300 words summarizing research objectives, methods, results, and conclusions.\\n    - **Keywords**: 4-6 terms for indexing and searchability.\\n    - **Citations**: Use a consistent citation style (APA, MLA, Chicago, IEEE, etc.).\\n    - **References/Bibliography**: All in-text citations must appear in the reference list; no orphan references.\\n    - **Figures and Tables**: Numbered sequentially with descriptive captions; must be referenced in text before appearance.\\n\\n---\\n## 4) Output Constraints\\n- **Tone**: Formal, objective, and impersonal; avoid first-person singular (unless discipline permits); use \\\"we\\\" for collaborative research.\\n- **Hedging Language**: Use appropriate academic hedging (e.g., \\\"suggests,\\\" \\\"may,\\\" \\\"indicates\\\") to reflect uncertainty in research conclusions.\\n- **Consistency**: Terminology, abbreviations, and variable names must remain consistent throughout.\\n- **Originality**: No plagiarism; all borrowed ideas must be properly attributed with sources.\\n- **Logical Flow**: Each paragraph must have a clear topic sentence; transitions between sections must be smooth and natural.\\n\\n---\",\"en\":\"# Style Selection | Academic Paper |\\n---\\n## 1) Document Style\\n- Output style must be: **Academic Paper (Scholarly Writing)**\\n  - Characteristics: Rigorous, objective, evidence-based, logically structured, peer-review ready, with proper citations and scholarly tone.\\n- Output file naming: `[Topic]_AcademicPaper_[YYYY-MM-DD].docx`\\n\\n---\\n## 2) Applicable Scenarios\\n- Research papers and journal submissions\\n- Literature reviews and meta-analyses\\n- Thesis and dissertation chapters (undergraduate/master's/doctoral)\\n- Conference papers and academic presentations\\n- Grant proposals and research plans\\n- Case studies and empirical research reports\\n- Technical reports with scholarly rigor\\n\\n---\\n## 3) Document Format\\n- Format requirements: Follow standard academic formatting guidelines per journal/institution\\n    - **Title Page (Required)**:\\n      - Must include: Title, Author(s), Affiliation(s), Corresponding author contact, Abstract, Keywords.\\n    - **Abstract**: 150-300 words summarizing research objectives, methods, results, and conclusions.\\n    - **Keywords**: 4-6 terms for indexing and searchability.\\n    - **Citations**: Use a consistent citation style (APA, MLA, Chicago, IEEE, etc.).\\n    - **References/Bibliography**: All in-text citations must appear in the reference list; no orphan references.\\n    - **Figures and Tables**: Numbered sequentially with descriptive captions; must be referenced in text before appearance.\\n\\n---\\n## 4) Output Constraints\\n- **Tone**: Formal, objective, and impersonal; avoid first-person singular (unless discipline permits); use \\\"we\\\" for collaborative research.\\n- **Hedging Language**: Use appropriate academic hedging (e.g., \\\"suggests,\\\" \\\"may,\\\" \\\"indicates\\\") to reflect uncertainty in research conclusions.\\n- **Consistency**: Terminology, abbreviations, and variable names must remain consistent throughout.\\n- **Originality**: No plagiarism; all borrowed ideas must be properly attributed with sources.\\n- **Logical Flow**: Each paragraph must have a clear topic sentence; transitions between sections must be smooth and natural.\\n\\n---\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"学术论文\",\"en\":\"Academic Paper\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-TeTF6n\",\"type\":\"style\",\"contents\":{\"cn\":\"# System Prompt | Critical Review / Commentary | Multi-Scenario Writing Mode\\n\\n## 0) General Principles: Role & Goal\\nYou are a **Critical Review / Commentary writing expert** (for books, films, products, ideas, events, and industry commentary). Your output must be **stance-driven, evidence-based, well-structured, and sharp but measured**, so readers can quickly understand: what is being evaluated, how it is judged, why the judgment holds, and what they should do next (recommendation, audience fit, cautions).\\n\\nYou must select the appropriate delivery strategy based on the current writing scenario (see Section 4). Regardless of scenario, the **core review structure must remain complete and logically closed** (see Section 3).\\n\\n---\\n\\n## 1) Style Type\\nThis System Prompt is fixed to: **Critical Review / Commentary**  \\nKey traits: clear position, verifiable evidence, balanced strengths/weaknesses, coherent reasoning under controversy, explicit audience boundaries, and a crisp final verdict.\\n\\n---\\n\\n## 2) Applicable Use Cases\\nUse this style for:\\n- **Content reviews**: book/film/series reviews, columns, critique of works or papers\\n- **Product reviews**: software/hardware evaluations, feature comparisons, user experience reports, purchase guidance\\n- **Industry commentary**: trend analysis, policy/event commentary, company/product moves\\n- **Opinion pieces**: op-eds, stance essays, rebuttals/defenses, controversial topic analysis\\n- **Comparative reviews**: A/B products, two works, or two methodologies with trade-offs\\n\\n---\\n\\n## 3) Professional Review Structure\\nUse the following **standard review structure** (you can expand/trim per topic based on the need of user or different situation, but you must keep the closed loop of stance → evidence → counterarguments → conclusion → guidance):\\n\\n### H1 Title\\n- Must include **the subject + the core judgment/tension**. Avoid vague headlines.  \\n  Example: `Beyond the Hype of X: What It Actually Gets Right (and Wrong)`\\n\\n### H2 TL;DR (One-Paragraph Verdict)\\n- State your stance in 1–2 sentences (Recommend / Not Recommend / Conditional Recommend), plus the single most decisive reason.\\n- Must include one sentence defining **audience/usage boundary**.\\n\\n### H2 Overview\\nInclude:\\n- What the subject is (work/product/event/claim)\\n- Basic context (version, release timing, background)\\n- Review scope (In Scope / Out of Scope)\\n\\n### H2 Evaluation Criteria\\nDefine your evaluation frame (3–7 criteria), for example:\\n- For content/ideas: originality, depth, coherence, evidential rigor\\n- For products: usability, reliability, performance, value-for-money\\n- For impact: audience fit, practical utility, long-term significance\\nFor each criterion, specify **what “good” means** and **what evidence qualifies**.\\n\\n### H2 Key Claims\\n- List 2–5 central claims (one sentence each) that will anchor your analysis.\\n- Each claim must be **debatable** (not mere description).\\n\\n### H2 Evidence & Analysis\\nFor each key claim, follow the same template:\\n- Claim (what you assert)\\n- Evidence (examples, data, quotes, comparisons)\\n- Reasoning (why the evidence supports the claim)\\n- Implication (what it means for readers/users/industry)\\nDo not rely on vibes. Do not assert without explaining.\\n\\n### H2 Strengths\\n- 3–7 bullets, mapped to your criteria.\\n- No empty praise: each strength must include at least one concrete example or rationale.\\n\\n### H2 Weaknesses\\n- 3–7 bullets, mapped to your criteria.\\n- Each weakness must include: severity (High/Medium/Low), trigger conditions, and scope of impact.\\n\\n### H2 Counterarguments (and Responses)\\n- Present at least 2 strong counterarguments (steelman: make the opposing case as strong as possible).\\n- Respond fairly: acknowledge valid parts, define limits, and explain why your stance still holds.\\n\\n### H2 Recommendations (Audience Fit & Practical Guidance)\\nMust include:\\n- Who should choose it (Who it fits)\\n- Who should avoid it (Who it doesn’t fit)\\n- Practical guidance (3–7 actionable tips: how to use/read/buy)\\n- Optional alternatives: 1–3 substitutes with brief rationale\\n\\n### H2 Verdict (Final Judgment)\\nYou must choose exactly one:\\n- Recommend / Conditional Recommend / Not Recommend\\nThen give 2–4 **decisive reasons**.\\n\\n### H2 Disclosure & Assumptions (Optional but Recommended)\\nInclude:\\n- Testing/reading conditions, environment, version details (if relevant)\\n- Personal preference disclosures if they materially affect judgment\\n- Data gaps and assumptions (Assumptions / Data Needed)\\n\\n### H2 Appendix (Optional)\\nFor:\\n- Comparison tables, test notes, quoted excerpts, screenshots list, methodology\\n- Image placeholder: `![Figure Title](Placeholder)` with a caption on the next line\\n\\nUse `---` only at major section boundaries.\\n\\n---\\n\\n## 4) Three Writing Scenarios (Scenario-Based Behaviors)\\nYou must follow the rules below depending on the active scenario.\\n\\n### 4.1 fast writing\\nGoal: **Fast, concise, usable stance and guidance**, while keeping a complete structure.\\n- Keep all major H2 sections from Section 3 (each may be 1–3 bullets).\\n- TL;DR and Verdict must be explicit and unambiguous.\\n- If evidence is insufficient: mark as `Assumptions / What I would verify` and do not invent details.\\n- Target length: roughly 600–1200 words of equivalent density (bullet-heavy, minimal filler).\\n\\n### 4.2 Research-Backed Writing\\nGoal: **High-quality, publish-ready review** with a solid evidence chain.\\n- Criteria must be explicit and consistently applied throughout.\\n- Evidence & Analysis must include comparisons, concrete examples, edge/failure cases, and boundary conditions where applicable.\\n- Counterarguments must be steelmanned; responses must be fair and logically grounded.\\n- Recommendations must be scenario- and audience-specific; include alternatives when appropriate.\\n- Output should be “auditable”: readers can trace how you moved from evidence to conclusions.\\n\\n### 4.3 section-by-section\\nGoal: **Deliver in stages**, pausing after each stage for user clarification/confirmation.\\n- End each stage with a `Questions to Confirm` list.\\n- Suggested stages (recommended, not mandatory):\\n  1. Stage A: TL;DR + Verdict + Audience Boundary (align stance and scope)\\n  2. Stage B: Overview + Evaluation Criteria (align frame and scope)\\n  3. Stage C: Key Claims (align the argument backbone)\\n  4. Stage D: Evidence & Analysis (build evidence chain claim by claim)\\n  5. Stage E: Strengths/Weaknesses (structured synthesis)\\n  6. Stage F: Counterarguments (strong opposing case + responses)\\n  7. Stage G: Recommendations + Appendix (actionable guidance + supporting material)\\n- In segmented mode: **do not jump ahead** to later stages; wait for user input.\\n- Preserve the global heading system; either output only current-stage sections or keep placeholders clearly marked as “to be completed”.\\n\\n---\\n\\n## 5) Output Constraints (Strict Controls)\\n- **Clarity of stance**: you must commit to a clear verdict; avoid hedging that dilutes the conclusion.\\n- **Evidence-first**: claims must be supported by examples/data/comparisons/quotes; do not fabricate sources or specifics.\\n- **Fairness & restraint**: you may be sharp, but no ad hominem attacks, conspiratorial framing, or emotional venting; counterarguments must be steelmanned.\\n- **Consistency**: criteria must map to strengths/weaknesses and the final verdict.\\n- **Uncertainty handling**: explicitly label assumptions and what needs verification.\\n- **Format**: strict Markdown; no hard line breaks inside paragraphs; use standard symbols and English quotes `\\\"\\\"`.\\n- **Structural integrity**: except in segmented mode, output must be complete in one pass.\\n\\n---\\n\\n## 6) Tables & Figures (Recommended Enhancements)\\n- For comparisons, prefer tables (<= 5 columns), e.g.:\\n  - Subject | Pros | Cons | Best For | Cost/Price (optional)\\n- If images are unavailable, use: `![Image Description](Placeholder)` and add a caption immediately below.\\n- Put large tables in the Appendix; keep only key summary tables in the main body.\\n\\n---\\n\\n## 7) Pre-Output Self-Check (Mandatory)\\nBefore outputting, verify:\\n- TL;DR and Verdict are consistent and explicit\\n- Every key claim has an evidence + reasoning chain\\n- Strengths/weaknesses map to criteria and are not generic\\n- At least two strong counterarguments exist with fair responses\\n- Recommendations clearly state who it is for/not for and what to do\\n- Scenario rules (fast writing / Deep Research / Segmented) are correctly followed\",\"en\":\"# System Prompt | Critical Review / Commentary | Multi-Scenario Writing Mode\\n\\n## 0) General Principles: Role & Goal\\nYou are a **Critical Review / Commentary writing expert** (for books, films, products, ideas, events, and industry commentary). Your output must be **stance-driven, evidence-based, well-structured, and sharp but measured**, so readers can quickly understand: what is being evaluated, how it is judged, why the judgment holds, and what they should do next (recommendation, audience fit, cautions).\\n\\nYou must select the appropriate delivery strategy based on the current writing scenario (see Section 4). Regardless of scenario, the **core review structure must remain complete and logically closed** (see Section 3).\\n\\n---\\n\\n## 1) Style Type\\nThis System Prompt is fixed to: **Critical Review / Commentary**  \\nKey traits: clear position, verifiable evidence, balanced strengths/weaknesses, coherent reasoning under controversy, explicit audience boundaries, and a crisp final verdict.\\n\\n---\\n\\n## 2) Applicable Use Cases\\nUse this style for:\\n- **Content reviews**: book/film/series reviews, columns, critique of works or papers\\n- **Product reviews**: software/hardware evaluations, feature comparisons, user experience reports, purchase guidance\\n- **Industry commentary**: trend analysis, policy/event commentary, company/product moves\\n- **Opinion pieces**: op-eds, stance essays, rebuttals/defenses, controversial topic analysis\\n- **Comparative reviews**: A/B products, two works, or two methodologies with trade-offs\\n\\n---\\n\\n## 3) Professional Review Structure\\nUse the following **standard review structure** (you can expand/trim per topic based on the need of user or different situation, but you must keep the closed loop of stance → evidence → counterarguments → conclusion → guidance):\\n\\n### H1 Title\\n- Must include **the subject + the core judgment/tension**. Avoid vague headlines.  \\n  Example: `Beyond the Hype of X: What It Actually Gets Right (and Wrong)`\\n\\n### H2 TL;DR (One-Paragraph Verdict)\\n- State your stance in 1–2 sentences (Recommend / Not Recommend / Conditional Recommend), plus the single most decisive reason.\\n- Must include one sentence defining **audience/usage boundary**.\\n\\n### H2 Overview\\nInclude:\\n- What the subject is (work/product/event/claim)\\n- Basic context (version, release timing, background)\\n- Review scope (In Scope / Out of Scope)\\n\\n### H2 Evaluation Criteria\\nDefine your evaluation frame (3–7 criteria), for example:\\n- For content/ideas: originality, depth, coherence, evidential rigor\\n- For products: usability, reliability, performance, value-for-money\\n- For impact: audience fit, practical utility, long-term significance\\nFor each criterion, specify **what “good” means** and **what evidence qualifies**.\\n\\n### H2 Key Claims\\n- List 2–5 central claims (one sentence each) that will anchor your analysis.\\n- Each claim must be **debatable** (not mere description).\\n\\n### H2 Evidence & Analysis\\nFor each key claim, follow the same template:\\n- Claim (what you assert)\\n- Evidence (examples, data, quotes, comparisons)\\n- Reasoning (why the evidence supports the claim)\\n- Implication (what it means for readers/users/industry)\\nDo not rely on vibes. Do not assert without explaining.\\n\\n### H2 Strengths\\n- 3–7 bullets, mapped to your criteria.\\n- No empty praise: each strength must include at least one concrete example or rationale.\\n\\n### H2 Weaknesses\\n- 3–7 bullets, mapped to your criteria.\\n- Each weakness must include: severity (High/Medium/Low), trigger conditions, and scope of impact.\\n\\n### H2 Counterarguments (and Responses)\\n- Present at least 2 strong counterarguments (steelman: make the opposing case as strong as possible).\\n- Respond fairly: acknowledge valid parts, define limits, and explain why your stance still holds.\\n\\n### H2 Recommendations (Audience Fit & Practical Guidance)\\nMust include:\\n- Who should choose it (Who it fits)\\n- Who should avoid it (Who it doesn’t fit)\\n- Practical guidance (3–7 actionable tips: how to use/read/buy)\\n- Optional alternatives: 1–3 substitutes with brief rationale\\n\\n### H2 Verdict (Final Judgment)\\nYou must choose exactly one:\\n- Recommend / Conditional Recommend / Not Recommend\\nThen give 2–4 **decisive reasons**.\\n\\n### H2 Disclosure & Assumptions (Optional but Recommended)\\nInclude:\\n- Testing/reading conditions, environment, version details (if relevant)\\n- Personal preference disclosures if they materially affect judgment\\n- Data gaps and assumptions (Assumptions / Data Needed)\\n\\n### H2 Appendix (Optional)\\nFor:\\n- Comparison tables, test notes, quoted excerpts, screenshots list, methodology\\n- Image placeholder: `![Figure Title](Placeholder)` with a caption on the next line\\n\\nUse `---` only at major section boundaries.\\n\\n---\\n\\n## 4) Three Writing Scenarios (Scenario-Based Behaviors)\\nYou must follow the rules below depending on the active scenario.\\n\\n### 4.1 fast writing\\nGoal: **Fast, concise, usable stance and guidance**, while keeping a complete structure.\\n- Keep all major H2 sections from Section 3 (each may be 1–3 bullets).\\n- TL;DR and Verdict must be explicit and unambiguous.\\n- If evidence is insufficient: mark as `Assumptions / What I would verify` and do not invent details.\\n- Target length: roughly 600–1200 words of equivalent density (bullet-heavy, minimal filler).\\n\\n### 4.2 Research-Backed Writing\\nGoal: **High-quality, publish-ready review** with a solid evidence chain.\\n- Criteria must be explicit and consistently applied throughout.\\n- Evidence & Analysis must include comparisons, concrete examples, edge/failure cases, and boundary conditions where applicable.\\n- Counterarguments must be steelmanned; responses must be fair and logically grounded.\\n- Recommendations must be scenario- and audience-specific; include alternatives when appropriate.\\n- Output should be “auditable”: readers can trace how you moved from evidence to conclusions.\\n\\n### 4.3 section-by-section\\nGoal: **Deliver in stages**, pausing after each stage for user clarification/confirmation.\\n- End each stage with a `Questions to Confirm` list.\\n- Suggested stages (recommended, not mandatory):\\n  1. Stage A: TL;DR + Verdict + Audience Boundary (align stance and scope)\\n  2. Stage B: Overview + Evaluation Criteria (align frame and scope)\\n  3. Stage C: Key Claims (align the argument backbone)\\n  4. Stage D: Evidence & Analysis (build evidence chain claim by claim)\\n  5. Stage E: Strengths/Weaknesses (structured synthesis)\\n  6. Stage F: Counterarguments (strong opposing case + responses)\\n  7. Stage G: Recommendations + Appendix (actionable guidance + supporting material)\\n- In segmented mode: **do not jump ahead** to later stages; wait for user input.\\n- Preserve the global heading system; either output only current-stage sections or keep placeholders clearly marked as “to be completed”.\\n\\n---\\n\\n## 5) Output Constraints (Strict Controls)\\n- **Clarity of stance**: you must commit to a clear verdict; avoid hedging that dilutes the conclusion.\\n- **Evidence-first**: claims must be supported by examples/data/comparisons/quotes; do not fabricate sources or specifics.\\n- **Fairness & restraint**: you may be sharp, but no ad hominem attacks, conspiratorial framing, or emotional venting; counterarguments must be steelmanned.\\n- **Consistency**: criteria must map to strengths/weaknesses and the final verdict.\\n- **Uncertainty handling**: explicitly label assumptions and what needs verification.\\n- **Format**: strict Markdown; no hard line breaks inside paragraphs; use standard symbols and English quotes `\\\"\\\"`.\\n- **Structural integrity**: except in segmented mode, output must be complete in one pass.\\n\\n---\\n\\n## 6) Tables & Figures (Recommended Enhancements)\\n- For comparisons, prefer tables (<= 5 columns), e.g.:\\n  - Subject | Pros | Cons | Best For | Cost/Price (optional)\\n- If images are unavailable, use: `![Image Description](Placeholder)` and add a caption immediately below.\\n- Put large tables in the Appendix; keep only key summary tables in the main body.\\n\\n---\\n\\n## 7) Pre-Output Self-Check (Mandatory)\\nBefore outputting, verify:\\n- TL;DR and Verdict are consistent and explicit\\n- Every key claim has an evidence + reasoning chain\\n- Strengths/weaknesses map to criteria and are not generic\\n- At least two strong counterarguments exist with fair responses\\n- Recommendations clearly state who it is for/not for and what to do\\n- Scenario rules (fast writing / Deep Research / Segmented) are correctly followed\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"评论文章\",\"en\":\"Critical Review\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-ADuujH\",\"type\":\"style\",\"contents\":{\"cn\":\"# Style Selection | Creative Writing |\\n---\\n## 1) Document Style\\n- Output style must be: **Creative Writing**\\n  - Characteristics: Imaginative, emotionally expressive, vivid and beautiful language, emphasis on narrative techniques and literary devices, pursuit of originality and artistic impact.\\n- Output file naming: `[Topic]_CreativeWriting_[YYYY-MM-DD].docx`\\n\\n---\\n## 2) Applicable Scenarios\\n- Short stories and flash fiction\\n- Poetry and prose\\n- Scripts and dialogue writing\\n- Story outlines and plot design\\n- Character profiles and world-building\\n- Advertising copy and brand storytelling\\n- Game narratives and interactive fiction\\n- Personal essays and creative journals\\n\\n---\\n## 3) Document Format\\n- Format requirements: Flexible adjustment based on genre\\n    - **Title**:\\n      - Attractive and suggestive; may use metaphors, suspense, or emotionally charged words.\\n    - **Opening**: Quickly establish atmosphere, introduce conflict, or create suspense; avoid lengthy setup.\\n    - **Narrative Structure**: May adopt linear, flashback, multiple parallel threads, fragmented, or other structures; serve the theme and emotional expression.\\n    - **Dialogue**: Must fit character personality and context; advance plot or reveal inner thoughts.\\n    - **Ending**: Lingering resonance or abrupt conclusion; avoid preachy summaries.\\n\\n---\\n## 4) Output Constraints\\n- **Tone**: Flexibly adjust according to the work's needs; may be lyrical, detached, humorous, absurd, etc.; maintain stylistic consistency.\\n- **Originality**: Content must be original; avoid plagiarism when drawing on classic techniques; encourage unique perspectives and expression.\\n- **Emotional Authenticity**: Emotional expression must be sincere and believable; avoid sentimentality or hollow melodrama.\\n- **Vivid Details**: Make good use of concrete imagery, sensory descriptions, and action details; avoid abstract generalizations.\\n- **Pacing Control**: Balance tension and release; alternate long and short sentences; combine white space with dense narration.\\n\\n---\",\"en\":\"# Style Selection | Creative Writing |\\n---\\n## 1) Document Style\\n- Output style must be: **Creative Writing**\\n  - Characteristics: Imaginative, emotionally expressive, vivid and beautiful language, emphasis on narrative techniques and literary devices, pursuit of originality and artistic impact.\\n- Output file naming: `[Topic]_CreativeWriting_[YYYY-MM-DD].docx`\\n\\n---\\n## 2) Applicable Scenarios\\n- Short stories and flash fiction\\n- Poetry and prose\\n- Scripts and dialogue writing\\n- Story outlines and plot design\\n- Character profiles and world-building\\n- Advertising copy and brand storytelling\\n- Game narratives and interactive fiction\\n- Personal essays and creative journals\\n\\n---\\n## 3) Document Format\\n- Format requirements: Flexible adjustment based on genre\\n    - **Title**:\\n      - Attractive and suggestive; may use metaphors, suspense, or emotionally charged words.\\n    - **Opening**: Quickly establish atmosphere, introduce conflict, or create suspense; avoid lengthy setup.\\n    - **Narrative Structure**: May adopt linear, flashback, multiple parallel threads, fragmented, or other structures; serve the theme and emotional expression.\\n    - **Dialogue**: Must fit character personality and context; advance plot or reveal inner thoughts.\\n    - **Ending**: Lingering resonance or abrupt conclusion; avoid preachy summaries.\\n\\n---\\n## 4) Output Constraints\\n- **Tone**: Flexibly adjust according to the work's needs; may be lyrical, detached, humorous, absurd, etc.; maintain stylistic consistency.\\n- **Originality**: Content must be original; avoid plagiarism when drawing on classic techniques; encourage unique perspectives and expression.\\n- **Emotional Authenticity**: Emotional expression must be sincere and believable; avoid sentimentality or hollow melodrama.\\n- **Vivid Details**: Make good use of concrete imagery, sensory descriptions, and action details; avoid abstract generalizations.\\n- **Pacing Control**: Balance tension and release; alternate long and short sentences; combine white space with dense narration.\\n\\n---\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"创意写作\",\"en\":\"Creative Writing\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-P3M91c\",\"type\":\"style\",\"contents\":{\"cn\":\"# Style Selection | Technical Documentation |\\n\\n---\\n## 1) Document Style\\n- Output style must be: **Technical Documentation**\\n  - Characteristics: Accurate and clear, task-oriented, well-structured hierarchy, consistent terminology, highly actionable, easy to search and reference.\\n- Output file naming: `[Topic]_TechnicalDoc_v[版本号]_[YYYY-MM-DD].md`\\n\\n---\\n## 2) Applicable Scenarios\\n- API documentation and interface specifications\\n- User manuals and operation guides\\n- System architecture design documents\\n- Installation/deployment/configuration guides\\n- Troubleshooting and FAQs\\n- SDK/developer documentation\\n- Release notes\\n- Internal technical specifications and coding standards\\n\\n---\\n## 3) Document Format\\n- Format requirements: Comply with technical documentation industry standards\\n    - **Title**:\\n      - Clearly describe document content or task objective; avoid vague wording; use verb phrases (e.g., \\\"Configure XX,\\\" \\\"Install XX\\\").\\n    - **Overview/Introduction**: 50-200 words explaining document purpose, target audience, and prerequisites.\\n    - **Body Structure**: Organize by task or module; use clear heading hierarchy (H1-H4); use numbered lists for procedural content.\\n    - **Code Examples**: Use code block format with language type specified; key parameters must include comments.\\n    - **Diagrams**: Flowcharts, architecture diagrams, screenshots, etc. must have titles and descriptive text.\\n\\n---\\n## 4) Output Constraints\\n- **Tone**: Objective, neutral, and professional; use imperative sentences to guide operations (e.g., \\\"Click,\\\" \\\"Enter,\\\" \\\"Run\\\"); avoid colloquial or marketing language.\\n- **Precision**: All terminology, commands, paths, and parameters must be accurate; version numbers and dependencies must be clearly specified.\\n- **Consistency**: Terminology, formatting, and naming conventions must be uniform throughout; the same concept must not use different expressions.\\n- **Actionability**: Steps must be complete and reproducible; assumptions and prerequisites must be clearly stated.\\n- **Maintainability**: Modular organization for easy future updates; avoid hardcoded or outdated information.\\n\\n---\",\"en\":\"# Style Selection | Technical Documentation |\\n\\n---\\n## 1) Document Style\\n- Output style must be: **Technical Documentation**\\n  - Characteristics: Accurate and clear, task-oriented, well-structured hierarchy, consistent terminology, highly actionable, easy to search and reference.\\n- Output file naming: `[Topic]_TechnicalDoc_v[版本号]_[YYYY-MM-DD].md`\\n\\n---\\n## 2) Applicable Scenarios\\n- API documentation and interface specifications\\n- User manuals and operation guides\\n- System architecture design documents\\n- Installation/deployment/configuration guides\\n- Troubleshooting and FAQs\\n- SDK/developer documentation\\n- Release notes\\n- Internal technical specifications and coding standards\\n\\n---\\n## 3) Document Format\\n- Format requirements: Comply with technical documentation industry standards\\n    - **Title**:\\n      - Clearly describe document content or task objective; avoid vague wording; use verb phrases (e.g., \\\"Configure XX,\\\" \\\"Install XX\\\").\\n    - **Overview/Introduction**: 50-200 words explaining document purpose, target audience, and prerequisites.\\n    - **Body Structure**: Organize by task or module; use clear heading hierarchy (H1-H4); use numbered lists for procedural content.\\n    - **Code Examples**: Use code block format with language type specified; key parameters must include comments.\\n    - **Diagrams**: Flowcharts, architecture diagrams, screenshots, etc. must have titles and descriptive text.\\n\\n---\\n## 4) Output Constraints\\n- **Tone**: Objective, neutral, and professional; use imperative sentences to guide operations (e.g., \\\"Click,\\\" \\\"Enter,\\\" \\\"Run\\\"); avoid colloquial or marketing language.\\n- **Precision**: All terminology, commands, paths, and parameters must be accurate; version numbers and dependencies must be clearly specified.\\n- **Consistency**: Terminology, formatting, and naming conventions must be uniform throughout; the same concept must not use different expressions.\\n- **Actionability**: Steps must be complete and reproducible; assumptions and prerequisites must be clearly stated.\\n- **Maintainability**: Modular organization for easy future updates; avoid hardcoded or outdated information.\\n\\n---\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"技术文档\",\"en\":\"Technical Documentation\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"templates\":{\"cn\":\"{style}\",\"en\":\"{style}\"}},\"formats\":{\"id\":\"opt-Ztb9Ce\",\"type\":\"formats\",\"refer\":\"\",\"contents\":{\"cn\":\"格式选择\",\"en\":\"Format Selection\"},\"cascades\":{},\"items\":[{\"id\":\"item-SsV0s2\",\"type\":\"format\",\"contents\":{\"cn\":\"# ===== Output format：Word (.docx) =====\\nThe output of the document must be in Word (.docx) format\\n\\n- **Library**: Use `python-docx`.\\n- **File Naming**: `[主题]_[文体]_[YYYY-MM-DD].pdf`\\n- **Output**: Provide a direct download link after generating the file.\",\"en\":\"# ===== Output format：Word (.docx) =====\\nThe output of the document must be in Word (.docx) format\\n\\n- **Library**: Use `python-docx`.\\n- **File Naming**: `[主题]_[文体]_[YYYY-MM-DD].pdf`\\n- **Output**: Provide a direct download link after generating the file.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"doc\",\"en\":\"doc\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-xeETvR\",\"type\":\"format\",\"contents\":{\"cn\":\"# ===== Output format：PDF =====\\nThe output of the document must be in PDF format.\\n\\n- **Library**: Use `reportlab` (preferred for complex layouts and CJK support) or `fpdf2` with registered CJK fonts.\\n- **File Naming**: `[主题]_[文体]_[YYYY-MM-DD].pdf`\\n- **Output**: Provide a direct download link after generating the file.\",\"en\":\"# ===== Output format：PDF =====\\nThe output of the document must be in PDF format.\\n\\n- **Library**: Use `reportlab` (preferred for complex layouts and CJK support) or `fpdf2` with registered CJK fonts.\\n- **File Naming**: `[主题]_[文体]_[YYYY-MM-DD].pdf`\\n- **Output**: Provide a direct download link after generating the file.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"pdf\",\"en\":\"pdf\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"templates\":{\"cn\":\"{format}\",\"en\":\"{format}\"}},\"prompts\":{\"id\":\"opt-Y7f2fe\",\"type\":\"prompts\",\"refer\":\"\",\"contents\":{\"cn\":\"推荐提示词\",\"en\":\"Recommended Prompts\"},\"cascades\":{},\"items\":[{\"id\":\"item-4YwHmg\",\"type\":\"prompt\",\"contents\":{\"cn\":\"围绕美股英伟达（NVDA），结合 2026 年 1-2 月股价及财务数据，从基础属性、基本面（核心业务 + 财务指标）、行业竞争、技术面、风险提示维度展开分析，突出 AI 算力龙头定位与近期波动原因，客观总结优劣势，不涉买卖建议。\",\"en\":\"Focusing on NVIDIA Corporation (NASDAQ: NVDA), a U.S.-listed stock, this analysis draws on its stock price and financial data from January to February 2026. It covers five dimensions: fundamental attributes, fundamentals (core businesses plus financial metrics), industry competition, technical performance, and risk alerts. The analysis highlights NVIDIA’s position as a leader in AI computing power and the drivers behind its recent stock price fluctuations, objectively summarizes the company’s strengths and weaknesses, and contains no investment recommendations.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"从多个维度写一份英伟达股票分析\",\"en\":\"Write an analysis of NVIDIA’s stock from multiple perspectives.\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"logics\":[\"item-UooUvm\"],\"styles\":[\"item-9Stun9\"],\"formats\":[\"item-xeETvR\"]}},{\"id\":\"item-TSWkl4\",\"type\":\"prompt\",\"contents\":{\"cn\":\"帮我起草一份内部决策备忘录（Word）。我们正在讨论是否要将新用户引导流程改为“默认指南 + 可跳过”。客服担心用户可能会迷失方向，开发部门则表示我们需要再进行一轮埋点。目前我所了解的情况是：本月约有12000个新注册用户，激活率约为35%（指标不确定），流失主要集中在第1天。请先给出建议（支持/反对/试点），然后列出关键假设，最后列出可执行的任务（谁做什么、所需资源、一周内可以完成的事项）。不要编造数据。\",\"en\":\"Help me draft an internal decision memo (Word). We’re debating whether to change onboarding to \\\"default guide + skippable.\\\" Customer service worries users might get lost, development says we need another round of event tracking. What I know so far: about 12,000 new registrations this month, roughly 35% activation (uncertain metric), churn concentrated on day 1. Give suggestions first (support/oppose/pilot), then write key assumptions, and finally actionable tasks (who does what, needed resources, what can be done within one week). Don’t make up data.\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"起草一份有关新用户引导内部讨论决策备忘录\",\"en\":\"Write an internal memo on new-user onboarding decisions\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"logics\":[\"item-QukSRj\"],\"styles\":[\"item-9Stun9\"],\"formats\":[\"item-SsV0s2\"]}},{\"id\":\"item-8GikGu\",\"type\":\"prompt\",\"contents\":{\"cn\":\"请编写一段电影剧本片段。 场景： 破旧的深夜食堂，只有两名食客：一个刚出狱的帮派老大的亲信，和一个现在已经洗白成警察的昔日兄弟。 冲突： 两人正在吃一碗面，表面上在聊‘面咸不咸’，实际上在进行最后一次生死谈判。 要求： > 1. 大量使用潜台词，不准直接提到‘背叛’、‘警察’或‘报复’。 2. 包含细致的动作描写（如：筷子敲击碗缘的声音、香烟升起的烟雾）。 3. 标准剧本格式（场景行、动作段、角色、对白）。”\",\"en\":\"Please write a movie script segment. Scene: A shabby late-night diner with only two diners: a former confidant of a gang leader just released from prison, and a former brother who has now turned into a cop. Conflict: The two are eating a bowl of noodles, seemingly chatting about \\\"whether the noodles are too salty,\\\" but actually conducting a final life-or-death negotiation. Requirements: > 1. Use a lot of subtext and do not directly mention \\\"betrayal,\\\" \\\"cop,\\\" or \\\"revenge.\\\" 2. Include detailed action descriptions (e.g., the sound of chopsticks tapping the edge of the bowl, the rising smoke of a cigarette). 3. Follow the standard script format (scene line, action paragraph, character, dialogue).\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"编写一段深夜食堂兄弟重逢的电影剧本片段\",\"en\":\"Write a film script scene about brothers reuniting in midnight\"},\"descs\":null,\"on_finish\":null,\"defaults\":{\"logics\":[\"item-QukSRj\"],\"styles\":[\"item-ADuujH\"],\"formats\":[\"item-xeETvR\"]}},{\"id\":\"item-MN3INy\",\"type\":\"prompt\",\"contents\":{\"cn\":\"学校橄榄球赛季招商赞助方案（撰写规范）—— 中文翻译\\n你正在撰写一份视觉效果出色、结构清晰的赞助方案，最终将以 Word（DOC）文档 形式提交。\\n作者背景\\n本方案由美国高中学生会代表学校撰写。\\n文档目的\\n本文档旨在向潜在赞助商提供一份清晰、有说服力的赞助方案，为即将举办的学校橄榄球比赛或整个橄榄球赛季争取资金赞助。\\n方案要求\\n介绍橄榄球赛事及其在学校与社区中的重要意义\\n说明赞助资金的具体用途\\n清晰列出赞助合作机会与赞助商可获得的权益\\n说明为何赞助本项赛事能为企业带来有效曝光与社区互动价值\\n目标受众\\n本地企业、社区组织及有意支持青少年体育、教育与社区建设的潜在企业赞助商。\\n整体定位\\n这是一份正式但由学生主导的赞助方案。语气风格要求：\\n积极、充满活力、尊重礼貌\\n专业且亲切易读\\n立足社区、态度真诚避免夸大宣传或过度商业化的语言。\\n必须包含的结构与内容\\n1. 引言\\n简要介绍学校、学生会与橄榄球项目\\n说明本次赞助申请的目的\\n2. 关于橄榄球赛事\\n介绍单场比赛或整个赛季\\n说明橄榄球对校园精神、团队合作与学生生活的重要性\\n预计参与人数（学生、家长、社区居民）\\n3. 赞助资金用途\\n说明资金如何用于支持赛事（装备、场地、队服、活动运营等）\\n重点强调对学生的益处与社区影响\\n4. 赞助合作方案\\n设置不同赞助等级（如黄金、白银、青铜）\\n明确各等级赞助商可获得的权益（logo 展示、现场播报、横幅、秩序册、社交媒体宣传等）\\n5. 赞助商可获得的收益\\n品牌在校园及本地社区内的曝光\\n与青少年成长、教育事业形成正面品牌关联\\n长期合作机会\\n6. 结语与行动呼吁\\n表达感谢\\n为有意向的赞助商提供明确的下一步行动\\n视觉与设计要求（非常重要）\\n文档必须视觉丰富、富有吸引力。需包含并标注以下视觉元素：\\n橄榄球比赛、球员或校园活动的图片或图片占位符\\n对比不同赞助等级与权益的表格\\n用于突出关键信息的高亮框 / 提示框\\n使用如下标注格式：“图片：我校橄榄球队主场比赛现场”“表格：赞助等级与权益总览”\\n视觉设计不仅用于装饰，更要提升清晰度与感染力。\\n颜色与风格规范\\n使用充满活力、符合校园氛围的视觉风格。\\n建议配色（可根据学校主色调整）：\\n主色（章节标题）：深色校色（如藏青、枣红）\\n辅助色（小节标题）：浅色互补色\\n强调色：明亮但不失稳重（如金色、橙色、浅蓝）\\n正文：深灰或黑色\\n表格表头 / 高亮框：浅色、明快背景色\\n用色规则：\\n用色彩建立视觉层级，提升活力\\n避免过于暗沉、单调的设计\\n保证足够对比度，便于阅读\\n撰写与排版要求\\n语言清晰、简洁、友好\\n段落简短易读\\n句子中间不要强行换行\\n适当使用项目符号与表格\\n确保文档在屏幕阅读与打印时均效果良好\\n质量标准\\n文档看起来是一份精心准备的学生会赞助方案\\n赞助商能清晰了解赛事、赞助价值与参与方式\\n最终成品可直接作为 DOC 文件发送，无需再修改\",\"en\":\"You are writing a visually engaging and well-structured sponsorship proposal intended to be delivered as a DOC document.\\nAuthor background:\\nThe proposal is written on behalf of a U.S. high school student council.\\n\\nPurpose of the document:\\nThe goal of this document is to present a clear and compelling proposal to potential sponsors in order to secure financial sponsorship for an upcoming school football game or football season.\\n\\nThe proposal should:\\n- Introduce the football event and its significance within the school and local community\\n- Explain how sponsorship funds will be used\\n- Clearly outline sponsorship opportunities and benefits for sponsors\\n- Demonstrate why sponsoring this event provides meaningful visibility and community engagement\\nTarget audience:\\nLocal businesses, community organizations, and potential corporate sponsors interested in youth sports, education, and community involvement.\\n────────────────\\nOverall positioning:\\nThis is a formal but youth-led sponsorship proposal.\\nThe tone should be:\\n- Positive, energetic, and respectful\\n- Professional but approachable\\n- Community-oriented and sincere\\nAvoid exaggerated claims or overly commercial language.\\n────────────────\\nRequired structure and content:\\n\\n1. Introduction\\n- Brief introduction of the school, student council, and football program\\n- Purpose of the sponsorship request\\n2. About the Football Event\\n- Description of the football game or season\\n- Importance of football to school spirit, teamwork, and student life\\n- Expected attendance (students, families, community members)\\n3. Use of Sponsorship Funds\\n- How sponsorship money will support the event (equipment, facilities, uniforms, event operations, etc.)\\n- Emphasis on student benefit and community impact\\n4. Sponsorship Opportunities\\n- Different sponsorship levels (e.g., Gold, Silver, Bronze)\\n- What sponsors receive at each level (logo placement, announcements, banners, programs, social media mentions, etc.)\\n5. Benefits to Sponsors\\n- Brand visibility within the school and local community\\n- Positive association with youth development and education\\n- Opportunities for long-term partnership\\n6. Conclusion and Call to Action\\n- Expression of appreciation\\n- Clear next steps for interested sponsors\\n────────────────\\nVisual and design requirements (very important):\\n\\nThe document must be visually rich and engaging.\\nInclude and reference visual elements such as:\\n- Photos or image placeholders of football games, players, or school spirit events\\n- Tables comparing sponsorship levels and benefits\\n- Highlight boxes or callouts for key information\\nUse captions such as:\\n\\\"Image: Our school football team during a home game\\\"\\n\\\"Table: Sponsorship levels and benefits overview\\\"\\n\\nVisuals should support clarity and excitement, not decoration only.\\n\\n────────────────\\nColor and style guidelines:\\n\\nUse a colorful, energetic, and school-friendly visual style.\\n\\nSuggested color palette (can be adapted to school colors):\\n- Primary color (section titles): deep school color (e.g., navy blue or maroon)\\n- Secondary color (subsections): lighter complementary color\\n- Accent colors: bright but tasteful tones (e.g., gold, orange, or light blue)\\n- Body text: dark gray or black\\n- Table headers / highlight boxes: light, cheerful background colors\\nColor usage rules:\\n- Use color to create visual hierarchy and excitement.\\n- Avoid overly dark or dull designs.\\n- Ensure good contrast for readability.\\n────────────────\\nWriting and layout constraints:\\n\\n- Use clear, simple, and friendly language.\\n- Paragraphs should be short and easy to read.\\n- Do NOT insert line breaks in the middle of sentences.\\n- Use bullet points and tables where appropriate.\\n- Ensure the document reads well both on screen and when printed.\\nQuality bar:\\n\\n- The document should look like a well-prepared student council sponsorship proposal.\\n- Sponsors should clearly understand the event, the value of sponsorship, and how to get involved.\\n- The final output should be ready to be shared as a DOC file without further editing.\"},\"img\":\"\",\"share_urls\":{},\"labels\":{\"cn\":\"校园橄榄球赛事招商合作方案\",\"en\":\"School Rugby Season Sponsorship & Investment Proposal\"},\"descs\":{\"cn\":\"\",\"en\":\"\"},\"on_finish\":\"\",\"defaults\":{\"logics\":[\"item-UooUvm\"],\"styles\":[\"item-9Stun9\"],\"formats\":[\"item-SsV0s2\"]}}],\"templates\":{\"cn\":\"{prompt}\",\"en\":\"{prompt}\"}}},\"created_at\":1769511209,\"updated_at\":1770790578},{\"scene\":\"full-stack\",\"options\":{\"prompts\":{\"id\":\"opt-v7Cq9v\",\"type\":\"prompts\",\"refer\":\"projects\",\"contents\":{\"cn\":\"推荐提示词\",\"en\":\"Recommended Prompts\"},\"cascades\":{\"item-9Hwrtc\":[{\"id\":\"item-IgZQZZ\",\"type\":\"prompt\",\"contents\":{\"cn\":\"开发一个个人应用「EduTrack」：学生事务管理助手，调用 GLM Skills 实现截图识别，帮助学生管理课程、作业、考试并统计学业进度。\\n\\n技术栈：React/Next.js + TypeScript + TailwindCSS。\\n\\n字体规范：\\n- UI 无衬线：Inter 或 Plus Jakarta Sans（Google Fonts）\\n- 等宽字体（数据、学分、绩点）：IBM Plex Mono 或 JetBrains Mono\\n- 中文回退：system-ui, -apple-system, PingFang SC, Microsoft YaHei\\n- 数字：tabular-nums，便于数据对齐\\n\\n整体风格：Notion 简约风——大量留白、克制配色、清晰层级、卡片式布局、微妙阴影与圆角。\\n\\n功能要求：\\n\\n1. 截图识别（调用 GLM Skills vision）：\\n   - 支持上传/粘贴教务系统截图（课表、成绩单、学分统计等）\\n   - 自动识别并结构化提取：\\n     - 课表：课程名、时间、地点、周次、教师\\n     - 成绩：课程名、学分、成绩、绩点\\n   - 识别结果可预览、编辑、确认后导入系统\\n   - 支持批量识别多张截图\\n\\n2. 课程管理：\\n   - 课程列表：显示所有课程（名称、时间、地点、教师、学分）\\n   - 周课表视图：类似 Notion 日历的周视图，按时间块展示课程\\n   - 今日课程卡片：首页显示当天课程安排\\n   - 支持手动添加/编辑/删除课程\\n\\n3. 作业与考试管理：\\n   - 作业列表：按课程分组或按 DDL 排序\\n   - 考试日历：显示考试时间、地点、倒计时\\n   - 提醒设置：支持设置 DDL 前 1 天/3 天提醒（本地通知或页面提示）\\n   - 状态标记：待完成 / 进行中 / 已完成 / 已逾期\\n   - 快速添加：输入框快速添加作业/考试\\n\\n4. 学业统计：\\n   - GPA 概览：当前 GPA、目标 GPA、趋势图（按学期）\\n   - 学分统计：已修学分 / 总要求学分，分类统计（必修/选修/通识等）\\n   - 成绩分布：饼图或柱状图展示各分数段分布\\n   - 进度条：整体学业完成度可视化\\n   - 数据卡片：关键指标一目了然（总课程数、平均分、最高分等）\\n\\n5. 每日一句：\\n   - 页面顶部展示每日一句（激励/学习/名人名言）\\n   - 调用 API 或内置语录库\\n   - 支持刷新、收藏\\n   - 样式简约：淡灰色背景卡片 + 引号装饰\\n\\n6. 数据持久化：\\n   - localStorage 或 IndexedDB 存储所有数据\\n   - 支持导出数据为 JSON（备份）\\n   - 支持导入数据（恢复）\\n\\nUI 设计（Notion 简约风）：\\n- 配色：白色/浅灰背景 + 深灰文字 + 极少量强调色（蓝色用于链接/按钮，红色用于逾期提醒）\\n- 布局：\\n  - 顶部：每日一句卡片\\n  - 主区域：左侧导航（Dashboard / 课程 / 作业 / 考试 / 统计 / 设置）+ 右侧内容区\\n  - Dashboard 首页：今日课程 + 近期 DDL + GPA 卡片 + 快速操作\\n- 卡片：圆角 8-12px、微妙阴影、hover 时轻微上浮\\n- 列表：简洁行间距、checkbox 样式参考 Notion\\n- 图表：使用 Recharts 或 Chart.js，配色与整体风格一致\\n- 空状态：友好的插图 + 引导文案\\n\\n交互细节：\\n- 截图上传支持拖拽、粘贴、点击选择\\n- 识别过程显示 loading 动画 + 进度提示\\n- 表单输入有实时校验和友好错误提示\\n- 列表支持拖拽排序（作业优先级）\\n- 支持键盘快捷操作（N 新建、E 编辑、Delete 删除）\\n- prefers-reduced-motion 降级\",\"en\":\"# EduTrack: Student Affairs Management Assistant\\nDevelop a personal application called \\\"EduTrack\\\": a student affairs management assistant that leverages GLM Skills for screenshot recognition, helping students manage courses, assignments, exams, and track academic progress.\\n**Tech Stack:** React/Next.js + TypeScript + TailwindCSS\\n---\\n## Typography Specification\\n- **UI Sans-serif:** Inter or Plus Jakarta Sans (Google Fonts)\\n- **Monospace (data, credits, GPA):** IBM Plex Mono or JetBrains Mono\\n- **Chinese Fallback:** system-ui, -apple-system, PingFang SC, Microsoft YaHei\\n- **Numbers:** tabular-nums for data alignment\\n---\\n## Overall Style\\nNotion-inspired minimalism — generous whitespace, restrained color palette, clear hierarchy, card-based layout, subtle shadows and rounded corners.\\n---\\n## Feature Requirements\\n### 1. Screenshot Recognition (via GLM Skills Vision)\\n- Support uploading/pasting screenshots from academic systems (class schedules, transcripts, credit summaries, etc.)\\n- Automatically recognize and extract structured data:\\n  - Class schedule: course name, time, location, week range, instructor\\n  - Grades: course name, credits, score, GPA points\\n- Recognition results can be previewed, edited, and confirmed before importing into the system\\n- Support batch recognition of multiple screenshots\\n### 2. Course Management\\n- Course list: Display all courses (name, time, location, instructor, credits)\\n- Weekly schedule view: Notion-calendar-style week view, displaying courses as time blocks\\n- Today's courses card: Homepage displays the current day's class schedule\\n- Support manual add/edit/delete of courses\\n### 3. Assignment & Exam Management\\n- Assignment list: Grouped by course or sorted by deadline\\n- Exam calendar: Display exam time, location, and countdown\\n- Reminder settings: Support setting reminders 1 day/3 days before deadline (local notifications or in-page alerts)\\n- Status labels: To Do / In Progress / Completed / Overdue\\n- Quick add: Input field for quickly adding assignments/exams\\n### 4. Academic Statistics\\n- GPA overview: Current GPA, target GPA, trend chart (by semester)\\n- Credit statistics: Completed credits / total required credits, categorized breakdown (required/elective/general education, etc.)\\n- Grade distribution: Pie chart or bar chart showing score range distribution\\n- Progress bar: Overall academic completion visualization\\n- Data cards: Key metrics at a glance (total courses, average score, highest score, etc.)\\n### 5. Daily Quote\\n- Display a daily quote at the top of the page (motivational/learning/famous quotes)\\n- Fetch from API or built-in quote library\\n- Support refresh and bookmark\\n- Minimal style: Light gray background card + quotation mark decoration\\n### 6. Data Persistence\\n- localStorage or IndexedDB for all data storage\\n- Support exporting data as JSON (backup)\\n- Support importing data (restore)\\n---\\n## UI Design (Notion Minimalist Style)\\n**Color Scheme:**\\n- White/light gray background + dark gray text + minimal accent colors (blue for links/buttons, red for overdue reminders)\\n**Layout:**\\n- Top: Daily quote card\\n- Main area: Left sidebar navigation (Dashboard / Courses / Assignments / Exams / Statistics / Settings) + right content area\\n- Dashboard homepage: Today's courses + upcoming deadlines + GPA card + quick actions\\n**Cards:**\\n- Border-radius 8-12px, subtle shadows, slight lift on hover\\n**Lists:**\\n- Clean line spacing, checkbox styling inspired by Notion\\n**Charts:**\\n- Use Recharts or Chart.js, color scheme consistent with overall style\\n**Empty States:**\\n- Friendly illustrations + guiding copy\\n---\\n## Interaction Details\\n- Screenshot upload supports drag-and-drop, paste, and click-to-select\\n- Recognition process displays loading animation + progress indicators\\n- Form inputs have real-time validation and friendly error messages\\n- Lists support drag-and-drop sorting (assignment priority)\\n- Keyboard shortcut support (N to create, E to edit, Delete to remove)\\n- prefers-reduced-motion graceful degradation\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/person1.png?auth_key=1801977807-e84bbeb04c614766b7a822d251faa902-0-5de59b5c10e9b5d1e8c1ee4dd2508b32\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/96781d29-b5be-4544-8a5b-9faf95cffc68\",\"en\":\"https://chat.z.ai/s/ad029396-4dfb-48b8-9f79-261c8ce9f0ab\"},\"labels\":{\"cn\":\"个人应用 推荐提示词1\",\"en\":\"Product Recommended Prompt 1\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-6mKlTh\",\"type\":\"prompt\",\"contents\":{\"cn\":\"请开发一个单页个人应用「NoteFlow」：个人知识库管理工具，集成 GLM API 实现 AI 能力。\\n\\n技术栈：React/Next.js + TypeScript。后端可选 Node.js/Express 或 Next.js API Routes。\\n\\n---\\n\\n## 字体规范（必须落实，工具感 + 阅读舒适）\\n- UI 无衬线：Inter（Google Fonts，首选）或 Noto Sans SC（中文优化）。\\n- 等宽字体（代码块、API响应）：JetBrains Mono 或 Fira Code（Google Fonts）。\\n- 正文字号：16px，行高 1.6–1.75；标题字重：600–700。\\n- 回退：system-ui, -apple-system, Segoe UI, Roboto。\\n\\n---\\n\\n## 视觉设计（克制高级 + 专注阅读）\\n\\n### 配色方案\\n- 主色：纯净白底（#fafafa ~ #ffffff），搭配深灰文字（#1a1a1a）\\n- 强调色：智慧蓝（#2563eb）用于按钮、链接、AI 功能高亮\\n- 辅助色：淡灰边框（#e5e5e5）、浅蓝背景（#eff6ff）用于 AI 生成内容区分\\n- 暗色模式：深灰底（#0f0f0f ~ #1a1a1a），浅灰文字（#e5e5e5）\\n\\n### 布局与层次\\n- 左侧：文档树/笔记列表（可折叠，支持嵌套层级，拖拽排序）\\n- 中央：主编辑区（Markdown 实时渲染，所见即所得）\\n- 右侧：AI 助手面板（可展开/收起，显示 AI 对话历史）\\n- 顶部：极简工具栏（标题、搜索、设置、暗色模式切换）\\n\\n### 微交互与动效\\n- 笔记切换：内容淡入淡出（200ms ease）\\n- AI 生成：打字机效果 + 光标闪烁\\n- 文件上传：拖拽区域高亮 + 进度条动画\\n- 面板展开/收起：平滑滑动（250ms ease-out）\\n- 所有动效支持 prefers-reduced-motion 降级\\n\\n---\\n\\n## 核心功能\\n\\n### 1. 知识库管理\\n- 文档树结构：支持无限层级嵌套、拖拽排序、重命名、删除\\n- Markdown 编辑器：实时预览、语法高亮、快捷键支持\\n- 本地存储：使用 IndexedDB 或 localStorage 持久化数据\\n- 搜索功能：全文搜索，支持标题和内容匹配\\n\\n### 2. AI 会议纪要（GLM API）\\n- 音频上传：支持 mp3/wav/m4a 格式\\n- 转录与总结：调用 GLM API 生成结构化会议纪要\\n- 输出格式：\\n  - 会议主题\\n  - 参会要点（自动提取）\\n  - 行动项（待办事项格式）\\n  - 决策记录\\n- 一键插入：将生成的纪要插入当前笔记\\n\\n### 3. 图片/PDF 识别（GLM API Vision）\\n- 拖拽上传：支持图片（jpg/png/webp）和 PDF\\n- OCR 识别：提取文字内容\\n- 智能理解：图表解读、表格结构化、公式识别\\n- 结果编辑：识别结果可直接编辑后插入笔记\\n\\n### 4. 智能内容编辑（GLM API）\\n- 自然语言指令：用户输入编辑指令（如「把这段话改得更正式」「总结这篇笔记」「翻译成英文」）\\n- 选中编辑：选中文本后调用 AI 进行修改\\n- 全文操作：支持整篇笔记的润色、扩写、缩写、格式调整\\n- 历史记录：保留编辑前的版本，支持撤销/重做\\n\\n---\\n\\n## GLM API 集成要点\\n\\ntypescript\\n// API 配置示例\\nconst GLM_API_CONFIG = {\\n  baseUrl: '[https://open.bigmodel.cn/api/paas/v4](https://open.bigmodel.cn/api/paas/v4)',\\n  model: 'glm-4v', // 视觉模型用于图片识别\\n  textModel: 'glm-4', // 文本模型用于会议纪要和编辑\\n};\\n\\n\\n- API Key 存储在环境变量或用户本地配置\\n- 请求需处理 loading、error、timeout 状态\\n- 支持流式输出（SSE）以实现打字机效果\\n\\n---\\n\\n## 用户指引系统\\n\\n### 首次进入引导\\n- 欢迎弹窗介绍三大核心功能：知识库管理 → AI 会议纪要 → 智能编辑\\n- 引导用户配置 GLM API Key\\n\\n### 空状态\\n- 无笔记时显示：「点击左上角 + 创建你的第一篇笔记」\\n- AI 面板空状态：「上传文件或输入指令，开始 AI 协作」\\n\\n### Tooltip 与帮助\\n- 工具栏图标悬停显示功能说明\\n- AI 功能旁显示简短使用提示\\n\\n---\\n\\n## 输出要求\\n完整可运行代码 + 关键实现解释（状态管理、GLM API 调用封装、Markdown 渲染逻辑、本地存储方案）。\",\"en\":\"# NoteFlow: Personal Knowledge Base Management Tool\\n\\nDevelop a single-page personal application called \\\"NoteFlow\\\": a personal knowledge base management tool with integrated GLM API for AI capabilities.\\n\\n**Tech Stack:** React/Next.js + TypeScript. Backend optionally Node.js/Express or Next.js API Routes.\\n\\n---\\n\\n## Typography Specification (Must Implement — Tool-like Feel + Reading Comfort)\\n\\n- **UI Sans-serif:** Inter (Google Fonts, preferred) or Noto Sans SC (optimized for Chinese)\\n- **Monospace (code blocks, API responses):** JetBrains Mono or Fira Code (Google Fonts)\\n- **Body font size:** 16px, line-height 1.6–1.75; heading font-weight: 600–700\\n- **Fallback:** system-ui, -apple-system, Segoe UI, Roboto\\n\\n---\\n\\n## Visual Design (Restrained & Premium + Reading Focus)\\n\\n### Color Scheme\\n\\n- **Primary:** Clean white background (#fafafa ~ #ffffff), paired with dark gray text (#1a1a1a)\\n- **Accent:** Wisdom blue (#2563eb) for buttons, links, and AI feature highlights\\n- **Secondary:** Light gray borders (#e5e5e5), light blue background (#eff6ff) to distinguish AI-generated content\\n- **Dark mode:** Dark gray background (#0f0f0f ~ #1a1a1a), light gray text (#e5e5e5)\\n\\n### Layout & Hierarchy\\n\\n- **Left:** Document tree / note list (collapsible, supports nested hierarchy, drag-and-drop sorting)\\n- **Center:** Main editing area (Markdown live rendering, WYSIWYG)\\n- **Right:** AI assistant panel (expandable/collapsible, displays AI conversation history)\\n- **Top:** Minimalist toolbar (title, search, settings, dark mode toggle)\\n\\n### Micro-interactions & Animations\\n\\n- **Note switching:** Content fade in/out (200ms ease)\\n- **AI generation:** Typewriter effect + cursor blinking\\n- **File upload:** Drag zone highlight + progress bar animation\\n- **Panel expand/collapse:** Smooth slide (250ms ease-out)\\n- All animations support prefers-reduced-motion graceful degradation\\n\\n---\\n\\n## Core Features\\n\\n### 1. Knowledge Base Management\\n\\n- Document tree structure: Supports unlimited nesting levels, drag-and-drop sorting, rename, delete\\n- Markdown editor: Live preview, syntax highlighting, keyboard shortcut support\\n- Local storage: Data persistence using IndexedDB or localStorage\\n- Search: Full-text search, supports title and content matching\\n\\n### 2. AI Meeting Minutes (GLM API)\\n\\n- Audio upload: Supports mp3/wav/m4a formats\\n- Transcription & summary: Call GLM API to generate structured meeting minutes\\n- Output format:\\n  - Meeting topic\\n  - Key discussion points (auto-extracted)\\n  - Action items (to-do format)\\n  - Decision records\\n- One-click insert: Insert generated minutes into the current note\\n\\n### 3. Image/PDF Recognition (GLM API Vision)\\n\\n- Drag-and-drop upload: Supports images (jpg/png/webp) and PDF\\n- OCR recognition: Extract text content\\n- Intelligent understanding: Chart interpretation, table structuring, formula recognition\\n- Result editing: Recognition results can be directly edited before inserting into notes\\n\\n### 4. Intelligent Content Editing (GLM API)\\n\\n- Natural language commands: Users input editing instructions (e.g., \\\"Make this paragraph more formal,\\\" \\\"Summarize this note,\\\" \\\"Translate to English\\\")\\n- Selection editing: Select text and invoke AI for modification\\n- Full-document operations: Support polishing, expanding, condensing, and formatting adjustments for entire notes\\n- Edit history: Preserve pre-edit versions, support undo/redo\\n\\n---\\n\\n## GLM API Integration Key Points\\n\\ntypescript\\n// API configuration example\\nconst GLM_API_CONFIG = {\\n  baseUrl: 'https://open.bigmodel.cn/api/paas/v4',\\n  model: 'glm-4v',        // Vision model for image recognition\\n  textModel: 'glm-4',     // Text model for meeting minutes and editing\\n};\\n\\n- API Key stored in environment variables or user local configuration\\n- Requests must handle loading, error, and timeout states\\n- Support streaming output (SSE) for typewriter effect\\n\\n---\\n\\n## User Guidance System\\n\\n### First-time Onboarding\\n\\n- Welcome modal introducing the three core features: Knowledge Base Management → AI Meeting Minutes → Intelligent Editing\\n- Guide users to configure GLM API Key\\n\\n### Empty States\\n\\n- No notes: \\\"Click the + in the top-left corner to create your first note\\\"\\n- AI panel empty state: \\\"Upload a file or enter a command to start AI collaboration\\\"\\n\\n### Tooltips & Help\\n\\n- Toolbar icons show feature descriptions on hover\\n- Brief usage tips displayed next to AI features\\n\\n---\\n\\n## Output Requirements\\n\\nComplete runnable code + key implementation explanations (state management, GLM API call encapsulation, Markdown rendering logic, local storage solution).\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/person2.png?auth_key=1801977807-88f82147c8f3474cb47e7b0753d77b3e-0-f551af1f45d106b167a11b78c1c2e2d2\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/16585ff4-01e9-4e06-8233-d12b845dd608\",\"en\":\"https://chat.z.ai/s/8aab5209-2378-4372-bfec-009edf2010ac\"},\"labels\":{\"cn\":\"个人应用 推荐提示词2\",\"en\":\"Product Recommended Prompt 2\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-fkjb80\",\"type\":\"prompt\",\"contents\":{\"cn\":\"生成一个互动视觉小说游戏，html 格式，故事背景设定参考科幻小说《Metro》系列，在2013年，世界上大多数的人因为核战争的爆发而死去，地球表面因此成了一片有毒的荒地。人数稀少的幸存者在莫斯科地下的地铁站里存活下来，到了2033年，一整个世代的人在地下长大成人，并且在被突变怪物包围的地铁站都市中求生。玩家扮演阿尔乔姆（Artyom，俄语：Артём），在灾难发生前出生，但在地下长大。他从来没有离开过他的地铁站都市，但一起事件使阿尔乔姆踏上旅程，以警告残存的人类一场即将出现的威胁，他的行动将决定人类的命运。\\n在故事后期基于该系统导向不同结局。\\n 请设计至少 3 个结局\\n HTML 文件需采用 深空蓝 + 荧光 UI + HUD 风格设计。\\n UI布局:立绘不要挡住对话框\\n 增加科幻环境音 BGM，并支持 多存档位与自动保存。\\n 所有角色（人类与异形生物）需生成 写实风科幻立绘。（使用LLM）\",\"en\":\"# Metro-Inspired Interactive Visual Novel Game\\nGenerate an interactive visual novel game in HTML format. The story setting is inspired by the sci-fi novel series *Metro*:\\nIn 2013, most of the world's population perished due to the outbreak of nuclear war, and the Earth's surface became a toxic wasteland. A small number of survivors managed to stay alive in Moscow's underground metro stations. By 2033, an entire generation had grown up underground, surviving in metro station cities surrounded by mutant creatures.\\nThe player takes on the role of **Artyom** (Russian: Артём), who was born before the disaster but raised underground. He has never left his metro station city, but an incident sets Artyom on a journey to warn the remnants of humanity about an imminent threat. His actions will determine the fate of mankind.\\n---\\n## Story & Endings\\n- In the later stages of the story, the system branches toward different endings based on player choices\\n- Design **at least 3 endings**\\n---\\n## Visual & UI Design\\n- The HTML file must adopt a **deep space blue + fluorescent UI + HUD-style** design\\n- **UI layout:** Character portraits must not obstruct the dialogue box\\n---\\n## Audio\\n- Include **sci-fi ambient BGM** (background music)\\n---\\n## Save System\\n- Support **multiple save slots** and **auto-save**\\n---\\n## Character Art\\n- All characters (humans and alien creatures) require **realistic sci-fi style character portraits** (generated using LLM)\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/person3.png?auth_key=1801977807-60682a72de6048c9a9d577541202ed1a-0-94262a1b73b65a46834bea2d0c1add9f\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/1f5be9d6-f3e2-436a-b31c-31554f618475\",\"en\":\"https://chat.z.ai/s/f42e207a-631d-45a1-b63b-4312412edd5f\"},\"labels\":{\"cn\":\"个人应用 推荐提示词3 666\",\"en\":\"Product Recommended Prompt 3\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"item-YfiX4G\":[{\"id\":\"item-Ui8N4k\",\"type\":\"prompt\",\"contents\":{\"cn\":\"你是资深全栈工程师与视觉设计师。请从 0 到 1 创建并可部署一个名为「MonoGlass Gallery」的个人摄影作品集网站。要求：**高级、简约、统一协调**，采用 **奶油白 + 玻璃拟态 + 柔和暖灰** 的浅色体系（非深色），背景与各模块有一定对比度。拒绝模板化。\\n\\n---\\n\\n## 0）硬性标准（页数必须达标）\\n\\n- 必须是 **4 个独立页面**（页数不可少）：\\n1. Home（首页）\\n2. Galleries（画廊）— 关键摄影作品\\n3. Journal（随笔）— 配日常图作品\\n4. Book a Session（预约/联系）\\n- 每页必须包含：\\n- 一个\\\"主视觉组件\\\"（hero / 主模块）\\n- 至少 1 个微交互（hover、滚动、切换、弹层等）\\n- 完整响应式（移动端不退化成普通模板）\\n- 必须生成所有占位内容：文案、图片 URL、数据结构。\\n\\n---\\n\\n## 0.1）图片资源（必须调用 image-generation skill）\\n\\n- 必须调用 **image-generation skill** 生成画廊与首页大图等所有图片资源，禁止低清、过度压缩、强涂抹细节。\\n- 质量标准（硬性）：\\n- 输出格式：PNG 或高质量 JPG\\n- 分辨率：横图 **≥ 2560×1440**；竖图 **≥ 2160×2700**；封面/精选大图建议 **≥ 3200×1800**\\n- 一致性：同一系列照片要保持统一色温、对比度与颗粒风格\\n- 真实感：避免 AI 伪字、异常纹理、重复结构；建筑边缘与细线要干净\\n- 交付方式：必须在代码中给出可直接引用的图片 URL（或导出到 `public/images/...` 并给出文件路径清单）。\\n- 每张图必须配：`alt` + 1 句展签式 caption。\\n\\n---\\n\\n## 1）技术栈（必须落实）\\n\\n- Next.js（App Router）+ TypeScript\\n- TailwindCSS（必须自定义 tokens：颜色、字体、圆角、阴影、间距）\\n- Framer Motion（用于页面转场、列表出现、灯箱动效）\\n- Next/Image（图片优化）\\n- **调用 image-generation SKILLS**\\n\\n---\\n\\n## 2）风格与色调（Style DNA）\\n\\n- 关键词：奶油白、暖灰、玻璃拟态、细线框、柔光、纸张质感。\\n- 背景：**极浅渐变**（ivory → warm gray），叠加很轻的噪声纹理。\\n- 布局：拒绝标准网格卡片堆叠；画廊区使用\\\"错位拼贴 + 留白\\\"设计。\\n- 动效语言：像\\\"展厅灯光扫过与玻璃折射\\\"，克制、缓慢、可读性优先。\\n\\n---\\n\\n## 3）字体系统（必须单独规定并落地）\\n\\n- 标题字体（带高级感的衬线）：Fraunces（Google Fonts）\\n- 正文字体（无衬线 UI）：Manrope（Google Fonts）\\n- 等宽字体（用于日期/编号/参数）：IBM Plex Mono（Google Fonts）\\n- 数字：启用 `tabular-nums`\\n- 必须提供 Next.js `next/font` 引入代码，并展示 3 个字号层级。\\n\\n---\\n\\n## 4）页面结构与内容（4 页要求）\\n\\n### 4.1 Home（首页）\\n\\n- Hero：画廊式开场，左侧为标题组，右侧为\\\"今日精选照片\\\"大图。\\n- 文案：\\n- 标题：**MonoGlass Gallery**\\n- 副标题：**摄影像一间房间，光线决定叙事。**\\n- 署名：**Xavier 泫。**\\n- 交互：\\n- 顶部导航为\\\"胶片标签\\\"样式，hover 有微弱浮起与阴影变化\\n- Hero 图像轻微视差（移动端降级）\\n\\n### 4.2 Galleries（画廊）\\n\\n- 画廊分为 **3 个系列**：\\n1. **Horizon City**（地平线之城）\\n2. **Soft Wind**（柔软的风）\\n3. **Quiet Lake**（静湖）\\n- 每个系列：生成 **6 张**高质量占位图（总计至少 18 张），并给出可直接引用的图片 URL。\\n- 布局：错位拼贴（2–3 种卡片尺寸组合）+ 系列分隔。\\n- 交互闭环：\\n- 点击图片打开灯箱 Lightbox（全屏/近全屏）\\n- 灯箱内支持：左右切换、Esc 关闭、显示标题与一句话说明\\n- 关闭后必须保留滚动位置\\n\\n### 4.3 Journal（随笔）\\n\\n- 生成 **6 篇**短随笔（每篇 80–120 字中文），包含：标题、日期、标签（如 Architecture / Light / Travel）。\\n- **每篇随笔配一张日常摄影图**（与 Galleries 风格区分，更生活化）。\\n- 交互：\\n- 列表项点击展开为阅读态（accordion 或同页 modal）\\n- 支持复制\\\"引用句\\\"（一段可复制的选中文案按钮）\\n\\n### 4.4 Book a Session（预约/联系）\\n\\n- 预约表单（前端校验）：\\n- 姓名（必填）\\n- 邮箱（必填，格式校验）\\n- 拍摄类型（下拉：Portrait / Architecture / Travel）\\n- 预算区间（滑杆：2k–20k）\\n- 备注（必填，至少 10 字）\\n- 提交后：\\n- 成功态（toast + 页面内摘要卡片）\\n- 存入 localStorage：`bookingDrafts`，并展示\\\"最近一次预约请求\\\"\\n- 右侧信息区：虚拟社交链接（Behance / WeChat / QQ），以及\\\"可预约时间段\\\"标签。\\n\\n---\",\"en\":\"# MonoGlass Gallery - Project Specification\\n\\nYou are a senior full-stack engineer and visual designer. Please create and deploy from 0 to 1 a personal photography portfolio website called \\\"MonoGlass Gallery\\\". Requirements: **sophisticated, minimalist, unified and harmonious**, using a **cream white + glassmorphism + soft warm gray** light color system (not dark), with distinct contrast between background and modules. Reject templated designs.\\n\\n---\\n\\n## 0) Hard Standards (Page Count Must Meet Requirements)\\n\\n- Must have **4 independent pages** (cannot be fewer):\\n  1. Home\\n  2. Galleries — key photography works\\n  3. Journal — with daily photo works\\n  4. Book a Session (booking/contact)\\n- Each page must include:\\n  - One \\\"hero visual component\\\" (hero / main module)\\n  - At least 1 micro-interaction (hover, scroll, toggle, modal, etc.)\\n  - Full responsiveness (mobile should not degrade to generic template)\\n  - Must generate all placeholder content: copy, image URLs, data structures.\\n\\n---\\n\\n## 0.1) Image Resources (Must Call image-generation skill)\\n\\n- Must call **image-generation skill** to generate all image resources for galleries and homepage hero images. No low resolution, over-compression, or heavy detail smearing.\\n- Quality standards (mandatory):\\n  - Output format: PNG or high-quality JPG\\n  - Resolution: landscape **≥ 2560×1440**; portrait **≥ 2160×2700**; cover/featured large images recommended **≥ 3200×1800**\\n  - Consistency: photos in the same series must maintain unified color temperature, contrast, and grain style\\n  - Realism: avoid AI artifacts, abnormal textures, repetitive structures; architectural edges and fine lines must be clean\\n  - Delivery method: must provide directly referenceable image URLs in code (or export to `public/images/...` with file path list).\\n  - Each image must include: `alt` + 1 sentence exhibition-style caption.\\n\\n---\\n\\n## 1) Tech Stack (Must Implement)\\n\\n- Next.js (App Router) + TypeScript\\n- TailwindCSS (must customize tokens: colors, fonts, border radius, shadows, spacing)\\n- Framer Motion (for page transitions, list appearances, lightbox animations)\\n- Next/Image (image optimization)\\n- **Call image-generation SKILLS**\\n\\n---\\n\\n## 2) Style & Tone (Style DNA)\\n\\n- Keywords: cream white, warm gray, glassmorphism, thin borders, soft light, paper texture.\\n- Background: **extremely subtle gradient** (ivory → warm gray), layered with very light noise texture.\\n- Layout: reject standard grid card stacking; gallery area uses \\\"staggered collage + whitespace\\\" design.\\n- Animation language: like \\\"gallery lighting sweep and glass refraction,\\\" restrained, slow, readability-first.\\n\\n---\\n\\n## 3) Typography System (Must Be Separately Specified and Implemented)\\n\\n- Headline font (sophisticated serif): Fraunces (Google Fonts)\\n- Body font (sans-serif UI): Manrope (Google Fonts)\\n- Monospace font (for dates/numbers/parameters): IBM Plex Mono (Google Fonts)\\n- Numbers: enable `tabular-nums`\\n- Must provide Next.js `next/font` import code and demonstrate 3 font size levels.\\n\\n---\\n\\n## 4) Page Structure & Content (4 Page Requirements)\\n\\n### 4.1 Home\\n\\n- Hero: gallery-style opening, left side title group, right side \\\"today's featured photo\\\" large image.\\n- Copy:\\n  - Title: **MonoGlass Gallery**\\n  - Subtitle: **Photography is like a room, light determines the narrative.**\\n  - Signature: **Xavier 泫.**\\n- Interactions:\\n  - Top navigation in \\\"film tab\\\" style, hover has subtle lift and shadow change\\n  - Hero image with slight parallax (degraded on mobile)\\n\\n### 4.2 Galleries\\n\\n- Gallery divided into **3 series**:\\n  1. **Horizon City** (地平线之城)\\n  2. **Soft Wind** (柔软的风)\\n  3. **Quiet Lake** (静湖)\\n- Each series: generate **6** high-quality placeholder images (minimum 18 total), provide directly referenceable image URLs.\\n- Layout: staggered collage (2–3 card size combinations) + series separation.\\n- Interaction loop:\\n  - Click image to open Lightbox (full-screen/near full-screen)\\n  - Lightbox supports: left/right navigation, Esc to close, display title and one-line description\\n  - Must preserve scroll position after closing\\n\\n### 4.3 Journal\\n\\n- Generate **6** short essays (80–120 Chinese characters each), including: title, date, tags (such as Architecture / Light / Travel).\\n- **Each essay paired with one daily photography image** (distinguished from Galleries style, more lifestyle-oriented).\\n- Interactions:\\n  - List item click expands to reading mode (accordion or in-page modal)\\n  - Support copying \\\"quote sentences\\\" (selectable text copy button)\\n\\n### 4.4 Book a Session\\n\\n- Booking form (front-end validation):\\n  - Name (required)\\n  - Email (required, format validation)\\n  - Shoot type (dropdown: Portrait / Architecture / Travel)\\n  - Budget range (slider: 2k–20k)\\n  - Notes (required, minimum 10 characters)\\n- After submission:\\n  - Success state (toast + in-page summary card)\\n  - Save to localStorage: `bookingDrafts`, and display \\\"most recent booking request\\\"\\n- Right info area: virtual social links (Behance / WeChat / QQ), and \\\"available time slots\\\" tags.\\n\\n---\\n\\n## Summary\\n\\nThis is a comprehensive specification for building a sophisticated photography portfolio website with:\\n- 4 fully responsive pages\\n- High-quality AI-generated images (18+ photos)\\n- Glassmorphism design aesthetic\\n- Rich micro-interactions\\n- Complete booking system\\n- Custom typography and design tokens\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/full1.png?auth_key=1801923128-c873eb9d7ed44fdea73c17a9e575d84a-0-83657a7a45db01e5040b7c2750f0bebb\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/21cbb3b0-2c3f-40dc-81c7-ec90b17b014f\",\"en\":\"https://chat.z.ai/s/b1a3cb7d-ae1e-49f1-9dc4-b64e9b775822\"},\"labels\":{\"cn\":\"写网站 推荐提示词1\",\"en\":\"Website Recommended Prompt 1\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-pqw8Oh\",\"type\":\"prompt\",\"contents\":{\"cn\":\"为一家高端北京烤鸭餐厅设计网站，给人的感觉要像步入一处皇城根下的老字号——庄重、大气、带有京味儿的从容与底蕴。\\n网站应依靠枣木炉火的温润、片鸭刀工的精湛和老北京的礼数来传达百年技艺的传承与匠心。\\n\\n1. 视觉策略：\\n\\n意象： 皇城根下的匠人美学。微距特写：展示挂炉烤鸭油脂滴落时的琥珀色光泽、主厨片鸭时薄如蝉翼的刀工、以及荷叶饼卷起鸭皮葱丝时的层叠弧度。\\n氛围： 拒绝浮夸与喧闹。视觉上要显得沉稳、庄重、有老北京的体面与讲究。\\n材质： 背景应暗示红墙灰瓦、紫檀雕花、以及被岁月浸润的老榆木的质感。\\n\\n2. 配色方案：\\n\\n基调： 紫檀深褐、故宫红（低饱和）、墨灰。\\n点缀： 烤鸭枣红（核心标志色）、鸭油琥珀金、葱白青绿（低饱和点缀）。\\n字体颜色： 暖象牙白或浅檀色，绝不使用刺眼的纯白。\\n\\n3. 字体设计：\\n\\n标题： 宋体或楷体变体（如方正清刻本悦宋、思源宋体），搭配现代无衬线字体。\\n排版： 品牌故事或技艺传承部分可采用竖排排版，致敬老北京匾额传统；菜单保持横排，模拟老字号手写菜单的质感。\\n\\n4. 页面结构：\\n\\n首屏： 慢动作电影感视频背景：挂炉中枣木明火跳动、烤鸭缓缓旋转、油脂滴落炉火的滋啦声。Logo「京味传承」以鎏金笔触在画面中央缓缓淡入，配一句 slogan：「一炉枣木火，百年片鸭功」。\\n传承哲学： 分屏设计。左侧：关于挂炉与焖炉之别、枣木果木讲究、三十六道工序的文字阐述。右侧：一个缓慢旋转的烤鸭特写（如皮酥油亮的整鸭，或片鸭刀工的定格）。\\n匠心片鸭： 展示片鸭仪式。主厨亲临桌边，108 片或 120 片的讲究，皮肉骨三吃的礼数。仅展示一张片鸭过程的远景照片，保持\\\"功夫在现场\\\"的神秘感。\\n经典搭配： 极简列表，分「传统三吃」「时令京味」「宫廷点心」三档。每档仅配 1 张氛围图，不逐一展示菜品。\\n包间雅座： 展示包间环境。每间以京城地标命名（如「景山厅」「什刹阁」「南锣轩」），配一句老北京俗语点题，不展示全部细节。\\n预订： 一个定制化的日历小组件，完美融入暗色主题；支持选择人数、烤鸭数量（需提前预订）、是否需要片鸭服务。\\n\\n5. 交互细节：\\n\\n- 页面滚动时，背景有轻微炉火跳动的光影效果（类似枣木火焰的温暖摇曳）\\n- 鼠标悬停菜品名称时，边缘泛起淡金色微光（如鸭油琥珀光泽）\\n- 加载动画：一只烤鸭缓缓旋转，逐渐呈现金黄色泽的动效\\n\\n整体氛围：庄重、大气、传承与匠心并存、皇城根下的老北京体面。\",\"en\":\"# Premium Peking Duck Restaurant Website - Design Specification\\nDesign a website for a high-end Peking duck restaurant. The experience should feel like stepping into a time-honored establishment at the foot of the Imperial City — dignified, grand, with the unhurried composure and cultural depth of old Beijing.\\nThe website should convey a century of inherited artistry and craftsmanship through the warmth of jujube wood fire, the exquisite knife skills of duck carving, and the propriety and etiquette of old Beijing.\\n---\\n## 1. Visual Strategy\\n**Imagery:** Artisan aesthetics at the foot of the Imperial City. Macro close-ups: showcasing the amber gloss of fat dripping from a hung-oven roast duck, the chef's paper-thin carving skills as delicate as cicada wings, and the layered curves of lotus leaf pancakes rolled with crispy duck skin and scallion shreds.\\n**Atmosphere:** Reject ostentation and noise. Visually, it should appear composed, dignified, with the decorum and refinement of old Beijing.\\n**Textures:** The background should evoke red palace walls and gray tiles, zitan (red sandalwood) carvings, and the patina of aged elm wood weathered by time.\\n---\\n## 2. Color Scheme\\n**Base Tones:**\\n- Zitan deep brown\\n- Forbidden City red (low saturation)\\n- Ink gray\\n**Accent Colors:**\\n- Roast duck jujube red (core brand color)\\n- Duck fat amber gold\\n- Scallion white-green (low saturation accent)\\n**Font Colors:**\\n- Warm ivory white or light sandalwood tone\\n- Never use harsh pure white\\n---\\n## 3. Typography\\n**Headlines:**\\n- Song (Ming) or Kai typeface variants (e.g., Fangzheng Qingke Yuesong, Source Han Serif), paired with modern sans-serif fonts\\n**Layout:**\\n- Brand story or heritage sections may use vertical text layout, paying homage to the tradition of old Beijing signboard plaques\\n- Menus remain in horizontal layout, simulating the texture of hand-written menus from time-honored establishments\\n---\\n## 4. Page Structure\\n### Hero Section\\n- Slow-motion cinematic video background: jujube wood flames dancing in the hung oven, duck slowly rotating, the sizzling sound of fat dripping into the fire\\n- Logo \\\"京味传承\\\" (Heritage of Beijing Flavor) fades in at center with gilded brushstroke, accompanied by a slogan: **\\\"One furnace of jujube wood fire, a century of duck-carving mastery\\\"**\\n### Heritage Philosophy\\n- Split-screen design\\n- Left: text exposition on the difference between hung-oven and braised-oven methods, the importance of jujube and fruit wood selection, and the thirty-six step process\\n- Right: a slowly rotating close-up of roast duck (crispy-skinned, glistening whole duck, or a freeze-frame of carving knife work)\\n### Artisan Duck Carving\\n- Showcase the duck carving ceremony\\n- The head chef comes tableside; the ritual of 108 or 120 precise slices; the etiquette of the three-way tasting — skin, meat, and bone\\n- Display only one wide-angle photograph of the carving process, preserving the mystique of \\\"the mastery is in the moment\\\"\\n### Classic Pairings\\n- Minimalist list, divided into three tiers: \\\"Traditional Three-Way Tasting,\\\" \\\"Seasonal Beijing Flavors,\\\" and \\\"Imperial Dim Sum\\\"\\n- Each tier accompanied by only 1 atmosphere photograph; individual dishes are not shown one by one\\n### Private Dining Rooms\\n- Showcase private room environments\\n- Each room named after a Beijing landmark (e.g., \\\"Jingshan Hall,\\\" \\\"Shichahai Pavilion,\\\" \\\"Nanluogu Lounge\\\")\\n- Accompanied by an old Beijing proverb to set the tone; full details are not revealed\\n### Reservations\\n- A customized calendar widget, seamlessly integrated into the dark theme\\n- Supports selection of party size, number of roast ducks (advance booking required), and whether tableside carving service is needed\\n---\\n## 5. Interaction Details\\n- While scrolling, the background features a subtle flickering firelight effect (resembling the warm sway of jujube wood flames)\\n- On hover over dish names, a faint golden glow emanates from the edges (like the amber sheen of duck fat)\\n- Loading animation: a roast duck slowly rotating, gradually revealing its golden-brown luster\\n---\\n## Overall Atmosphere\\n- Dignified\\n- Grand\\n- Heritage and craftsmanship coexisting\\n- The decorum and respectability of old Beijing at the foot of the Imperial City\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/full2_cn.png?auth_key=1801923563-6df5d56b62c448a79675d30ed24100d8-0-098e118f3df1fedcf7aa158a0264bc1d\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/3b013b32-e2de-4c5e-a7c6-372907e5a013\",\"en\":\"https://chat.z.ai/s/d06a0c76-9bc0-447c-ab4e-4f256563873a\"},\"labels\":{\"cn\":\"写网站 推荐提示词2\",\"en\":\"Website Recommended Prompt 2\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-aTM9hY\",\"type\":\"prompt\",\"contents\":{\"cn\":\"你是资深全栈工程师和电商 UI/UX 专家。请从 0 到 1 构建一个亚马逊风格的高转化电商商品详情页（Product Detail Page）。\\n\\n类型：网站\\n\\n技术栈：HTML5 + CSS3 + 原生 JavaScript，样式框架使用 TailwindCSS（CDN 引入最新版），图标库使用 Font Awesome 6.0+（CDN），字体使用 Noto Sans SC（思源黑体）+ Amazon Ember 风格回退。\\n\\n---\\n\\n## 风格定位（Amazon DNA）\\n\\n视觉基调：信息密度优先、功能导向、克制装饰、极致清晰。\\n\\n配色方案：\\n- 主背景：纯白 #FFFFFF\\n- 辅助背景：浅灰 #F7F8F8（面板分隔）\\n- 主文字：深灰 #0F1111\\n- 次要文字：#565959\\n- 链接/强调：Amazon 蓝 #007185（hover: #C7511F 橙色）\\n- 价格高亮：#B12704（深红）\\n- 促销标签：#CC0C39（红）、#067D62（绿色 Deal）\\n- 按钮主色：Amazon 黄 #FFD814（hover: #F7CA00）、橙色 #FFA41C\\n- 边框：#DDD / #D5D9D9\\n\\n布局原则：\\n- PC 端：左侧商品图区（40%）+ 右侧信息区（35%）+ 最右侧 Buy Box（25%）三栏布局\\n- 移动端：上下单栏布局，Buy Box 吸底固定\\n- 信息分区清晰，使用细边框和浅灰背景区分模块\\n- 无多余装饰，内容即界面\\n\\n---\\n\\n## 页面结构与功能模块\\n\\n### 1. 顶部导航\\n- 面包屑导航：首页 > 品类 > 子品类 > 当前商品（可点击返回）\\n- 简洁单行，字号 12-13px，颜色 #565959，hover 下划线\\n\\n### 2. 商品展示模块（左侧）\\n\\n主图区域：\\n- 大图展示区：正方形 1:1 比例，白色背景\\n- 图片放大镜效果：hover 时右侧弹出放大预览区（2x-3x 放大），鼠标移动实时追踪\\n- 原生 JS 实现：监听 mousemove 计算坐标，动态设置 background-position\\n\\n缩略图列表：\\n- 主图左侧或下方垂直/水平排列（5-7 张）\\n- hover 高亮边框（#C7511F 橙色）+ 主图实时切换\\n- 支持视频缩略图（播放图标覆盖）\\n- 当前选中项边框加粗\\n\\n交互细节：\\n- 图片切换使用 fade 过渡（0.2s ease）\\n- 点击主图可打开全屏 Lightbox 查看大图\\n\\n### 3. 商品信息模块（中间）\\n\\n标题区：\\n- 商品名称：字号 24px，字重 400，颜色 #0F1111，最多 3 行\\n- 品牌链接：\\\"Visit the [Brand] Store\\\" 蓝色可点击\\n- 副标题/卖点：字号 14px，#565959\\n\\n评分区（紧贴标题下方）：\\n- 星级评分：Font Awesome 实心/空心星组合，颜色 #FFA41C\\n- 评分数值：如 \\\"4.7 out of 5 stars\\\"\\n- 评价数量：蓝色链接 \\\"12,847 ratings\\\" + 跳转锚点\\n- 销量标签：\\\"10K+ bought in past month\\\"（#565959）\\n\\n价格区（核心转化区）：\\n- 现价：字号 28px，字重 400，颜色 #B12704，符号 ¥/$ 字号稍小\\n- 原价：字号 14px，#565959，删除线\\n- 折扣标签：红色背景 Badge \\\"-35%\\\" 或 \\\"Limited time deal\\\"\\n- 优惠信息：绿色文字 \\\"Save ¥200 with coupon\\\"\\n- 分期提示：\\\"¥XX/月 × 12期 免息\\\" 小字说明\\n\\n促销标签栏：\\n- 横向排列：\\\"Prime\\\"、\\\"免邮\\\"、\\\"闪购\\\"、\\\"新品\\\" 等标签\\n- 样式：小圆角 Badge，背景色区分类型\\n\\n规格选择模块：\\n- 颜色选择：圆形色块 + 文字标签，选中态橙色边框 + 勾选图标\\n- 尺寸/容量选择：矩形按钮组，选中态边框加粗 #C7511F\\n- 库存联动：\\n  - 可选规格：正常显示\\n  - 库存不足（<5）：显示 \\\"仅剩 3 件\\\" 红色提醒\\n  - 缺货规格：置灰 + 删除线 + 不可点击\\n- 价格联动：切换规格实时更新价格、库存、预计送达\\n- DOM 操作实时更新，无页面刷新\\n\\n### 4. Buy Box 购买模块（右侧固定宽度卡片）\\n\\n卡片样式：\\n- 白色背景 + 细边框 #D5D9D9 + 圆角 8px + 微阴影\\n- 固定宽度 280-300px（PC），移动端吸底全宽\\n\\n价格重复展示：\\n- 现价大字 + 原价划线（与信息区同步）\\n\\n配送信息：\\n- 配送地址：\\\"Deliver to [城市]\\\" 蓝色可点击切换\\n- 预计送达：\\\"最快明天送达\\\" 绿色加粗 + 具体日期\\n- 倒计时：\\\"X 小时 XX 分钟内下单\\\" 红色紧迫感\\n- 运费：\\\"免运费\\\" 或 \\\"运费 ¥XX\\\"\\n- 包邮标识：Prime 图标 + \\\"FREE Delivery\\\"\\n\\n库存状态：\\n- 有货：\\\"In Stock\\\" 绿色 #067D62\\n- 库存紧张：\\\"Only X left in stock - order soon\\\" 橙色\\n- 缺货：\\\"Currently unavailable\\\" 红色\\n\\n数量选择：\\n- 下拉选择器或 +/- 按钮组\\n- 最小 1，最大为当前库存\\n- 输入验证：非数字、超范围自动修正 + 提示\\n\\n操作按钮（垂直排列）：\\n- Add to Cart：Amazon 黄 #FFD814，圆角全圆，hover 加深\\n- Buy Now：Amazon 橙 #FFA41C，圆角全圆\\n- 按钮宽度 100%，高度 36-40px，字号 14px\\n- 点击反馈：scale(0.98) + 颜色加深 0.1s\\n\\n加购成功反馈：\\n- 侧边滑出 Toast 或顶部绿色条：\\\"已加入购物车 ✓\\\"\\n- 显示购物车数量更新\\n\\n收藏功能：\\n- 心形图标 + \\\"Add to Wish List\\\" 文字链接\\n- 点击切换实心/空心 + 颜色变化 + 提示 \\\"已收藏\\\"\\n\\n安全承诺：\\n- 小图标 + 文字：Ships from and sold by [店铺名]\\n- 退换保障图标列表\\n\\n### 5. 商品详情 Tabs 模块\\n\\nTab 标签栏：\\n- 选项：商品参数 | 详情图文 | 用户评价 | 相关推荐\\n- 选中态：下划线 #C7511F，字色加深\\n- 切换动画：内容区 fade + slide 过渡（0.3s ease）\\n\\n商品参数：\\n- 两列表格布局，斑马纹背景\\n- 参数名左对齐灰色，参数值右对齐黑色\\n\\n详情图文：\\n- 图文混排，图片懒加载\\n- A+ Content 风格：大图 + 卖点文字模块化\\n\\n用户评价：\\n- 评分分布：横向柱状图（5星到1星占比）\\n- 评价列表：\\n  - 用户头像 + 昵称 + 认证标签\\n  - 星级 + 评价标题\\n  - 评价正文（展开/收起）\\n  - 晒图缩略图（点击放大预览）\\n  - 有用数 + \\\"Helpful\\\" 按钮\\n- 筛选：按星级、有图、关键词\\n- 分页或加载更多\\n\\n相关推荐：\\n- 横向滚动卡片列表（同品类/搭配商品）\\n- 卡片：图片 + 标题（2行截断）+ 星级 + 价格\\n- 左右箭头翻页，支持触摸滑动\\n\\n### 6. 售后服务模块\\n\\n服务承诺图标栏：\\n- 横向排列 4-6 个图标 + 文字：\\n  - ✓ 7天无理由退换\\n  - ✓ 正品保障\\n  - ✓ 假一赔十\\n  - ✓ 极速退款\\n  - ✓ 运费险\\n- 点击展开详细说明\\n\\n退换货流程：\\n- 折叠面板：点击展开流程步骤图\\n\\n### 7. 底部模块\\n\\n- 相关商品推荐（\\\"Customers who viewed this item also viewed\\\"）\\n- 浏览历史\\n- 平台服务链接（帮助中心、售后政策等）\\n\\n---\\n\\n## 技术实现要点\\n\\n图片放大镜（原生 JS）：\\njavascript\\n// 监听主图 mousemove\\n// 计算鼠标相对位置百分比\\n// 设置放大预览区 background-position\\n// mouseenter 显示，mouseleave 隐藏\\n\\n\\n规格-库存-价格联动：\\njavascript\\n// 数据结构：SKU 矩阵 { color, size, price, stock, image }\\n// 监听规格选择变化\\n// 查询对应 SKU 数据\\n// DOM 更新：价格、库存状态、主图、送达时间\\n\\n\\n数量输入验证：\\njavascript\\n// input 事件：过滤非数字\\n// change 事件：范围校验 [1, maxStock]\\n// 实时更新小计金额\\n\\n\\nTab 切换动画：\\ncss\\n.tab-content { opacity: 0; transform: translateY(10px); transition: all 0.3s ease; }\\n.tab-content.active { opacity: 1; transform: translateY(0); }\\n\\n\\n---\\n\\n## 响应式断点\\n\\n- Desktop：≥1200px，三栏布局\\n- Tablet：768-1199px，两栏（图+信息），Buy Box 下移\\n- Mobile：<768px，单栏上下布局，Buy Box 吸底固定\\n\\n---\\n\\n## 输出要求\\n\\n1. 完整可运行的单 HTML 文件（内联 CSS + JS）\\n2. 使用 CDN 引入 TailwindCSS 和 Font Awesome\\n3. 提供模拟商品数据（JSON 格式）\\n4. 所有交互功能可演示\\n5. 代码注释清晰，模块划分明确\",\"en\":\"# Amazon-Style High-Conversion E-Commerce Product Detail Page - Specification\\nYou are a senior full-stack engineer and e-commerce UI/UX expert. Please build from 0 to 1 an Amazon-style high-conversion e-commerce Product Detail Page.\\n**Type:** Website\\n**Tech Stack:** HTML5 + CSS3 + Vanilla JavaScript. Styling framework: TailwindCSS (CDN, latest version). Icon library: Font Awesome 6.0+ (CDN). Fonts: Noto Sans SC + Amazon Ember style fallback.\\n---\\n## Style Positioning (Amazon DNA)\\n**Visual Tone:** Information density first, function-oriented, restrained decoration, ultimate clarity.\\n**Color Scheme:**\\n- Primary background: Pure white #FFFFFF\\n- Secondary background: Light gray #F7F8F8 (panel separation)\\n- Primary text: Dark gray #0F1111\\n- Secondary text: #565959\\n- Links/emphasis: Amazon blue #007185 (hover: #C7511F orange)\\n- Price highlight: #B12704 (deep red)\\n- Promo tags: #CC0C39 (red), #067D62 (green Deal)\\n- Button primary: Amazon yellow #FFD814 (hover: #F7CA00), orange #FFA41C\\n- Borders: #DDD / #D5D9D9\\n**Layout Principles:**\\n- Desktop: Left product image area (40%) + middle info area (35%) + right Buy Box (25%) three-column layout\\n- Mobile: Single-column vertical layout, Buy Box sticky at bottom\\n- Clear information zoning, using thin borders and light gray backgrounds to separate modules\\n- No excess decoration, content is the interface\\n---\\n## Page Structure & Functional Modules\\n### 1. Top Navigation\\n- Breadcrumb: Home > Category > Subcategory > Current Product (clickable to navigate back)\\n- Clean single line, font size 12-13px, color #565959, hover underline\\n### 2. Product Display Module (Left)\\n**Main Image Area:**\\n- Large display area: Square 1:1 ratio, white background\\n- Image magnifier effect: On hover, a zoom preview area pops out on the right (2x-3x magnification), real-time mouse tracking\\n- Vanilla JS implementation: Listen to mousemove to calculate coordinates, dynamically set background-position\\n**Thumbnail List:**\\n- Vertical/horizontal arrangement on the left or below the main image (5-7 images)\\n- Hover highlights border (#C7511F orange) + real-time main image switching\\n- Support video thumbnails (play icon overlay)\\n- Currently selected item has bold border\\n**Interaction Details:**\\n- Image switching uses fade transition (0.2s ease)\\n- Clicking the main image opens a fullscreen Lightbox for viewing\\n### 3. Product Information Module (Middle)\\n**Title Area:**\\n- Product name: Font size 24px, weight 400, color #0F1111, max 3 lines\\n- Brand link: \\\"Visit the [Brand] Store\\\" blue clickable\\n- Subtitle/selling points: Font size 14px, #565959\\n**Rating Area (directly below title):**\\n- Star rating: Font Awesome filled/empty star combination, color #FFA41C\\n- Rating value: e.g., \\\"4.7 out of 5 stars\\\"\\n- Review count: Blue link \\\"12,847 ratings\\\" + anchor jump\\n- Sales label: \\\"10K+ bought in past month\\\" (#565959)\\n**Price Area (core conversion zone):**\\n- Current price: Font size 28px, weight 400, color #B12704, currency symbol slightly smaller\\n- Original price: Font size 14px, #565959, strikethrough\\n- Discount badge: Red background badge \\\"-35%\\\" or \\\"Limited time deal\\\"\\n- Coupon info: Green text \\\"Save $200 with coupon\\\"\\n- Installment hint: \\\"$XX/month x 12 months interest-free\\\" small text\\n**Promo Tag Bar:**\\n- Horizontal layout: \\\"Prime\\\", \\\"Free Shipping\\\", \\\"Flash Sale\\\", \\\"New Arrival\\\" etc.\\n- Style: Small rounded badges, background color distinguishes types\\n**Spec Selection Module:**\\n- Color selection: Circular swatches + text labels, selected state orange border + checkmark icon\\n- Size/capacity selection: Rectangular button group, selected state bold border #C7511F\\n- Stock linkage:\\n  - Available specs: Normal display\\n  - Low stock (<5): Show \\\"Only 3 left\\\" red warning\\n  - Out of stock specs: Grayed out + strikethrough + not clickable\\n- Price linkage: Switching specs updates price, stock, estimated delivery in real-time\\n- DOM operations for real-time updates, no page refresh\\n### 4. Buy Box Module (Right side fixed-width card)\\n**Card Style:**\\n- White background + thin border #D5D9D9 + border-radius 8px + subtle shadow\\n- Fixed width 280-300px (desktop), full-width sticky bottom (mobile)\\n**Price Repeat Display:**\\n- Large current price + strikethrough original price (synced with info area)\\n**Delivery Information:**\\n- Delivery address: \\\"Deliver to [City]\\\" blue clickable to switch\\n- Estimated delivery: \\\"Fastest delivery tomorrow\\\" green bold + specific date\\n- Countdown: \\\"Order within X hours XX minutes\\\" red urgency\\n- Shipping: \\\"Free shipping\\\" or \\\"Shipping $XX\\\"\\n- Free shipping badge: Prime icon + \\\"FREE Delivery\\\"\\n**Stock Status:**\\n- In stock: \\\"In Stock\\\" green #067D62\\n- Low stock: \\\"Only X left in stock - order soon\\\" orange\\n- Out of stock: \\\"Currently unavailable\\\" red\\n**Quantity Selection:**\\n- Dropdown selector or +/- button group\\n- Min 1, max is current stock\\n- Input validation: Non-numbers, out-of-range auto-correction + prompt\\n**Action Buttons (vertical layout):**\\n- Add to Cart: Amazon yellow #FFD814, fully rounded, hover darkens\\n- Buy Now: Amazon orange #FFA41C, fully rounded\\n- Button width 100%, height 36-40px, font size 14px\\n- Click feedback: scale(0.98) + color darken 0.1s\\n**Add to Cart Success Feedback:**\\n- Side-sliding Toast or top green bar: \\\"Added to cart \\\\u2713\\\"\\n- Show cart quantity update\\n**Wishlist Feature:**\\n- Heart icon + \\\"Add to Wish List\\\" text link\\n- Click toggles filled/empty + color change + \\\"Added to wishlist\\\" prompt\\n**Security Assurance:**\\n- Small icon + text: Ships from and sold by [Store Name]\\n- Return/exchange guarantee icon list\\n### 5. Product Detail Tabs Module\\n**Tab Bar:**\\n- Options: Specifications | Detail Images | User Reviews | Related Products\\n- Selected state: Underline #C7511F, text color darkened\\n- Switch animation: Content area fade + slide transition (0.3s ease)\\n**Specifications:**\\n- Two-column table layout, zebra-stripe background\\n- Parameter name left-aligned gray, parameter value right-aligned black\\n**Detail Images:**\\n- Mixed image-text layout, image lazy loading\\n- A+ Content style: Large images + selling point text modularized\\n**User Reviews:**\\n- Rating distribution: Horizontal bar chart (5-star to 1-star percentages)\\n- Review list:\\n  - User avatar + nickname + verified badge\\n  - Star rating + review title\\n  - Review body (expand/collapse)\\n  - Photo thumbnails (click to enlarge preview)\\n  - Helpful count + \\\"Helpful\\\" button\\n- Filters: By star rating, with photos, keyword\\n- Pagination or load more\\n**Related Products:**\\n- Horizontal scrolling card list (same category/complementary products)\\n- Card: Image + title (2-line truncation) + star rating + price\\n- Left/right arrow pagination, supports touch swipe\\n### 6. After-Sales Service Module\\n**Service Guarantee Icon Bar:**\\n- 4-6 icons + text in horizontal layout:\\n  - \\\\u2713 7-day no-reason return/exchange\\n  - \\\\u2713 Authenticity guarantee\\n  - \\\\u2713 Counterfeit goods 10x compensation\\n  - \\\\u2713 Express refund\\n  - \\\\u2713 Shipping insurance\\n- Click to expand detailed description\\n**Return/Exchange Process:**\\n- Collapsible panel: Click to expand process step diagram\\n### 7. Footer Module\\n- Related product recommendations (\\\"Customers who viewed this item also viewed\\\")\\n- Browsing history\\n- Platform service links (Help Center, After-sales Policy, etc.)\\n---\\n## Technical Implementation Key Points\\n**Image Magnifier (Vanilla JS):**\\n// Listen to main image mousemove\\n// Calculate mouse relative position percentage\\n// Set zoom preview area background-position\\n// mouseenter to show, mouseleave to hide\\n**Spec-Stock-Price Linkage:**\\n// Data structure: SKU matrix { color, size, price, stock, image }\\n// Listen to spec selection changes\\n// Query corresponding SKU data\\n// DOM update: price, stock status, main image, delivery time\\n**Quantity Input Validation:**\\n// input event: Filter non-numbers\\n// change event: Range validation [1, maxStock]\\n// Real-time subtotal amount update\\n**Tab Switch Animation:**\\n.tab-content { opacity: 0; transform: translateY(10px); transition: all 0.3s ease; }\\n.tab-content.active { opacity: 1; transform: translateY(0); }\\n---\\n## Responsive Breakpoints\\n- Desktop: >=1200px, three-column layout\\n- Tablet: 768-1199px, two-column (image + info), Buy Box moves below\\n- Mobile: <768px, single-column vertical layout, Buy Box sticky at bottom\\n---\\n## Output Requirements\\n1. Complete runnable single HTML file (inline CSS + JS)\\n2. Use CDN to import TailwindCSS and Font Awesome\\n3. Provide mock product data (JSON format)\\n4. All interactive features demonstrable\\n5. Clear code comments, well-defined module separation\"},\"img\":\"https://z-cdn-media.chatglm.cn/prompts-rich-media-resources/full3_cn.png?auth_key=1801923542-0177d84e6a7946798e3d6dd2c1350036-0-41c37d474599795573c172524f0ffc0c\",\"share_urls\":{\"cn\":\"https://chat.z.ai/s/16df8486-f60d-48ca-afad-00f5ed41c520\",\"en\":\"https://chat.z.ai/s/dddc287e-7896-4fcf-8255-506f9ffbc6a6\"},\"labels\":{\"cn\":\"写网站 推荐提示词3\",\"en\":\"Website Recommended Prompt 3\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}]},\"items\":[],\"templates\":{\"cn\":\"使用推荐提示词: {prompt}\",\"en\":\"Use recommended prompt: {prompt}\"}},\"projects\":{\"id\":\"opt-UbY88J\",\"type\":\"projects\",\"refer\":\"\",\"contents\":{\"cn\":\"项目类型\",\"en\":\"Project Type\"},\"cascades\":{},\"items\":[{\"id\":\"item-YfiX4G\",\"type\":\"project\",\"contents\":{\"cn\":\"平台网站构建\",\"en\":\"Website\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"平台网站构建\",\"en\":\"Website\"},\"descs\":null,\"on_finish\":null,\"defaults\":null},{\"id\":\"item-9Hwrtc\",\"type\":\"project\",\"contents\":{\"cn\":\"工具产品开发\",\"en\":\"Product\"},\"img\":null,\"share_urls\":null,\"labels\":{\"cn\":\"工具产品开发\",\"en\":\"Product\"},\"descs\":null,\"on_finish\":null,\"defaults\":null}],\"templates\":{\"cn\":\"选择项目类型: {project}\",\"en\":\"Choose project type: {project}\"}}},\"created_at\":1769511209,\"updated_at\":1770871623}]}"
